<Window x:Class="DnDBattle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DnDBattle"
        xmlns:controls="clr-namespace:DnDBattle.Controls"
        xmlns:battlegrid="clr-namespace:DnDBattle.Controls.BattleGrid"
        xmlns:views="clr-namespace:DnDBattle.Views"
        Title="DnD Battle Builder" 
        Height="950" Width="1720"
        MinHeight="700" MinWidth="1000"
        Background="#1A1A1D"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#0E639C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1177BB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#C42B1C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Header Style -->
        <Style x:Key="SidebarHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
            <!-- <Setter Property="TextTransform" Value="Uppercase"/> -->
        </Style>

        <!-- Panel Style -->
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="Auto"/>
            <!-- Initiative Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ==================== MENU BAR ==================== -->
        <Menu Grid.Row="0" Background="#1E1E1E" Foreground="White" Padding="5,3">
            <MenuItem Header="_File" Foreground="White">
                <MenuItem Header="Save Encounter..." Click="MenuSaveEncounter_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Load Encounter..." Click="MenuLoadEncounter_Click" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="Import SRD Pack..." Click="MenuImportSrdPack_Click"/>
                <Separator/>
                <MenuItem Header="Settings..." Click="MenuOptions_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="MenuExit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Edit" Foreground="White">
                <MenuItem Header="Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="Redo" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_Map">
                <MenuItem Header="Load Tile Map..." Click="LoadTileMap_Click"/>
                <MenuItem Header="Clear Tile Map" Click="ClearTileMap_Click"/>
                <Separator/>
                <MenuItem Header="Open Tile Map Editor..." Click="OpenTileMapEditor_Click"/>
            </MenuItem>
            <MenuItem Header="_Encounter" Foreground="White">
                <Button Content="📋 Encounter Builder" 
                        Click="BtnEncounterBuilder_Click" />
                <Separator/>
                <MenuItem Header="Encounter Templates..." Click="MenuEncounterTemplates_Click"/>
            </MenuItem>
            <MenuItem Header="_Database" Foreground="White">
                <MenuItem Header="Import JSON to Database..." Click="MenuImportDatabase_Click"/>
                <MenuItem Header="Reload from Database" Click="MenuReloadDatabase_Click"/>
                <Separator/>
                <MenuItem Header="Database Statistics" Click="MenuDatabaseStats_Click"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="White">
                <MenuItem Header="Toggle Left Sidebar" Click="ToggleLeftSidebar_Click" InputGestureText="F9"/>
                <MenuItem Header="Toggle Right Sidebar" Click="ToggleRightSidebar_Click" InputGestureText="F10"/>
                <Separator/>
                <MenuItem Header="Grid Settings..." Click="MenuGridSettings_Click"/>
                <Separator/>
                <MenuItem Header="Fog of War">
                    <MenuItem Header="Enable Fog of War" Click="EnableFog_Click" x:Name="MenuFogEnabled" IsCheckable="True"/>
                    <MenuItem Header="Fog Mode">
                        <MenuItem Header="Exploration (stays revealed)" Click="FogExploration_Click" x:Name="MenuFogExploration" IsCheckable="True" IsChecked="True"/>
                        <MenuItem Header="Dynamic (reverts to fog)" Click="FogDynamic_Click" x:Name="MenuFogDynamic" IsCheckable="True"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Reveal All (DM)" Click="RevealAllFog_Click"/>
                    <MenuItem Header="Reset Fog" Click="ResetFog_Click"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="🧱 Walls" Foreground="White">
                <MenuItem Header="Draw Solid Wall" Click="DrawSolidWall_Click"/>
                <MenuItem Header="Draw Door" Click="DrawDoor_Click"/>
                <MenuItem Header="Draw Window" Click="DrawWindow_Click"/>
                <MenuItem Header="Draw Half Wall" Click="DrawHalfWall_Click"/>
                <Separator/>
                <MenuItem Header="🏠 Draw Room (Solid)" Click="DrawRoom_Click"/>
                <MenuItem Header="🚪 Draw Room (with Doors)" Click="DrawRoomWithDoors_Click"/>
                <Separator/>
                <MenuItem Header="Stop Drawing" Click="StopWallDraw_Click"/>
                <Separator/>
                <MenuItem Header="Clear All Walls" Click="ClearAllWalls_Click"/>
            </MenuItem>

            <MenuItem Header="Tools" Foreground="White">
                <MenuItem Header="Tile Map Builder" Click="OpenTileMapBuilder_Click"/>
            </MenuItem>
        </Menu>
        

        <!-- ==================== TOOLBAR ==================== -->
        <Border Grid.Row="1" Background="#252526" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Toolbar Items -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="➕ Add Creature" 
                            Command="{Binding OpenCreatureBrowserCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="🗺️ Load Map" 
                            Command="{Binding LoadMapCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,8,0"/>

                    <Rectangle Width="1" Fill="#444" Margin="8,2"/>

                    <Button Content="↩️" ToolTip="Undo (Ctrl+Z)" Click="Undo_Click"
                            Style="{StaticResource ModernButton}" Width="36" Margin="0,0,4,0"/>
                    <Button Content="↪️" ToolTip="Redo (Ctrl+Y)" Click="Redo_Click"
                            Style="{StaticResource ModernButton}" Width="36"/>
                </StackPanel>

                <!-- Center - Combat Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="{Binding IsInCombat, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="#1B5E20" CornerRadius="4" Padding="15,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚔️ COMBAT" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" - Round " Foreground="#AAA" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentRound}" Foreground="#4CAF50" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Toolbar Items -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="💡 Light" Click="AddLight_Click"
                            Style="{StaticResource ModernButton}" Margin="0,0,8,0"/>
                    <CheckBox Content="🔒 Snap to Grid" 
                              IsChecked="{Binding ElementName=BattleGrid, Path=LockToGrid}" 
                              Foreground="White" VerticalAlignment="Center"/>

                    <Rectangle Width="1" Fill="#444" Margin="8,2"/>

                    <Button x:Name="BtnMeasure" Content="📏" ToolTip="Measure Distance"
                        Click="ToggleMeasure_Click"
                        Style="{StaticResource ModernButton}" Width="36" Margin="0,0,4,0"/>

                    <!--<CheckBox Content="Grid"  IsChecked="{Binding ElementName=BattleGrid, Path=ShowGrid}" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Show/Hide Grid Lines"/>

                    <CheckBox Content="Coords" IsChecked="{Binding ElementName=BattleGrid, Path=ShowCoordinates}" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Show/Hide Coordinate Labels"/> -->

                    <Rectangle Width="1" Fill="#444" Margin="8,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="280" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="RightSidebarColumn" Width="300" MinWidth="350" MaxWidth="450"/>
            </Grid.ColumnDefinitions>

            <!-- ========== LEFT SIDEBAR ========== -->
            <Border Grid.Column="0" Background="#1E1E1E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Initiative Tracker (takes remaining space) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Splitter -->
                        <RowDefinition Height="320" MinHeight="100" MaxHeight="400"/>
                        <!-- Action Log -->
                    </Grid.RowDefinitions>

                    <!-- Initiative Tracker -->
                    <views:InitiativeTrackerPanel x:Name="InitiativeTracker" 
                                       Grid.Row="0"
                                       Margin="0"/>

                    <!-- Horizontal Splitter -->
                    <GridSplitter Grid.Row="1" 
                      Height="5" 
                      HorizontalAlignment="Stretch"
                      Background="#333"
                      Cursor="SizeNS"/>

                    <StackPanel Orientation="Horizontal" Margin="10,0" Grid.Row="1">
                        <TextBlock Text="⏳ Pending Spawns:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock x:Name="TxtPendingSpawns" Text="0" FontWeight="Bold" 
                                   VerticalAlignment="Center" Foreground="{StaticResource Brush_Warning}"/>
                    </StackPanel>

                    <!-- Action Log at Bottom -->
                    <Border Grid.Row="2" Background="#1E1E1E" Padding="10,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                           Text="ACTION LOG" 
                           Style="{StaticResource SidebarHeader}"
                           Margin="0,5,0,8"/>

                            <Border Grid.Row="1" Background="#252526" CornerRadius="6">
                                <ListBox ItemsSource="{Binding ActionLog}" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="#CCC"
                             FontFamily="Consolas"
                             FontSize="10"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Margin="8,3">
                                    <Run Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}" Foreground="#555"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Source}" Foreground="#4FC3F7"/>
                                    <Run Text=": " Foreground="#555"/>
                                    <Run Text="{Binding Message}" Foreground="#AAA"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Left Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                          Background="#1A1A1D" Cursor="SizeWE"/>

            <!-- ========== BATTLE MAP (CENTER) ========== -->
            <Border Grid.Column="2" Background="#202030" CornerRadius="8" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Area Effect Toolbar -->
                    <StackPanel>
                        <views:AreaEffectToolbar x:Name="AoeToolbar" 
                        Grid.Row="0"
                        Visibility="Visible"/>

                        <views:FogOfWarToolbar x:Name="FogToolbar" 
                       Grid.Row="0"
                       Visibility="Visible"/>
                    </StackPanel>
                    

                    <!-- Battle Grid - NOTE: Grid.Row="1" is required! -->
                    <battlegrid:BattleGridControl x:Name="BattleGrid"
                                                Grid.Row="1"
                                                GridCellSize="48"
                                                LockToGrid="True"
                                                Tokens="{Binding Tokens}"
                                                SelectedToken="{Binding SelectedToken, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <!-- Right Splitter -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" 
                          Background="#1A1A1D" Cursor="SizeWE"/>

            <!-- ========== RIGHT SIDEBAR ========== -->
            <GridSplitter Grid.Column="3" 
                          Width="3" 
                          Background="#333"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="4" 
                    Background="#252526" 
                    MinWidth="380"
                    MaxWidth="500">
                <views:SelectedTokenPanel x:Name="SelectedTokenPanel"/>
            </Border>
        </Grid>

        <!-- ==================== INITIATIVE BAR (BOTTOM) ==================== -->
        <Border Grid.Row="3" Background="#252526" Padding="10,8"
                Visibility="{Binding IsInCombat, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Round Counter -->
                <Border Grid.Column="0" Background="#1B5E20" CornerRadius="4" Padding="12,6" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Round " Foreground="#AAA" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentRound}" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Initiative Order (Horizontal Scroll) -->
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InitiativeOrderList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,0" CornerRadius="6" Padding="12,8" MinWidth="120" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2D2D30"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentTurn}" Value="True">
                                                    <Setter Property="Background" Value="#0E639C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" 
                                                   TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Background="#4FC3F7" CornerRadius="8" Padding="6,2" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Initiative}" Foreground="Black" FontWeight="Bold" FontSize="11"/>
                                            </Border>
                                            <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center">
                                                <Run Text="HP:  "/><Run Text="{Binding HP}" Foreground="#4CAF50"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Turn Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0">
                    <Button Content="◀ Prev" Command="{Binding PreviousTurnCommand}"
                            Style="{StaticResource ModernButton}" Margin="0,0,8,0"/>
                    <Button Content="Next ▶" Command="{Binding NextTurnCommand}"
                            Padding="15,8" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="4" Background="#007ACC" Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="Status_Cursor" Text="Cell:  -,-" 
                           Foreground="White" Margin="0,0,20,0"/>
                <TextBlock Grid.Column="1" x:Name="Status_Mode" Text="Mode: Normal" 
                           Foreground="White" Margin="0,0,20,0"/>
                <TextBlock Grid.Column="3" x:Name="Status_Undo" Text="Undo:  0 | Redo: 0" 
                           Foreground="White"/>
            </Grid>
        </Border>

        <!-- ==================== LOADING OVERLAY ==================== -->
        <Border Grid.RowSpan="5" 
                Background="#DD1A1A1D"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                Panel.ZIndex="9999">
            <Border Background="#252526" CornerRadius="12" Padding="40,30"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="300" Height="6" 
                                 Background="#1E1E1E" Foreground="#007ACC"/>
                    <TextBlock Text="{Binding LoadingMessage}" 
                               Foreground="White" 
                               FontSize="16" 
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <TextBlock Text="Please wait..."
                               Foreground="#666"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>