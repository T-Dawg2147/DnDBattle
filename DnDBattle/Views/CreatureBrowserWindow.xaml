<UserControl x:Class="DnDBattle.Views.CreatureBrowserWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DnDBattle.Views"
             xmlns:vm="clr-namespace:DnDBattle.ViewModels"
             mc:Ignorable="d" 
             MinWidth="700" MinHeight="480" Background="DarkSlateGray">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBox x:Name="TxtSearch" Width="220" Margin="0,0,8,0" VerticalAlignment="Center" 
                     TextChanged="TxtSearch_TextChanged" Foreground="White"/>
            <ComboBox x:Name="CmbCategory" Width="160" Margin="0,0,8,0" VerticalAlignment="Center"
                      ItemsSource="{Binding Categories}" 
                      SelectedItem="{Binding SelectedCategory}" 
                      SelectionChanged="CmbCategory_SelectionChanged"/>
            <ComboBox x:Name="CmbType" Width="100" Margin="0,0,8,0" VerticalAlignment="Center" 
                      SelectionChanged="CmbType_SelectionChanged"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <TextBlock Text="CR:" VerticalAlignment="Center" Margin="2" Foreground="White"/>
                <TextBox x:Name="TxtCRMin" Width="48" Margin="4,0" TextChanged="FilterNumeric_TextChanged" Foreground="White"/>
                <TextBlock Text="—" VerticalAlignment="Center" Foreground="White"/>
                <TextBox x:Name="TxtCRMax" Width="48" Margin="4,0" TextChanged="FilterNumeric_TextChanged" Foreground="White"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <TextBlock Text="HP:" VerticalAlignment="Center" Margin="2" Foreground="White"/>
                <TextBox x:Name="TxtHPMin" Width="48" Margin="4,0" TextChanged="FilterNumeric_TextChanged" Foreground="White"/>
                <TextBlock Text="—" VerticalAlignment="Center" Foreground="White"/>
                <TextBox x:Name="TxtHPMax" Width="48" Margin="4,0" TextChanged="FilterNumeric_TextChanged" Foreground="White"/>
            </StackPanel>

            <ComboBox x:Name="CmbSort" Width="160" VerticalAlignment="Center" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Tag="Name">Sort: Name</ComboBoxItem>
                <ComboBoxItem Tag="CR">Sort: Challenge Rating</ComboBoxItem>
                <ComboBoxItem Tag="MaxHP">Sort: Max HP</ComboBoxItem>
            </ComboBox>

            <ToggleButton x:Name="ToggleSortDesc" Content="Desc" Margin="8,0,0,0" VerticalAlignment="Center" Checked="ToggleSort_Checked" Unchecked="ToggleSort_Checked"/>
        </StackPanel>

        <!-- Result list (virtualized) -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#444" Background="{StaticResource AppDarkBg}">
            <ListView x:Name="LvResults" Margin="6"
                      ItemsSource="{Binding CreatureBankView}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      SelectionMode="Single"
                      MouseDoubleClick="LvResults_MouseDoubleClick">

                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add Tag..." Click="ContextMenu_AddTag_Click"/>
                        <MenuItem Header="Remove Tag..." Click="ContextMenu_RemoveTag_Click"/>
                        <Separator/>
                        <MenuItem Header="Quick Tags">
                            <MenuItem Header="Mark as Favourite" Click="ContextMenu_QuickTag_Favourite"/>
                            <MenuItem Header="Mark as Boss" Click="ContextMenu_QuickTag_Boss"/>
                            <MenuItem Header="Mark as Monster" Click="ContextMenu_QuickTag_Monster"/>
                            <MenuItem Header="Mark as NPC" Click="ContextMenu_QuickTag_NPC"/>
                        </MenuItem>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="40" Height="40" Background="#222" CornerRadius="3" Grid.Column="0">
                                <Image Source="{Binding IconPath}" Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                                <TextBlock FontSize="11" Foreground="#bbb" Text="{Binding Type}" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="{Binding ChallengeRating}"/>
                            <TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="{Binding MaxHP}"/>
                            <TextBlock Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ccc" Text="{Binding Speed}" />

                            <Button Grid.Column="5" Content="Add" Width="64" Margin="6,0,0,0" Click="BtnAdd_Click" Tag="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Background="#FF2D2D30"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Click="BtnClose_Click" Width="90" Margin="8,0"/>
        </StackPanel>
    </Grid>
</UserControl>
