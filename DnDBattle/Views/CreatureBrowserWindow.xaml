<UserControl x:Class="DnDBattle.Views.CreatureBrowserWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             MinWidth="900" MinHeight="600" Background="#1E1E1E"
             Loaded="CreatureBrowserWindow_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300" MinWidth="250"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT PANEL: Categories ========== -->
        <Border Grid.Column="0" Background="#252526" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="📚 LIBRARY" 
                           Foreground="#4FC3F7" FontWeight="Bold" 
                           FontSize="12" Margin="0,0,0,10"/>

                <!-- Category Tree -->
                <TreeView x:Name="CategoryTree" Grid.Row="1" 
                          Background="Transparent" BorderThickness="0"
                          SelectedItemChanged="CategoryTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- Category Actions -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Content="➕ New Category" Click="NewCategory_Click"
                            Padding="8,5" Margin="0,0,0,5"/>
                    <Button Content="📝 Rename" Click="RenameCategory_Click"
                            Padding="8,5" Margin="0,0,0,5"
                            x:Name="BtnRenameCategory"/>
                    <Button Content="🗑️ Delete" Click="DeleteCategory_Click"
                            Padding="8,5"
                            x:Name="BtnDeleteCategory"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                      Background="#1E1E1E" Cursor="SizeWE"/>

        <!-- ========== CENTER: Creature List ========== -->
        <Border Grid.Column="2" Background="#1E1E1E" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBox x:Name="TxtSearch" 
                             Padding="30,8,10,8" 
                             FontSize="14"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderBrush="#444"
                             TextChanged="TxtSearch_TextChanged"/>
                    <TextBlock Text="🔍" 
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="#888"/>
                </Grid>

                <!-- Favorites Section -->
                <Expander Grid.Row="1" Header="⭐ Favorites" IsExpanded="True" Margin="0,0,0,10"
                          Foreground="White" Background="Transparent">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Expander.Style>
                    <Border Background="#252526" CornerRadius="4" Padding="8" MaxHeight="120">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="FavoritesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#3E3E42" CornerRadius="4" Padding="8,5" 
                                                Margin="0,0,6,6" Cursor="Hand"
                                                MouseLeftButtonDown="Favorite_Click"
                                                ToolTip="{Binding Name}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⭐" Margin="0,0,5,0" Foreground="Gold"/>
                                                <TextBlock Text="{Binding Name}" Foreground="White" 
                                                           MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text=" CR " Foreground="#666" FontSize="10" 
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ChallengeRating}" Foreground="#888" 
                                                           FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Filter Bar -->
                <Border Grid.Row="2" Background="#252526" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                    <WrapPanel Orientation="Horizontal">
                        <TextBlock Text="CR:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtCRMin" Width="40" Margin="0,0,3,0" 
                                 TextChanged="FilterChanged" Background="#1E1E1E" Foreground="White"
                                 BorderBrush="#444"/>
                        <TextBlock Text="—" Foreground="#666" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="TxtCRMax" Width="40" Margin="0,0,15,0"
                                 TextChanged="FilterChanged" Background="#1E1E1E" Foreground="White"
                                 BorderBrush="#444"/>

                        <TextBlock Text="Type:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="CmbTypeFilter" Width="120" Margin="0,0,15,0" 
                                  SelectionChanged="CmbTypeFilter_SelectionChanged"
                                  Background="#1E1E1E"/>

                        <TextBlock Text="Group:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="CmbGroupBy" Width="100" Margin="0,0,15,0"
                                  SelectionChanged="CmbGroupBy_SelectionChanged"
                                  Background="#1E1E1E">
                            <ComboBoxItem Content="None" Tag="None"/>
                            <ComboBoxItem Content="Type" Tag="Type" IsSelected="True"/>
                            <ComboBoxItem Content="CR" Tag="ChallengeRating"/>
                            <ComboBoxItem Content="Size" Tag="Size"/>
                        </ComboBox>

                        <Button Content="Clear" Padding="10,3" Click="BtnClearFilters_Click"/>

                        <TextBlock x:Name="TxtCreatureCount" Foreground="#888" 
                                   VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </WrapPanel>
                </Border>

                <!-- Creature Tree View -->
                <TreeView x:Name="CreatureTree" Grid.Row="3" 
                    Background="Transparent" BorderThickness="0"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    SelectedItemChanged="CreatureTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="IsExpanded" Value="False"/>
                            <!-- Start collapsed! -->
                            <Setter Property="Padding" Value="2"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="➕ Create Creature" Click="CreateCreature_Click"
                            Padding="12,8" Margin="0,0,10,0"/>
                    <Button Content="📥 Import JSON" Click="ImportJson_Click"
                            Padding="12,8" Margin="0,0,10,0"/>
                    <Button Content="📁 Import Folder" Click="ImportFolder_Click"
                            Padding="12,8" Margin="0,0,10,0"/>
                    <Button Content="🔄 Reload" Click="BtnReload_Click"
                            Padding="12,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== RIGHT PANEL: Creature Details ========== -->
        <Border Grid.Column="3" Background="#252526" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailsPanel">
                    <!-- Placeholder -->
                    <TextBlock x:Name="TxtNoSelection" 
                               Text="Select a creature to view details"
                               Foreground="#666" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,50,0,0"/>

                    <!-- Creature Details -->
                    <StackPanel x:Name="CreatureDetails" Visibility="Collapsed">
                        <!-- Header with Image -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Creature Image -->
                            <Border Grid.Column="0" 
                                Width="64" Height="64" 
                                CornerRadius="8" 
                                Background="#1E1E1E"
                                Margin="0,0,12,0">
                                <Image x:Name="ImgCreatureDetail" 
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCreatureName" FontSize="20" FontWeight="Bold" 
                                    Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtCreatureSubtitle" FontSize="11" 
                                    Foreground="#888" FontStyle="Italic" TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="2" x:Name="BtnFavorite" Content="☆" FontSize="24"
                                Click="BtnFavorite_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="Gray" Cursor="Hand" ToolTip="Toggle Favorite"
                                VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Stats -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <UniformGrid Columns="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="AC" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAC" Foreground="#4FC3F7" FontSize="18" 
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="HP" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtHP" Foreground="#4CAF50" FontSize="18" 
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CR" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtCR" Foreground="#FFB74D" FontSize="18" 
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <!-- Ability Scores -->
                        <TextBlock Text="Ability Scores" Foreground="#4FC3F7" FontWeight="Bold" 
                                   FontSize="11" Margin="0,0,0,8"/>
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                            <UniformGrid Columns="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="STR" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtStr" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="DEX" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtDex" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CON" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtCon" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="INT" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtInt" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="WIS" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtWis" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CHA" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtCha" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <!-- Speed -->
                        <TextBlock Text="Speed" Foreground="#4FC3F7" FontWeight="Bold" 
                                   FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtSpeed" Foreground="#CCC" Margin="0,0,0,15" TextWrapping="Wrap"/>

                        <!-- Traits -->
                        <StackPanel x:Name="TraitsSection" Margin="0,0,0,15">
                            <TextBlock Text="Traits" Foreground="#4FC3F7" FontWeight="Bold" 
                                       FontSize="11" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtTraits" Foreground="#CCC" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel x:Name="ActionsSection">
                            <TextBlock Text="Actions" Foreground="#F44336" FontWeight="Bold" 
                                       FontSize="11" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="ActionsList"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Margin="0,20,0,0">
                            <Button Content="➕ Add to Battle Map" Click="BtnAddToMap_Click"
                                    Padding="15,10" FontWeight="Bold"
                                    Background="#4CAF50" Foreground="White"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Button Content="📝 Edit" Click="EditCreature_Click"
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="📋 Duplicate" Click="DuplicateCreature_Click"
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="🗑️ Delete" Click="DeleteCreature_Click"
                                        Padding="10,5" Foreground="#F44336"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Import Progress Overlay -->
        <Border x:Name="ImportProgressOverlay" 
                Grid.ColumnSpan="4"
                Background="#DD1A1A1D" 
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border Background="#252526" CornerRadius="12" Padding="30,20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="350">
                <StackPanel>
                    <TextBlock x:Name="ImportProgressTitle" 
                               Text="Importing Creatures..." 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <ProgressBar x:Name="ImportProgressBar" 
                                 Height="8" 
                                 Minimum="0" Maximum="100" Value="0"
                                 Background="#1E1E1E" 
                                 Foreground="#007ACC"/>

                    <TextBlock x:Name="ImportProgressText" 
                               Text="Preparing..." 
                               Foreground="#AAA" 
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>

                    <TextBlock x:Name="ImportProgressDetail" 
                               Text="" 
                               Foreground="#666" 
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="300"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>