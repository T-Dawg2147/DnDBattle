<Window x:Class="DnDBattle.Views.Features.Phase7CombatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚔️ Phase 7: Combat Automation"
        Width="640" Height="1060"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}" Foreground="{StaticResource Brush_Text_Primary}"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Info}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Width" Value="160"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <TextBlock Text="⚔️ Phase 7: Combat Automation" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush_Info}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtSelectedToken" Text="Selected Token: (none)" Foreground="{StaticResource Brush_Warning}" FontSize="13" Margin="0,0,0,12"/>

            <!-- 7.1 Attack Roll System -->
            <GroupBox Header="🎯 7.1 Attack Roll System">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableAttackRolls" Content="Enable Attack Roll System" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAutoApplyDamage" Content="Auto-Apply Damage on Hit" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <TextBlock Text="Attack Form:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Target:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbAttackTarget" Style="{StaticResource FieldCombo}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Attack Bonus:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtAttackBonus" Style="{StaticResource FieldInput}" Text="5" Width="60"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Damage:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDamageExpression" Style="{StaticResource FieldInput}" Text="2d6+3"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Attack Mode:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbAttackMode" Style="{StaticResource FieldCombo}" SelectedIndex="0">
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="Advantage"/>
                            <ComboBoxItem Content="Disadvantage"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="🎲 Roll Attack" Click="RollAttack_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtAttackResult" Text="" Foreground="{StaticResource Brush_Success}" TextWrapping="Wrap" FontSize="12" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 7.2 Saving Throw Automation -->
            <GroupBox Header="🛡️ 7.2 Saving Throw Automation">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableSavingThrows" Content="Enable Saving Throw Automation" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAutoRollMonsterSaves" Content="Auto-Roll Monster Saves" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <TextBlock Text="Save Form:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Ability:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbSaveAbility" Style="{StaticResource FieldCombo}" SelectedIndex="0">
                            <ComboBoxItem Content="Strength"/>
                            <ComboBoxItem Content="Dexterity"/>
                            <ComboBoxItem Content="Constitution"/>
                            <ComboBoxItem Content="Intelligence"/>
                            <ComboBoxItem Content="Wisdom"/>
                            <ComboBoxItem Content="Charisma"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="DC:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtSaveDC" Style="{StaticResource FieldInput}" Text="15" Width="60"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Damage (opt):" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtSaveDamage" Style="{StaticResource FieldInput}" Text=""/>
                    </StackPanel>
                    <Button Content="🎲 Roll Saving Throw" Click="RollSave_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtSaveResult" Text="" Foreground="{StaticResource Brush_Success}" TextWrapping="Wrap" FontSize="12" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 7.3 Spell Slot Tracking -->
            <GroupBox Header="📖 7.3 Spell Slot Tracking">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableSpellSlots" Content="Enable Spell Slot Tracking" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <TextBlock Text="Initialize Slots:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Caster Level:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbCasterLevel" Style="{StaticResource FieldCombo}" Width="60" SelectedIndex="0">
                            <ComboBoxItem Content="1"/><ComboBoxItem Content="2"/><ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/><ComboBoxItem Content="5"/><ComboBoxItem Content="6"/>
                            <ComboBoxItem Content="7"/><ComboBoxItem Content="8"/><ComboBoxItem Content="9"/>
                            <ComboBoxItem Content="10"/><ComboBoxItem Content="11"/><ComboBoxItem Content="12"/>
                            <ComboBoxItem Content="13"/><ComboBoxItem Content="14"/><ComboBoxItem Content="15"/>
                            <ComboBoxItem Content="16"/><ComboBoxItem Content="17"/><ComboBoxItem Content="18"/>
                            <ComboBoxItem Content="19"/><ComboBoxItem Content="20"/>
                        </ComboBox>
                        <TextBlock Text="  Type:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox x:Name="CmbCasterType" Width="80" SelectedIndex="0">
                            <ComboBoxItem Content="Full"/>
                            <ComboBoxItem Content="Half"/>
                            <ComboBoxItem Content="Third"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="📖 Initialize Slots for Selected Token" Click="InitializeSlots_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>

                    <TextBlock Text="Current Slots:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <TextBlock x:Name="TxtSlotDisplay" Text="No slots initialized." Foreground="{StaticResource Brush_Info}" TextWrapping="Wrap" FontSize="12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Slot Level:" Style="{StaticResource FieldLabel}" Width="70"/>
                        <ComboBox x:Name="CmbSlotLevel" Width="50" SelectedIndex="0">
                            <ComboBoxItem Content="1"/><ComboBoxItem Content="2"/><ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/><ComboBoxItem Content="5"/><ComboBoxItem Content="6"/>
                            <ComboBoxItem Content="7"/><ComboBoxItem Content="8"/><ComboBoxItem Content="9"/>
                        </ComboBox>
                        <Button Content="Use Slot" Click="UseSlot_Click" Style="{StaticResource ActionButton}" Margin="6,0"/>
                        <Button Content="Restore Slot" Click="RestoreSlot_Click" Style="{StaticResource ActionButton}" Margin="6,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="🌙 Long Rest" Click="LongRest_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="☀️ Short Rest" Click="ShortRest_Click" Style="{StaticResource ActionButton}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 7.4 Concentration Tracking -->
            <GroupBox Header="🔮 7.4 Concentration Tracking">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableConcentration" Content="Enable Concentration Tracking" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAutoPromptConcentration" Content="Auto-Prompt Concentration Check on Damage" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <TextBlock x:Name="TxtConcentrationStatus" Text="Not concentrating." Foreground="{StaticResource Brush_Warning}" Margin="0,6,0,4" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Spell Name:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtConcentrationSpell" Style="{StaticResource FieldInput}" Text="" Width="160"/>
                    </StackPanel>
                    <Button Content="🔮 Start Concentration" Click="StartConcentration_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Damage Taken:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtConcentrationDamage" Style="{StaticResource FieldInput}" Text="10" Width="60"/>
                    </StackPanel>
                    <Button Content="⚡ Check Concentration" Click="CheckConcentration_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtConcentrationResult" Text="" Foreground="{StaticResource Brush_Success}" TextWrapping="Wrap" FontSize="12" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 7.5 Condition Automation -->
            <GroupBox Header="⚠️ 7.5 Condition Automation">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableConditions" Content="Enable Condition Automation" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 When enabled, conditions automatically affect combat:" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                    <TextBlock Text="• Paralyzed/Unconscious: Auto-fail STR/DEX saves, attacks within 5ft auto-crit" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11"/>
                    <TextBlock Text="• Stunned: Auto-fail STR/DEX saves, attacks have advantage" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11"/>
                    <TextBlock Text="• Blinded/Invisible: Affect attack advantage/disadvantage" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11"/>
                    <TextBlock Text="• Frightened/Poisoned/Restrained: Attack roll disadvantage" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11"/>
                    <TextBlock Text="• Prone: Melee attacks have advantage, ranged have disadvantage" Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </GroupBox>

            <!-- 7.6 Cover System -->
            <GroupBox Header="🧱 7.6 Cover System">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableCover" Content="Enable Cover System" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkUseSelectedTokens" Content="Use Selected Tokens for Attacker/Defender" IsChecked="True"/>

                    <TextBlock Text="Manual Position Override:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Attacker (X,Y):" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtAttackerX" Style="{StaticResource FieldInput}" Text="0" Width="40" Margin="0,0,4,0"/>
                        <TextBox x:Name="TxtAttackerY" Style="{StaticResource FieldInput}" Text="0" Width="40"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Defender (X,Y):" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDefenderX" Style="{StaticResource FieldInput}" Text="5" Width="40" Margin="0,0,4,0"/>
                        <TextBox x:Name="TxtDefenderY" Style="{StaticResource FieldInput}" Text="5" Width="40"/>
                    </StackPanel>
                    <Button Content="🧱 Calculate Cover" Click="CalculateCover_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtCoverResult" Text="" Foreground="{StaticResource Brush_Success}" TextWrapping="Wrap" FontSize="12" Margin="0,4"/>
                    <TextBlock Text="💡 Cover bonuses: Half (+2 AC), Three-Quarters (+5 AC), Full (cannot be targeted)." Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
