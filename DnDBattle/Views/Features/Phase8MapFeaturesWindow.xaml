<Window x:Class="DnDBattle.Views.Features.Phase8MapFeaturesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🗺️ Phase 8: Advanced Map Features"
        Width="640" Height="1060"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}" Foreground="{StaticResource Brush_Text_Primary}"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Info}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Width" Value="160"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <TextBlock Text="🗺️ Phase 8: Advanced Map Features" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush_Info}" Margin="0,0,0,4"/>
            <TextBlock Text="Configure multi-map management, background layers, hex grids, gridless mode, custom grid sizes, and map notes." 
                       TextWrapping="Wrap" Foreground="{StaticResource Brush_Text_Hint}" Margin="0,0,0,12"/>

            <!-- 8.1 Multi-Map Management -->
            <GroupBox Header="📚 8.1 Multi-Map Management">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableMultiMap" Content="Enable Multi-Map Management" 
                              Checked="ChkEnableMultiMap_Changed" Unchecked="ChkEnableMultiMap_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max Recent Maps:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMaxRecent" Minimum="1" Maximum="25" Width="150" 
                                Value="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMaxRecent_ValueChanged"/>
                        <TextBlock x:Name="TxtMaxRecent" Text="10" Margin="8,0,0,0" Foreground="{StaticResource Brush_Warning}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="Add Current Map to Library" Style="{StaticResource ActionButton}" Click="AddMapToLibrary_Click"/>
                        <Button Content="Search Maps..." Style="{StaticResource ActionButton}" Margin="8,4,0,4" Click="SearchMaps_Click"/>
                    </StackPanel>
                    <TextBlock Text="Recent Maps:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <ListBox x:Name="LstRecentMaps" Height="100" 
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}"
                             SelectionChanged="LstRecentMaps_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Brush_Text_Primary}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Load Selected Map" Style="{StaticResource ActionButton}" Click="LoadSelectedMap_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- 8.2 Background Image Layers -->
            <GroupBox Header="🖼️ 8.2 Background Image Layers">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableBackgroundLayers" Content="Enable Background Layers" 
                              Checked="ChkEnableBackgroundLayers_Changed" Unchecked="ChkEnableBackgroundLayers_Changed"/>
                    <Button Content="Add Background Layer..." Style="{StaticResource ActionButton}" Click="AddBackgroundLayer_Click"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Layer Opacity:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderLayerOpacity" Minimum="0" Maximum="1" Width="150" 
                                Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                ValueChanged="SliderLayerOpacity_ValueChanged"/>
                        <TextBlock x:Name="TxtLayerOpacity" Text="1.0" Margin="8,0,0,0" Foreground="{StaticResource Brush_Warning}"/>
                    </StackPanel>
                    <TextBlock Text="Layers:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <ListBox x:Name="LstBackgroundLayers" Height="80" 
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}"
                             SelectionChanged="LstBackgroundLayers_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ImagePath}" Foreground="{StaticResource Brush_Text_Primary}" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text=" | Opacity: " Foreground="{StaticResource Brush_Text_Hint}"/>
                                    <TextBlock Text="{Binding Opacity, StringFormat=F2}" Foreground="{StaticResource Brush_Warning}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove Selected Layer" Style="{StaticResource ActionButton}" Click="RemoveBackgroundLayer_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- 8.3 Hexagonal Grids -->
            <GroupBox Header="⬡ 8.3 Hexagonal Grids">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableHexGrid" Content="Enable Hex Grid Support" 
                              Checked="ChkEnableHexGrid_Changed" Unchecked="ChkEnableHexGrid_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Grid Type:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbGridType" Style="{StaticResource FieldCombo}" SelectionChanged="CmbGridType_SelectionChanged">
                            <ComboBoxItem Content="Square" IsSelected="True"/>
                            <ComboBoxItem Content="Hex Flat Top"/>
                            <ComboBoxItem Content="Hex Pointy Top"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="Hex grids use axial coordinates for movement and distance calculation." 
                               Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 8.4 Gridless Mode -->
            <GroupBox Header="✨ 8.4 Gridless Mode">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableGridless" Content="Enable Gridless Mode" 
                              Checked="ChkEnableGridless_Changed" Unchecked="ChkEnableGridless_Changed"/>
                    <TextBlock Text="In gridless mode, tokens are placed at exact pixel positions instead of snapping to grid cells. Useful for theatre-of-the-mind style play with visual reference." 
                               Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 8.5 Custom Grid Sizes -->
            <GroupBox Header="📏 8.5 Custom Grid Sizes">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableCustomGridSizes" Content="Enable Custom Grid Sizes" 
                              Checked="ChkEnableCustomGridSizes_Changed" Unchecked="ChkEnableCustomGridSizes_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Feet Per Square:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderFeetPerSquare" Minimum="5" Maximum="100" Width="150" 
                                Value="5" TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderFeetPerSquare_ValueChanged"/>
                        <TextBlock x:Name="TxtFeetPerSquare" Text="5 ft" Margin="8,0,0,0" Foreground="{StaticResource Brush_Warning}"/>
                    </StackPanel>
                    <TextBlock Text="Changing the scale adjusts movement distances and area effect sizes. Standard D&amp;D uses 5 ft per square." 
                               Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 8.6 Map Notes & Labels -->
            <GroupBox Header="📝 8.6 Map Notes &amp; Labels">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableMapNotes" Content="Enable Map Notes" 
                              Checked="ChkEnableMapNotes_Changed" Unchecked="ChkEnableMapNotes_Changed"/>
                    <CheckBox x:Name="ChkShowDMNotes" Content="Show DM-Only Notes" 
                              Checked="ChkShowDMNotes_Changed" Unchecked="ChkShowDMNotes_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Note Font Size:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderNoteFontSize" Minimum="8" Maximum="36" Width="150" 
                                Value="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderNoteFontSize_ValueChanged"/>
                        <TextBlock x:Name="TxtNoteFontSize" Text="12" Margin="8,0,0,0" Foreground="{StaticResource Brush_Warning}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Category:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbNoteCategory" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="General" IsSelected="True"/>
                            <ComboBoxItem Content="Trap"/>
                            <ComboBoxItem Content="Treasure"/>
                            <ComboBoxItem Content="NPC"/>
                            <ComboBoxItem Content="Quest"/>
                            <ComboBoxItem Content="Lore"/>
                            <ComboBoxItem Content="Secret"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Note Text:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtNoteText" Width="300" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" 
                                 BorderBrush="{StaticResource Brush_Border_Normal}" Padding="4,2"/>
                    </StackPanel>
                    <Button Content="Add Note to Map Center" Style="{StaticResource ActionButton}" Click="AddNote_Click"/>
                    <TextBlock Text="Map Notes:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <ListBox x:Name="LstMapNotes" Height="120" 
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource Brush_Info}" Width="60"/>
                                    <TextBlock Text="{Binding Text}" Foreground="{StaticResource Brush_Text_Primary}" MaxWidth="350" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove Selected Note" Style="{StaticResource ActionButton}" Click="RemoveNote_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- Action Log -->
            <GroupBox Header="📋 Action Log">
                <ListBox x:Name="LstActionLog" Height="100" 
                         Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Secondary}" BorderBrush="{StaticResource Brush_Border_Normal}"/>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
