<Window x:Class="DnDBattle.Views.ThemeSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎨 Application Theme"
        Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Theme Card Style -->
        <Style x:Key="ThemeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Radio Button Style for Theme Selection -->
        <Style x:Key="ThemeRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ThemeBorder" 
                                Style="{StaticResource ThemeCardStyle}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ThemeBorder" Property="BorderBrush" Value="#007ACC"/>
                                <Setter TargetName="ThemeBorder" Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeBorder" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Color Button Style -->
        <Style x:Key="AccentColorButton" TargetType="RadioButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ColorBorder" 
                                Background="{TemplateBinding Tag}"
                                CornerRadius="20"
                                BorderThickness="3"
                                BorderBrush="Transparent"
                                Cursor="Hand">
                            <TextBlock x:Name="CheckMark" 
                                       Text="✓" 
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ColorBorder" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🎨 Application Theme" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White"/>
            <TextBlock Text="Customize the look and feel of DnD Battle Builder" 
                       Foreground="#888" 
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Theme Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="THEME" 
                       Foreground="#4FC3F7" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,10"/>

            <WrapPanel>
                <!-- Dark Theme -->
                <RadioButton x:Name="RbDarkTheme" 
                             Style="{StaticResource ThemeRadioStyle}"
                             GroupName="Theme"
                             IsChecked="True"
                             Checked="Theme_Changed">
                    <StackPanel Width="180">
                        <Border Background="#1E1E1E" Height="60" CornerRadius="4" Margin="0,0,0,10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#007ACC" Height="8" Width="80" CornerRadius="2" Margin="2"/>
                                <Border Background="#3E3E42" Height="6" Width="60" CornerRadius="2" Margin="2"/>
                                <Border Background="#3E3E42" Height="6" Width="40" CornerRadius="2" Margin="2"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Dark" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="Default dark theme" Foreground="#888" FontSize="10"/>
                    </StackPanel>
                </RadioButton>

                <!-- Darker Theme -->
                <RadioButton x:Name="RbDarkerTheme" 
                             Style="{StaticResource ThemeRadioStyle}"
                             GroupName="Theme"
                             Checked="Theme_Changed">
                    <StackPanel Width="180">
                        <Border Background="#0D0D0D" Height="60" CornerRadius="4" Margin="0,0,0,10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#007ACC" Height="8" Width="80" CornerRadius="2" Margin="2"/>
                                <Border Background="#252526" Height="6" Width="60" CornerRadius="2" Margin="2"/>
                                <Border Background="#252526" Height="6" Width="40" CornerRadius="2" Margin="2"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Darker" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="Even darker background" Foreground="#888" FontSize="10"/>
                    </StackPanel>
                </RadioButton>
            </WrapPanel>
        </StackPanel>

        <!-- Accent Color Selection -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="ACCENT COLOR" 
                       Foreground="#4FC3F7" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,10"/>

            <WrapPanel>
                <RadioButton x:Name="RbAccentBlue" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#007ACC"
                             IsChecked="True"
                             Checked="AccentColor_Changed"
                             ToolTip="Blue (Default)"/>
                <RadioButton x:Name="RbAccentGreen" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#4CAF50"
                             Checked="AccentColor_Changed"
                             ToolTip="Green"/>
                <RadioButton x:Name="RbAccentPurple" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#9C27B0"
                             Checked="AccentColor_Changed"
                             ToolTip="Purple"/>
                <RadioButton x:Name="RbAccentOrange" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#FF9800"
                             Checked="AccentColor_Changed"
                             ToolTip="Orange"/>
                <RadioButton x:Name="RbAccentRed" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#F44336"
                             Checked="AccentColor_Changed"
                             ToolTip="Red"/>
                <RadioButton x:Name="RbAccentTeal" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#00BCD4"
                             Checked="AccentColor_Changed"
                             ToolTip="Teal"/>
                <RadioButton x:Name="RbAccentPink" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#E91E63"
                             Checked="AccentColor_Changed"
                             ToolTip="Pink"/>
                <RadioButton x:Name="RbAccentGold" 
                             Style="{StaticResource AccentColorButton}"
                             GroupName="AccentColor"
                             Tag="#FFD700"
                             Checked="AccentColor_Changed"
                             ToolTip="Gold"/>
            </WrapPanel>
        </StackPanel>

        <!-- Preview Section -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="PREVIEW" 
                       Foreground="#4FC3F7" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,10"/>

            <Border x:Name="PreviewBorder" 
                    Background="#1E1E1E" 
                    CornerRadius="8" 
                    Padding="15"
                    BorderBrush="#3E3E42"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Sample Interface" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="This is how your UI will look" Foreground="#888" FontSize="11" Margin="0,5,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PreviewPrimaryButton" 
                                Content="Primary Action" 
                                Padding="15,8"
                                Margin="0,0,10,0"/>
                        <Button Content="Secondary" 
                                Padding="15,8"
                                Background="#3E3E42"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Info Text -->
        <TextBlock Grid.Row="4" 
                   Text="Note: Theme changes apply immediately. Restart the application for the best experience."
                   Foreground="#666"
                   FontSize="11"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,15"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Reset to Default" 
                    Padding="15,10" 
                    Margin="0,0,10,0"
                    Click="BtnReset_Click"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Content="Close" 
                    Padding="20,10"
                    Click="BtnClose_Click"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
