<Window x:Class="DnDBattle.Views.Settings.CloudSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="☁️ Cloud Save &amp; Sync" Height="520" Width="550"
        Background="#1A1A1D" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Server Config -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Cloud Server" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Server URL:" Foreground="#CCC" VerticalAlignment="Center" Width="80"/>
                    <TextBox x:Name="ServerUrlBox" Width="350"
                             Background="#333" Foreground="White" BorderBrush="#555" Padding="4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Campaign:" Foreground="#CCC" VerticalAlignment="Center" Width="80"/>
                    <TextBox x:Name="CampaignIdBox" Width="200" Text="default"
                             Background="#333" Foreground="White" BorderBrush="#555" Padding="4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Save Section -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Save" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                <Button Content="Save Current Encounter" Click="SaveEncounter_Click"
                        Background="#0E639C" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Load Section -->
        <Border Grid.Row="2" Background="#252526" CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Available Encounters" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Click="RefreshList_Click"
                            Background="#555" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                    <Button Content="Load Selected" Click="LoadEncounter_Click"
                            Background="#0E639C" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
                <ListBox x:Name="EncounterList" Background="#2D2D30" Foreground="White" BorderThickness="0"
                         DisplayMemberPath="Name"/>
            </DockPanel>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Background="#252526" CornerRadius="8" Padding="12">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#007ACC" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
