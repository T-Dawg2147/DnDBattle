<Window x:Class="DnDBattle.Views.ActionResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolve Action"
        Width="400" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown"
        FocusManager.FocusedElement="{Binding ElementName=TxtAttackRoll}">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Hint}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtActionName" Style="{StaticResource HeaderText}" FontSize="18"/>
            <TextBlock x:Name="TxtSourceTarget" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Attack Roll Section -->
        <Border x:Name="AttackSection" Grid.Row="1" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Attack Roll" Style="{StaticResource HeaderText}" Foreground="{StaticResource Brush_Success}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="ManualAttackPanel">
                        <TextBlock Text="Enter your d20 roll:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TxtAttackRoll" 
                                 Width="80" 
                                 HorizontalAlignment="Left"
                                 FontSize="18"
                                 Padding="8,5"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="AutoAttackPanel" Visibility="Collapsed">
                        <TextBlock Text="Roll Result:" Style="{StaticResource LabelText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock x:Name="TxtAutoAttackRoll" FontSize="24" Foreground="{StaticResource Brush_Success}" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtAttackBonus" FontSize="14" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                            <TextBlock Text=" = " FontSize="14" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtAttackTotal" FontSize="24" Foreground="{StaticResource Brush_Text_Primary}" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="vs AC" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtTargetAC" FontSize="24" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Damage Roll Section -->
        <Border x:Name="DamageSection" Grid.Row="2" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Damage" Style="{StaticResource HeaderText}" Foreground="{StaticResource Brush_Error}"/>
                    <TextBlock x:Name="TxtDamageExpression" Style="{StaticResource LabelText}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="ManualDamagePanel">
                    <TextBlock Text="Enter your damage roll:" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtDamageRoll" 
                             Width="80" 
                             HorizontalAlignment="Left"
                             FontSize="18"
                             Padding="8,5"
                             Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel x:Name="AutoDamagePanel" Visibility="Collapsed">
                    <TextBlock Text="Damage Roll:" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="TxtAutoDamageRoll" FontSize="24" Foreground="{StaticResource Brush_Error}" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Damage Type Selection -->
        <Border Grid.Row="3" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Damage Type" Style="{StaticResource HeaderText}"/>
                    <TextBlock x:Name="TxtAutoDetected" 
                               Text="(auto-detected)" 
                               Foreground="{StaticResource Brush_Success}" 
                               FontSize="10" 
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
                <ComboBox x:Name="CmbDamageType"/>
            </StackPanel>
        </Border>

        <!-- Target Defenses Info -->
        <Border x:Name="DefensesSection" Grid.Row="4" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Target Defenses" Style="{StaticResource HeaderText}" Margin="0,0,0,10"/>
                <WrapPanel x:Name="DefensesBadges"/>
                <TextBlock x:Name="TxtNoDefenses" 
                           Text="No relevant immunities, resistances, or vulnerabilities" 
                           Style="{StaticResource LabelText}"
                           FontStyle="Italic"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel (Esc)" 
                    Padding="20,10" 
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnConfirm"
                    Content="⚔️ Confirm (Enter)" 
                    Padding="20,10"
                    Click="BtnConfirm_Click"
                    Style="{StaticResource SuccessButton}"
                    FontWeight="Bold"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>