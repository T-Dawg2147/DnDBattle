<Window x:Class="DnDBattle.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Options" Height="480" Width="480" WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Setting Row Style -->
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚙️ Application Options" FontWeight="Bold" FontSize="18" Foreground="White"/>
            <TextBlock Text="Configure grid, gameplay, and visual settings" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Grid Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🗺️ GRID SETTINGS" Style="{StaticResource SectionHeader}"/>

                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cell Size (px)" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCellSize" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="8,6"/>
                        </Grid>

                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Max Width (tiles)" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtMaxWidth" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="8,6"/>
                        </Grid>

                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Max Height (tiles)" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtMaxHeight" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="8,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Gameplay Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚔️ GAMEPLAY" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkAutoAOO" Content="Auto-resolve Attacks of Opportunity" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkLiveMode" Content="Live Mode (manual dice; disable auto-resolution)" Foreground="#CCC" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Performance/Visuals Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🎨 PERFORMANCE / VISUALS" Style="{StaticResource SectionHeader}"/>

                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Shadow Softness (px)" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtShadowSoftness" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="8,6"/>
                        </Grid>

                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Path Speed (squares/sec)" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtPathSpeed" Grid.Column="1" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="8,6"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click" 
                    Padding="20,10" Margin="0,0,10,0"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="Save" Click="BtnSave_Click" 
                    Padding="20,10"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>