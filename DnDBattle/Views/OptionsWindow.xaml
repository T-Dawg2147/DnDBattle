<Window x:Class="DnDBattle.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options" Height="420" Width="420" WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Application Options" FontWeight="Bold" FontSize="14" Margin="2"/>

        <StackPanel Grid.Row="1" Margin="0,8,0,8" VerticalAlignment="Top">
            <GroupBox Header="Grid" Margin="0,4">
                <StackPanel Orientation="Vertical" Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Cell size (px):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtCellSize" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max width (tiles):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtMaxWidth" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max height (tiles):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtMaxHeight" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Gameplay" Margin="0,8">
                <StackPanel Margin="6">
                    <CheckBox x:Name="ChkAutoAOO" Content="Auto-resolve Attacks of Opportunity" Margin="0,4"/>
                    <CheckBox x:Name="ChkLiveMode" Content="Live Mode (manual dice; disable auto-resolution)" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Performance / Visuals" Margin="0,8">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Shadow softness (px):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtShadowSoftness" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Path speed (squares/sec):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtPathSpeed" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="Cancel" Click="BtnCancel_Click" Width="75" Margin="6"/>
            <Button Content="Save" Click="BtnSave_Click" Width="75" Margin="6"/>
        </StackPanel>
    </Grid>
</Window>