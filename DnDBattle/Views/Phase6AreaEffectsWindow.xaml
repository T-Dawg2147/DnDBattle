<Window x:Class="DnDBattle.Views.Phase6AreaEffectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔥 Phase 6: Area Effects Expansion"
        Width="600" Height="980"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E" Foreground="White"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FF88AAFF"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <TextBlock Text="🔥 Phase 6: Area Effects Expansion" FontSize="18" FontWeight="Bold" Foreground="#FF88AAFF" Margin="0,0,0,12"/>
            <TextBlock Text="Manage spell templates, duration tracking, DoT, polygon effects, and animations." Foreground="#FF888899" Margin="0,0,0,4"/>

            <!-- 6.1 Spell Templates Library -->
            <GroupBox Header="📖 6.1 Spell Templates Library">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableSpellLibrary" Content="Enable Spell Library" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <Button Content="📖 Open Spell Library..." Click="OpenSpellLibrary_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>

                    <TextBlock Text="Quick-Place Common Spells:" Margin="0,8,0,4" FontWeight="SemiBold"/>
                    <WrapPanel>
                        <Button Content="🔥 Fireball (20ft Sphere)" Click="QuickFireball_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="⚡ Lightning Bolt (100ft Line)" Click="QuickLightningBolt_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="❄️ Cone of Cold (60ft Cone)" Click="QuickConeOfCold_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                    </WrapPanel>
                    <TextBlock Text="💡 Use the Spell Library to search, filter, and place any D&amp;D spell as an area effect." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 6.2 Duration Tracking -->
            <GroupBox Header="⏱️ 6.2 Duration Tracking">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableDurationTracking" Content="Enable Duration Tracking" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 Effect durations auto-countdown each round. Effects are removed when their duration expires." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                    <Button Content="⏩ Advance Round (Tick Durations)" Click="AdvanceRound_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtDurationStatus" Text="No active duration effects." Foreground="#FFFFCC66" Margin="0,4" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <!-- 6.3 Damage Over Time -->
            <GroupBox Header="💥 6.3 Damage Over Time">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableDamageOverTime" Content="Enable Damage Over Time" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAutoApplyDot" Content="Auto-Apply DoT Damage" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 Damage timing modes: OnEnter (when token moves in), StartOfTurn, EndOfTurn. When auto-apply is off, reminders are shown instead." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 6.4 Custom Polygon Areas -->
            <GroupBox Header="🔷 6.4 Custom Polygon Areas">
                <StackPanel>
                    <CheckBox x:Name="ChkEnablePolygonEffects" Content="Enable Custom Polygon Effects" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 Click on the grid to place vertices defining a custom polygon area. Useful for irregular shapes like Hunger of Hadar or Wall of Fire." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 6.5 Effect Animations -->
            <GroupBox Header="✨ 6.5 Effect Animations">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableEffectAnimations" Content="Enable Effect Animations" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max Particles:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderMaxParticles" Minimum="10" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtMaxParticles" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Default Animation:" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CmbDefaultAnimation" Width="150" SelectionChanged="CmbDefaultAnimation_SelectionChanged">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Pulse"/>
                            <ComboBoxItem Content="Particle"/>
                            <ComboBoxItem Content="Rotate"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="💡 Animations add visual flair: Pulse fades in/out, Particle spawns floating particles, Rotate spins the effect overlay." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- Active Effects List -->
            <GroupBox Header="📋 Active Area Effects">
                <StackPanel>
                    <ListBox x:Name="LstActiveEffects" Height="140" Background="#FF1A1A2E" Foreground="White" BorderBrush="#FF444466">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RoundsRemaining, StringFormat='({0} rds)'}" Foreground="#FF88AAFF" VerticalAlignment="Center" Margin="8,0"/>
                                    <Button Grid.Column="2" Content="❌" Tag="{Binding Id}" Click="RemoveEffect_Click" Background="Transparent" Foreground="#FFFF6666" BorderThickness="0" Cursor="Hand" Padding="4,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="🗑️ Clear All Effects" Click="ClearAllEffects_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Margin="0,6,0,0"/>
                    <Button Content="🔄 Refresh List" Click="RefreshEffects_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
