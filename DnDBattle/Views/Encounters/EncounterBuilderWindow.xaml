<UserControl x:Class="DnDBattle.Views.Encounters.EncounterBuilderWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5E5E62"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Party Setup -->
        <Border Grid.Row="0" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Party Setup -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Party:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <TextBlock Text="Size" Foreground="#888" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbPartySize" Width="50" SelectedIndex="3" SelectionChanged="PartySettings_Changed">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                    </ComboBox>

                    <TextBlock Text="Level" Foreground="#888" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <ComboBox x:Name="CmbPartyLevel" Width="50" SelectedIndex="0" SelectionChanged="PartySettings_Changed">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="9"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="11"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="13"/>
                        <ComboBoxItem Content="14"/>
                        <ComboBoxItem Content="15"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="17"/>
                        <ComboBoxItem Content="18"/>
                        <ComboBoxItem Content="19"/>
                        <ComboBoxItem Content="20"/>
                    </ComboBox>
                </StackPanel>

                <!-- Difficulty Display -->
                <Border Grid.Column="1" x:Name="DifficultyBadge" 
                        Background="#2D2D30" 
                        CornerRadius="4" 
                        Padding="15,8" 
                        Margin="20,0"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtDifficultyIcon" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtDifficulty" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- XP Display -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Total XP" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalXP" Text="0" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Adjusted XP" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtAdjustedXP" Text="0" Foreground="#FF9800" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Multiplier" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtMultiplier" Text="×1" Foreground="#4FC3F7" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Creature Browser (Left) -->
            <Border Grid.Column="0" Background="#252526" Margin="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Add Creatures" Style="{StaticResource SectionHeader}" Margin="15,15,15,10"/>

                    <!-- Search -->
                    <Grid Grid.Row="1" Margin="15,0,15,10">
                        <TextBox x:Name="TxtSearch" 
                                 Background="#1E1E1E" 
                                 Foreground="White" 
                                 BorderBrush="#444"
                                 Padding="10,8"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <TextBlock Text="🔍 Search creatures..." 
                                   Foreground="#666" 
                                   IsHitTestVisible="False"
                                   Margin="12,8,0,0"
                                   Visibility="{Binding Text.Length, ElementName=TxtSearch, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- Creature List -->
                    <ListBox x:Name="CreatureList" 
                             Grid.Row="2"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="CreatureList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D30" CornerRadius="4" Padding="10,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Type}" Foreground="#888" FontSize="10"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" 
                                                Background="#3E3E42" 
                                                CornerRadius="3" 
                                                Padding="8,2" 
                                                Margin="10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChallengeRating, StringFormat='CR {0}'}" 
                                                       Foreground="#FF9800" 
                                                       FontSize="11"/>
                                        </Border>

                                        <Button Grid.Column="2" 
                                                Content="+" 
                                                Width="28" Height="28"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="BtnAddCreature_Click"
                                                Tag="{Binding}"
                                                ToolTip="Add to encounter"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Encounter Creatures (Right) -->
            <Border Grid.Column="1" Background="#1E1E1E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Encounter Creatures" Style="{StaticResource SectionHeader}" Margin="15,15,15,10"/>

                    <!-- Encounter Creature List -->
                    <ListBox x:Name="EncounterList" 
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="15,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252526" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Creature Info -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Creature.Name}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding Creature.ChallengeRating, StringFormat='CR {0}'}" Foreground="#FF9800" FontSize="11"/>
                                                <TextBlock Text=" • " Foreground="#666"/>
                                                <TextBlock Foreground="#888" FontSize="11">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} XP">
                                                            <Binding Path="TotalXP"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Quantity Controls -->
                                        <Button Grid.Column="1" 
                                                Content="-" 
                                                Width="28" Height="28"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="BtnDecreaseQuantity_Click"
                                                Tag="{Binding}"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Quantity}" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Width="30"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <Button Grid.Column="3" 
                                                Content="+" 
                                                Width="28" Height="28"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="BtnIncreaseQuantity_Click"
                                                Tag="{Binding}"/>

                                        <Button Grid.Column="4" 
                                                Content="🗑️" 
                                                Width="28" Height="28"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="BtnRemoveCreature_Click"
                                                Tag="{Binding}"
                                                ToolTip="Remove from encounter"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Thresholds Display -->
                    <Border Grid.Row="2" Background="#252526" Padding="15" Margin="15,10,15,15" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Easy" Foreground="#4CAF50" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtEasyThreshold" Text="0" Foreground="#4CAF50" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Medium" Foreground="#FFC107" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMediumThreshold" Text="0" Foreground="#FFC107" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Hard" Foreground="#FF9800" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtHardThreshold" Text="0" Foreground="#FF9800" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Deadly" Foreground="#F44336" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtDeadlyThreshold" Text="0" Foreground="#F44336" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer / Actions -->
        <Border Grid.Row="2" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Preset Actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📂 Load Preset" Style="{StaticResource ToolbarButton}" Click="BtnLoadPreset_Click"/>
                    <Button Content="💾 Save Preset" Style="{StaticResource ToolbarButton}" Click="BtnSavePreset_Click"/>
                    <Button Content="🗑️ Clear All" Style="{StaticResource ToolbarButton}" Click="BtnClearAll_Click"/>
                </StackPanel>

                <!-- Deploy -->
                <Button Grid.Column="1" 
                        x:Name="BtnDeploy"
                        Click="BtnDeploy_Click"
                        Background="#4CAF50"
                        Padding="20,10">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚔️" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Deploy to Map" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#66BB6A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#43A047"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>