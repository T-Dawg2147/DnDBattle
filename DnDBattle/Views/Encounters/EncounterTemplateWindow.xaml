<Window x:Class="DnDBattle.Views.Encounters.EncounterTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encounter Templates" 
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D30">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="4" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Saved Templates"
                           FontSize="14" FontWeight="Bold" Foreground="White"
                           Margin="10"/>

                <ListBox x:Name="LstTemplates" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="LstTemplates_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#999"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border Background="#3E3E42" CornerRadius="2" Padding="4,1" Margin="0,0,5,0">
                                        <TextBlock Text="{Binding Difficulty}" FontSize="10" Foreground="#CCC"/>
                                    </Border>
                                    <TextBlock FontSize="10" Foreground="#777">
                                        <Run Text="{Binding Slots.Count, Mode=OneWay}"/>
                                        <Run Text=" creature types"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
                    <Button Content="New" Width="60" Margin="0,0,5,0" Click="BtnNewTemplate_Click"/>
                    <Button Content="Delete" Width="60" Click="BtnDeleteTemplate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="4" Padding="15">
            <Grid x:Name="EditorPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Template Name:" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtTemplateName" FontSize="14" Padding="5"/>

                    <TextBlock Text="Description:" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtTemplateDescription" Height="50"
                             TextWrapping="Wrap" AcceptsReturn="True"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Difficulty" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="CmbDifficulty" Width="120">
                            <ComboBoxItem Content="Easy" IsSelected="True"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="Hard"/>
                            <ComboBoxItem Content="Deadly"/>
                            <ComboBoxItem Content="Legendary"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <GroupBox Grid.Row="1" Header="Add Creature" Foreground="White" Margin="0,0,0,15">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CmbCreatureSelect" Grid.Column="0"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  DisplayMemberPath="Name"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                            <TextBlock Text="×" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="TxtCreatureCount" Width="40" Text="1"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Add" Width="60" Click="BtnAddCreature_Click"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="Creatures in Template" Foreground="White">
                    <ListBox x:Name="LstSlots" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="White">
                                        <Run Text="{Binding CreatureName}" FontWeight="Bold"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               Foreground="#CCC" HorizontalAlignment="Center">
                                        <Run Text="×"/>
                                        <Run Text="{Binding Count}"/>
                                    </TextBlock>

                                    <Button Grid.Column="2" Content="✕" Width="25"
                                            Click="BtnRemoveSlot_Click" Tag="{Binding}"
                                            ToolTip="Remove from template"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <StackPanel Grid.Row="4" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Save Template" Width="100" Margin="0,0,10,0"
                            Click="BtnSaveTemplate_Click"/>
                    <Button x:Name="BtnSpawn" Content="Spawn Encounter" Width="120"
                            Click="BtnSpawnEncounter_Click" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
