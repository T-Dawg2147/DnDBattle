<Window x:Class="DnDBattle.Views.Phase5TokenFeaturesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎭 Phase 5: Advanced Token Features"
        Width="580" Height="950"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E" Foreground="White"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FF88AAFF"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <TextBlock Text="🎭 Phase 5: Advanced Token Features" FontSize="18" FontWeight="Bold" Foreground="#FF88AAFF" Margin="0,0,0,12"/>
            <TextBlock Text="Manage pathfinding, movement preview, auras, elevation, and facing." Foreground="#FF888899" Margin="0,0,0,4"/>

            <!-- Selected token indicator -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Selected Token: " FontWeight="SemiBold" Foreground="#FFCCCCDD"/>
                <TextBlock x:Name="TxtSelectedToken" Text="(none)" FontWeight="Bold" Foreground="#FFFFCC66"/>
            </StackPanel>

            <!-- 5.1 A* Pathfinding -->
            <GroupBox Header="🗺️ 5.1 A* Pathfinding">
                <StackPanel>
                    <CheckBox x:Name="ChkEnablePathfinding" Content="Enable A* Pathfinding" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAllowDiagonal" Content="Allow Diagonal Movement" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max Depth:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderMaxDepth" Minimum="10" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtMaxDepth" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <TextBlock Text="💡 A* pathfinding calculates optimal movement paths around obstacles." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.2 Movement Cost Preview -->
            <GroupBox Header="👣 5.2 Movement Cost Preview">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableMovementPreview" Content="Enable Movement Cost Preview" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 Hover over grid squares to see movement cost from the selected token. Difficult terrain costs double." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.3 Path Animation -->
            <GroupBox Header="✨ 5.3 Path Animation">
                <StackPanel>
                    <CheckBox x:Name="ChkEnablePathAnimation" Content="Enable Path Animation" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Speed:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderAnimationSpeed" Minimum="0.1" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtAnimationSpeed" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <TextBlock Text="💡 Tokens animate smoothly along the calculated path instead of snapping." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.4 AOO Detection -->
            <GroupBox Header="⚔️ 5.4 Attacks of Opportunity Detection">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableAOO" Content="Enable AOO Detection" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <TextBlock Text="💡 Detects when a moving token leaves an enemy's threatened area and warns about attacks of opportunity." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.5 Token Auras -->
            <GroupBox Header="🔮 5.5 Token Auras">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableAuras" Content="Enable Token Auras" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <TextBlock Text="Add Preset Aura to Selected Token:" Margin="0,6,0,4" FontWeight="SemiBold"/>
                    <WrapPanel>
                        <Button Content="🛡️ Paladin Aura" Click="AddPaladinAura_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="👻 Spirit Guardians" Click="AddSpiritGuardians_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="💢 Rage" Click="AddRage_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                        <Button Content="✨ Bless" Click="AddBless_Click" Style="{StaticResource ActionButton}" Margin="0,0,6,0"/>
                    </WrapPanel>

                    <TextBlock Text="Auras on Selected Token:" Margin="0,8,0,4" FontWeight="SemiBold"/>
                    <ListBox x:Name="AurasList" Height="100" Background="#FF1A1A2E" Foreground="White" BorderBrush="#FF444466">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Width="160" Foreground="White"/>
                                    <TextBlock Text="{Binding RadiusSquares, StringFormat='{}{0} sq'}" Width="60" Foreground="#FF88AAFF"/>
                                    <TextBlock Text="{Binding IsVisible}" Foreground="#FFAAAAAA"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="🗑️ Remove Selected Aura" Click="RemoveAura_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.6 Token Elevation -->
            <GroupBox Header="⬆️ 5.6 Token Elevation">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableElevation" Content="Enable Token Elevation" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Elevation:" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CmbElevation" Width="180" SelectedIndex="0">
                            <ComboBoxItem Content="0 ft (Ground)"/>
                            <ComboBoxItem Content="5 ft"/>
                            <ComboBoxItem Content="10 ft"/>
                            <ComboBoxItem Content="15 ft"/>
                            <ComboBoxItem Content="20 ft"/>
                            <ComboBoxItem Content="30 ft"/>
                            <ComboBoxItem Content="50 ft"/>
                            <ComboBoxItem Content="100 ft"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="📌 Apply Elevation to Selected Token" Click="ApplyElevation_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock Text="💡 Elevation affects distance calculations and displays a badge on the token." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 5.7 Token Facing -->
            <GroupBox Header="🧭 5.7 Token Facing">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableFacing" Content="Enable Token Facing" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkAutoFace" Content="Auto-Face Movement Direction" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <CheckBox x:Name="ChkEnableFlanking" Content="Enable Flanking Detection" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Facing Angle:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderFacingAngle" Minimum="0" Maximum="360" TickFrequency="15" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtFacingAngle" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <Button Content="🧭 Apply Facing to Selected Token" Click="ApplyFacing_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                    <TextBlock Text="💡 Facing determines the direction a token looks. Flanking detection uses facing to determine advantage." Foreground="#FF888899" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
