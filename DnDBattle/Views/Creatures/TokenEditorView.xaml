<UserControl x:Class="DnDBattle.Views.Creatures.TokenEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    <Border Padding="8" Background="#FF242424" CornerRadius="6">
        <StackPanel>
            <TextBlock Text="Token Editor" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Image Width="64" Height="64" Source="{Binding Image}" Stretch="UniformToFill" />
                <StackPanel Margin="8,0,0,0">
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                    <CheckBox Content="Player" IsChecked="{Binding IsPlayer}" Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="HP:" Foreground="LightGray" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HP, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="6,0,0,0" KeyDown="TextBox_KeyDown"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="AC:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,6,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ArmorClass, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="6,6,0,0" KeyDown="TextBox_KeyDown"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Initiative Mod:" Foreground="LightGray" VerticalAlignment="Center" Margin="0,6,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InitiativeModifier, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="6,6,0,0" KeyDown="TextBox_KeyDown"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="Speed (ft):" Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="6,0,0,0" KeyDown="TextBox_KeyDown"/>
                <Button Content="Upload Image" Click="UploadImage_Click" Margin="8,0,0,0" />
            </StackPanel>
            
        </StackPanel>
    </Border>
</UserControl>