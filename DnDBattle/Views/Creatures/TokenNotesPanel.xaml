<UserControl x:Class="DnDBattle.Views.Creatures.TokenNotesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border x:Name="MainBorder" 
            Background="#252526" 
            CornerRadius="4" 
            Padding="10"
            Visibility="Collapsed">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="📝 Notes" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11"/>

                <Button Grid.Column="1" 
                        Content="+" 
                        Width="20" Height="20"
                        Click="BtnAddNote_Click"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        ToolTip="Add Note"/>
            </Grid>

            <!-- Notes List -->
            <StackPanel x:Name="NotesContainer"/>

            <!-- Quick Add -->
            <Grid x:Name="QuickAddPanel" Visibility="Collapsed" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtQuickNote" 
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#444"
                         Padding="8,6"
                         KeyDown="TxtQuickNote_KeyDown"/>

                <Button Grid.Column="1" 
                        Content="✓" 
                        Width="28"
                        Margin="5,0,0,0"
                        Click="BtnConfirmNote_Click"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>