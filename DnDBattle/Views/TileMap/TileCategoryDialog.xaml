<Window x:Class="DnDBattle.Views.TileMap.TileCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📁 Select Tile Category" Height="320" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="📁 Select Tile Category" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Choose where to place the imported tiles" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="6" Padding="15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="EXISTING CATEGORY" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>

                <ComboBox x:Name="CmbCategory" Height="40" FontSize="14" Background="#1E1E1E" Foreground="White" BorderBrush="#444">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="5" Foreground="White"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="OR CREATE NEW CATEGORY" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11" Margin="0,20,0,10"/>
                <TextBox x:Name="TxtNewCategory" Height="40" FontSize="14"
                         Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                         VerticalContentAlignment="Center" Padding="10,0"
                         TextChanged="TxtNewCategory_TextChanged"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" 
                    Click="Cancel_Click" IsCancel="True"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="✅ Import" Padding="20,10" 
                    Click="Import_Click" IsDefault="True"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>