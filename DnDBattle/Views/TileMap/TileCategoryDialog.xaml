<Window x:Class="DnDBattle.Views.TileMap.TileCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Category" Height="250" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="📁 Select Tile Category" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Choose where to place the imported tiles:" Margin="0,0,0,10"/>

            <ComboBox x:Name="CmbCategory" Height="35" FontSize="14">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Padding="5"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Or create a new category:" Margin="0,15,0,5"/>
            <TextBox x:Name="TxtNewCategory" Height="35" 
                     VerticalContentAlignment="Center"
                     TextChanged="TxtNewCategory_TextChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="✅ Import" Width="100" Height="35" Margin="5" 
                    Click="Import_Click" IsDefault="True" 
                    Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" 
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>