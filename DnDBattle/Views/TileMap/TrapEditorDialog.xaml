<Window x:Class="DnDBattle.Views.TileMap.TrapEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚠️ Trap Configuration" Height="720" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚠️ Configure Trap" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up traps with detection, disarm, and damage mechanics" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Trap Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Trigger Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbTriggerType" SelectedIndex="0" Background="#1E1E1E">
                            <ComboBoxItem Content="Pressure Plate"/>
                            <ComboBoxItem Content="Tripwire"/>
                            <ComboBoxItem Content="Proximity"/>
                            <ComboBoxItem Content="Manual (DM-triggered)"/>
                            <ComboBoxItem Content="Timed"/>
                            <ComboBoxItem Content="Interactive"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Roll Mode Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎲 ROLL MODE" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Choose whether the app auto-rolls or you input player rolls" Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <CheckBox x:Name="ChkAutoRollDetection" Content="Auto-roll Detection checks" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkAutoRollDisarm" Content="Auto-roll Disarm checks" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkAutoRollSave" Content="Auto-roll Saving Throws" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkAutoRollDamage" Content="Auto-roll Damage" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Detection & Disarm in a row -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Detection -->
                    <Border Grid.Column="0" Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="🔍 DETECTION" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Detection DC" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtDetectionDC" Text="15" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center" Margin="0,0,0,10"/>

                            <TextBlock Text="Detection Description" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtDetectionDesc" Text="You notice something unusual about this area." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                     TextWrapping="Wrap" Height="50" AcceptsReturn="True" Padding="10,8"/>
                        </StackPanel>
                    </Border>

                    <!-- Disarming -->
                    <Border Grid.Column="1" Background="#252526" CornerRadius="6" Padding="15" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="🔧 DISARMING" Style="{StaticResource SectionHeader}"/>

                            <CheckBox x:Name="ChkCanBeDisarmed" Content="Can be disarmed" IsChecked="True" Foreground="#CCC" Margin="0,0,0,10"/>

                            <TextBlock Text="Disarm Skill" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbDisarmSkill" SelectedIndex="0" Background="#1E1E1E" Margin="0,0,0,10">
                                <ComboBoxItem Content="Thieves' Tools"/>
                                <ComboBoxItem Content="Sleight of Hand"/>
                                <ComboBoxItem Content="Arcana"/>
                                <ComboBoxItem Content="Investigation"/>
                            </ComboBox>

                            <TextBlock Text="Disarm DC" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtDisarmDC" Text="15" Background="#1E1E1E" Foreground="#4CAF50" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center" Margin="0,0,0,10"/>

                            <CheckBox x:Name="ChkFailTriggers" Content="Failed disarm triggers trap" IsChecked="True" Foreground="#F44336"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Save & Damage -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Saving Throw -->
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="🛡️ SAVING THROW" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="Save Ability" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbSaveAbility" SelectedIndex="1" Background="#1E1E1E" Margin="0,0,0,10">
                                    <ComboBoxItem Content="STR"/>
                                    <ComboBoxItem Content="DEX"/>
                                    <ComboBoxItem Content="CON"/>
                                    <ComboBoxItem Content="INT"/>
                                    <ComboBoxItem Content="WIS"/>
                                    <ComboBoxItem Content="CHA"/>
                                </ComboBox>

                                <TextBlock Text="Save DC" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSaveDC" Text="13" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Damage -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="💥 DAMAGE" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="Damage Dice" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDamageDice" Text="2d6" Background="#1E1E1E" Foreground="#F44336" FontWeight="Bold" FontSize="14" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                                <TextBlock Text="Damage Type" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbDamageType" SelectedIndex="1" Background="#1E1E1E">
                                    <ComboBoxItem Content="🔨 Bludgeoning"/>
                                    <ComboBoxItem Content="🗡️ Piercing"/>
                                    <ComboBoxItem Content="⚔️ Slashing"/>
                                    <ComboBoxItem Content="🔥 Fire"/>
                                    <ComboBoxItem Content="❄️ Cold"/>
                                    <ComboBoxItem Content="⚡ Lightning"/>
                                    <ComboBoxItem Content="💥 Thunder"/>
                                    <ComboBoxItem Content="🧪 Acid"/>
                                    <ComboBoxItem Content="☠️ Poison"/>
                                    <ComboBoxItem Content="💀 Necrotic"/>
                                    <ComboBoxItem Content="✨ Radiant"/>
                                    <ComboBoxItem Content="💫 Force"/>
                                    <ComboBoxItem Content="🧠 Psychic"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="ChkHalfDamageOnSave" Content="Half damage on successful save" IsChecked="True" Foreground="#CCC" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Flavor Text -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="✨ FLAVOR TEXT" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Trigger Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtTriggerDesc" Text="The trap is sprung!" Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="45" AcceptsReturn="True" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Effect Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtEffectDesc" Text="Darts shoot from the walls!" Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="45" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Reusability -->
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="♻️ REUSABILITY" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkReusable" Content="Trap is reusable" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Max Triggers (0 = unlimited)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtMaxTriggers" Text="1" Width="80" HorizontalAlignment="Left" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click" IsCancel="True"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click" IsDefault="True"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>