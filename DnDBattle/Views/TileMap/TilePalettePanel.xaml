<UserControl x:Class="DnDBattle.Views.TileMap.TilePalettePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="{StaticResource Brush_Background_Control}" Margin="0,0,0,5">
            <TextBlock Text="🎨 Tile Palette" FontSize="14" FontWeight="Bold" Margin="10,8"/>
            <Button Content="🔄 Refresh Library" Click="RefreshLibrary_Click" 
                    Margin="5" Padding="5" Style="{StaticResource ToolbarButton}" 
                    HorizontalAlignment="Stretch"/>
            <Button Content="➕ Import Tiles..." Click="ImportTiles_Click" 
                    Margin="5,0,5,5" Padding="5" Style="{StaticResource ToolbarButton}" 
                    HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Tile List (Grouped by Category) -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="TileList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Key}" IsExpanded="True" Margin="5"
                                  Foreground="{StaticResource Brush_Text_Primary}"
                                  Background="{StaticResource Brush_Background_Control}">
                            <ItemsControl ItemsSource="{Binding Value}" Margin="5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="100" Margin="5" 
                                                Background="{StaticResource Brush_Background_Control}"
                                                BorderBrush="{StaticResource Brush_Border_Normal}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="TileButton_Click"
                                                Tag="{Binding}"
                                                ToolTip="{Binding DisplayName}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Hover}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Margin="5">
                                                <Image Width="60" Height="60" Stretch="Uniform"
                                                       Source="{Binding ImagePath, Converter={StaticResource TileImageConverter}}"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="9"
                                                           TextTrimming="CharacterEllipsis" 
                                                           HorizontalAlignment="Center"
                                                           Margin="0,5,0,0"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="30"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Info -->
        <Border Grid.Row="2" Background="{StaticResource Brush_Background_Control}" Padding="10,5">
            <TextBlock x:Name="StatusText" Text="No tile selected" 
                       Style="{StaticResource HintText}"/>
        </Border>
    </Grid>
</UserControl>