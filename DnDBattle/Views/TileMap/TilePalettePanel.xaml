<UserControl x:Class="DnDBattle.Views.TileMap.TilePalettePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF2D2D30"
             MinWidth="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#FF1E1E1E" Margin="0,0,0,5">
            <TextBlock Text="Tile Palette" FontSize="14" FontWeight="Bold" Foreground="White" Margin="10,8"/>
            <Button Content="🔄 Refresh Library" Click="RefreshLibrary_Click" Margin="5" Padding="5"/>
        </StackPanel>

        <!-- Tile List (Grouped by Category) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TileList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Key}" IsExpanded="True" Foreground="White" Margin="5">
                            <ItemsControl ItemsSource="{Binding Value}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="80" Height="80" Margin="5" Padding="2"
                                                Click="TileButton_Click" Tag="{Binding}"
                                                ToolTip="{Binding DisplayName}">
                                            <StackPanel>
                                                <Image Width="60" Height="60" Stretch="Uniform"
                                                       Source="{Binding ImagePath, Converter={StaticResource TileImageConverter}}"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="9" Foreground="White"
                                                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Info -->
        <Border Grid.Row="2" Background="#FF1E1E1E" Padding="10,5">
            <TextBlock x:Name="StatusText" Text="No tile selected" Foreground="#FFAAAAAA" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>