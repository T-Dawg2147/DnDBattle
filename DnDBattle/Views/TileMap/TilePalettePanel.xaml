<UserControl x:Class="DnDBattle.Views.TileMap.TilePalettePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- NEW: Search box -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="{StaticResource Brush_Background_Control}" Margin="0,0,0,5">
            <TextBlock Text="🎨 Tile Palette" FontSize="14" FontWeight="Bold" Margin="10,8"/>
            <Button Content="🔄 Refresh Library" Click="RefreshLibrary_Click" 
                    Margin="5" Padding="5" Style="{StaticResource ToolbarButton}" 
                    HorizontalAlignment="Stretch"/>
            <Button Content="➕ Import Tiles..." Click="ImportTiles_Click" 
                    Margin="5,0,5,5" Padding="5" Style="{StaticResource ToolbarButton}" 
                    HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- NEW: Search Box -->
        <Border Grid.Row="1" Background="{StaticResource Brush_Background_Control}" 
                Padding="5" Margin="5,0,5,5">
            <Grid>
                <TextBox x:Name="TxtSearch" 
                         Height="30"
                         VerticalContentAlignment="Center"
                         TextChanged="TxtSearch_TextChanged"
                         Background="{StaticResource Brush_Background_Dark}"/>
                <TextBlock Text="🔍 Search tiles..." 
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{StaticResource Brush_Text_Hint}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Tile List (Grouped by Category) -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="TileList">
                <!-- existing template -->
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Info -->
        <Border Grid.Row="3" Background="{StaticResource Brush_Background_Control}" Padding="10,5">
            <TextBlock x:Name="StatusText" Text="No tile selected" 
                       Style="{StaticResource HintText}"/>
        </Border>
    </Grid>
</UserControl>