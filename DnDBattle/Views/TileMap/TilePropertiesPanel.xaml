<UserControl x:Class="DnDBattle.Views.TileMap.TilePropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="280">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">

            <!-- Header -->
            <TextBlock Text="⚙️ Tile Properties" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10"/>

            <Separator Margin="0,0,0,10"/>

            <!-- Basic Properties -->
            <TextBlock Text="📍 Position" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Grid X:"/>
                    <TextBox x:Name="TxtGridX" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Grid Y:"/>
                    <TextBox x:Name="TxtGridY" IsReadOnly="True"/>
                </StackPanel>
            </Grid>

            <!-- Rotation & Flip -->
            <TextBlock Text="🔄 Transform" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <TextBlock Text="Rotation:"/>
            <TextBox x:Name="TxtRotation" IsReadOnly="True" Margin="0,0,0,5"/>

            <CheckBox x:Name="ChkFlipH" Content="Flip Horizontal" IsEnabled="False" Margin="0,0,0,2"/>
            <CheckBox x:Name="ChkFlipV" Content="Flip Vertical" IsEnabled="False" Margin="0,0,0,10"/>

            <Separator Margin="0,0,0,10"/>

            <!-- Tile Definition Properties Section -->
            <TextBlock Text="🧱 Tile Definition" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtTileDefName" Text="No tile selected" 
                       Style="{StaticResource HintText}" Margin="0,0,0,10"/>

            <!-- Collision & Vision -->
            <TextBlock Text="🚧 Collision &amp; Vision" FontWeight="SemiBold" Margin="0,5,0,5"/>
            <CheckBox x:Name="ChkBlocksMovement" Content="Blocks Movement" Margin="0,0,0,2"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
            <CheckBox x:Name="ChkBlocksSight" Content="Blocks Line of Sight" Margin="0,0,0,2"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
            <CheckBox x:Name="ChkBlocksLight" Content="Blocks Light" Margin="0,0,0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>

            <!-- Terrain Effects -->
            <TextBlock Text="🏔️ Terrain Effects" FontWeight="SemiBold" Margin="0,5,0,5"/>
            <CheckBox x:Name="ChkDifficultTerrain" Content="Difficult Terrain (2x movement cost)" Margin="0,0,0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>

            <!-- Door Properties -->
            <TextBlock Text="🚪 Door Properties" FontWeight="SemiBold" Margin="0,5,0,5"/>
            <CheckBox x:Name="ChkIsDoor" Content="Is Door" Margin="0,0,0,2"
                      Checked="IsDoor_Changed" Unchecked="IsDoor_Changed"/>
            <StackPanel x:Name="DoorPropertiesPanel" Visibility="Collapsed" Margin="15,0,0,5">
                <CheckBox x:Name="ChkIsLocked" Content="Locked by Default" Margin="0,0,0,2"
                          Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Lock DC:" VerticalAlignment="Center" Width="60"/>
                    <TextBox x:Name="TxtLockDC" Width="50" Text="15" 
                             TextChanged="TileDefProperty_Changed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Break DC:" VerticalAlignment="Center" Width="60"/>
                    <TextBox x:Name="TxtBreakDC" Width="50" Text="20" 
                             TextChanged="TileDefProperty_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- Cover Properties -->
            <TextBlock Text="🛡️ Cover Properties" FontWeight="SemiBold" Margin="0,5,0,5"/>
            <CheckBox x:Name="ChkProvidesCover" Content="Provides Cover" Margin="0,0,0,2"
                      Checked="ProvidesCover_Changed" Unchecked="ProvidesCover_Changed"/>
            <StackPanel x:Name="CoverPropertiesPanel" Visibility="Collapsed" Margin="15,0,0,5">
                <TextBlock Text="Cover Type:" Margin="0,0,0,2"/>
                <ComboBox x:Name="CmbCoverType" SelectedIndex="0" Margin="0,0,0,5"
                          SelectionChanged="CoverType_Changed">
                    <ComboBoxItem Content="None" Tag="None"/>
                    <ComboBoxItem Content="Half (+2 AC)" Tag="Half"/>
                    <ComboBoxItem Content="Three-Quarters (+5 AC)" Tag="ThreeQuarters"/>
                    <ComboBoxItem Content="Full (untargetable)" Tag="Full"/>
                </ComboBox>
            </StackPanel>

            <!-- Interactive Properties -->
            <TextBlock Text="⚡ Interactive Properties" FontWeight="SemiBold" Margin="0,5,0,5"/>
            <CheckBox x:Name="ChkIsInteractive" Content="Is Interactive" Margin="0,0,0,2"
                      Checked="IsInteractive_Changed" Unchecked="IsInteractive_Changed"/>
            <StackPanel x:Name="InteractivePropertiesPanel" Visibility="Collapsed" Margin="15,0,0,5">
                <TextBlock Text="Interaction Type:" Margin="0,0,0,2"/>
                <ComboBox x:Name="CmbInteractionType" SelectedIndex="0" Margin="0,0,0,5"
                          SelectionChanged="InteractionType_Changed">
                    <ComboBoxItem Content="Open/Close" Tag="OpenClose"/>
                    <ComboBoxItem Content="Loot" Tag="Loot"/>
                    <ComboBoxItem Content="Lever/Switch" Tag="Lever"/>
                    <ComboBoxItem Content="Button" Tag="Button"/>
                    <ComboBoxItem Content="Custom" Tag="Custom"/>
                </ComboBox>
                <TextBlock Text="Interaction Data:" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtInteractionData" Height="40" TextWrapping="Wrap" 
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextChanged="TileDefProperty_Changed"/>
            </StackPanel>

            <Separator Margin="0,10,0,10"/>

            <!-- Notes -->
            <TextBlock Text="📝 Notes" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtNotes" 
                     Height="60" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,10"
                     TextChanged="Notes_Changed"/>

            <Separator Margin="0,0,0,10"/>

            <!-- Metadata Section -->
            <TextBlock Text="🏷️ Metadata" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <!-- Metadata List -->
            <Border BorderBrush="{StaticResource Brush_Border_Normal}" 
                    BorderThickness="1" 
                    Margin="0,0,0,5"
                    Height="120">
                <ListBox x:Name="MetadataList" 
                         Background="{StaticResource Brush_Background_Dark}"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- Metadata Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="✏️ Edit" 
                        Width="70" 
                        Height="30" 
                        Margin="0,0,5,0"
                        Click="EditMetadata_Click"/>
                <Button Content="🗑️ Remove" 
                        Width="70" 
                        Height="30"
                        Click="RemoveMetadata_Click"/>
            </StackPanel>

            <!-- Add Metadata Buttons -->
            <TextBlock Text="Add Metadata:" Margin="0,0,0,5"/>
            <WrapPanel>
                <Button Content="⚠️ Trap" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddTrap_Click"/>
                <Button Content="🔍 Secret" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddSecret_Click"/>
                <Button Content="⚙️ Interactive" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddInteractive_Click"/>
                <Button Content="⚡ Trigger" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddTrigger_Click"/>
                <Button Content="☠️ Hazard" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddHazard_Click"/>
                <Button Content="🌀 Teleporter" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddTeleporter_Click"/>
                <Button Content="💚 Healing" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddHealing_Click"/>
                <Button Content="👹 Spawn" 
                        Margin="2" 
                        Padding="8,4" 
                        Click="AddSpawn_Click"/>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>