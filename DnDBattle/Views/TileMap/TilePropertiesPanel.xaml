<UserControl x:Class="DnDBattle.Views.TileMap.TilePropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="280"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- Header -->
            <Border Background="#252526" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="⚙️ TILE PROPERTIES" 
                               FontSize="13" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="TxtTileDefName" Text="No tile selected" 
                               Style="{StaticResource HintText}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Position -->
            <TextBlock Text="📍 POSITION" Style="{StaticResource SectionHeader}" Margin="0,5,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Grid X" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtGridX" IsReadOnly="True" Background="#252526" Foreground="#CCC" BorderBrush="#444" Padding="8,6"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Grid Y" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtGridY" IsReadOnly="True" Background="#252526" Foreground="#CCC" BorderBrush="#444" Padding="8,6"/>
                </StackPanel>
            </Grid>

            <!-- Transform -->
            <TextBlock Text="🔄 TRANSFORM" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Rotation" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtRotation" IsReadOnly="True" Background="#252526" Foreground="#CCC" BorderBrush="#444" Padding="8,6" Margin="0,0,0,8"/>

            <CheckBox x:Name="ChkFlipH" Content="Flip Horizontal" IsEnabled="False" Foreground="#CCC" Margin="0,5"/>
            <CheckBox x:Name="ChkFlipV" Content="Flip Vertical" IsEnabled="False" Foreground="#CCC" Margin="0,5"/>

            <!-- Collision & Vision -->
            <TextBlock Text="🚧 COLLISION &amp; VISION" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="ChkBlocksMovement" Content="Blocks Movement" Foreground="#CCC" Margin="0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
            <CheckBox x:Name="ChkBlocksSight" Content="Blocks Line of Sight" Foreground="#CCC" Margin="0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
            <CheckBox x:Name="ChkBlocksLight" Content="Blocks Light" Foreground="#CCC" Margin="0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>

            <!-- Terrain -->
            <TextBlock Text="🏔️ TERRAIN" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="ChkDifficultTerrain" Content="Difficult Terrain (2x movement cost)" Foreground="#CCC" Margin="0,5"
                      Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>

            <!-- Door Properties -->
            <TextBlock Text="🚪 DOOR" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="ChkIsDoor" Content="Is Door" Foreground="#CCC" Margin="0,5"
                      Checked="IsDoor_Changed" Unchecked="IsDoor_Changed"/>
            <StackPanel x:Name="DoorPropertiesPanel" Visibility="Collapsed" Margin="15,5,0,5">
                <CheckBox x:Name="ChkIsLocked" Content="Locked by Default" Foreground="#AAA" Margin="0,3"
                          Checked="TileDefProperty_Changed" Unchecked="TileDefProperty_Changed"/>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Lock DC:" Foreground="#AAA" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtLockDC" Grid.Column="1" Width="60" Text="15" HorizontalAlignment="Left"
                             Background="#252526" Foreground="White" BorderBrush="#444" Padding="6,4"
                             TextChanged="TileDefProperty_Changed"/>
                </Grid>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Break DC:" Foreground="#AAA" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtBreakDC" Grid.Column="1" Width="60" Text="20" HorizontalAlignment="Left"
                             Background="#252526" Foreground="White" BorderBrush="#444" Padding="6,4"
                             TextChanged="TileDefProperty_Changed"/>
                </Grid>
            </StackPanel>

            <!-- Cover Properties -->
            <TextBlock Text="🛡️ COVER" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="ChkProvidesCover" Content="Provides Cover" Foreground="#CCC" Margin="0,5"
                      Checked="ProvidesCover_Changed" Unchecked="ProvidesCover_Changed"/>
            <StackPanel x:Name="CoverPropertiesPanel" Visibility="Collapsed" Margin="15,5,0,5">
                <TextBlock Text="Cover Type" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbCoverType" SelectedIndex="0" Background="#252526" Margin="0,0,0,5"
                          SelectionChanged="CoverType_Changed">
                    <ComboBoxItem Content="None" Tag="None"/>
                    <ComboBoxItem Content="Half (+2 AC)" Tag="Half"/>
                    <ComboBoxItem Content="Three-Quarters (+5 AC)" Tag="ThreeQuarters"/>
                    <ComboBoxItem Content="Full (untargetable)" Tag="Full"/>
                </ComboBox>
            </StackPanel>

            <!-- Interactive Properties -->
            <TextBlock Text="⚡ INTERACTIVE" Style="{StaticResource SectionHeader}"/>
            <CheckBox x:Name="ChkIsInteractive" Content="Is Interactive" Foreground="#CCC" Margin="0,5"
                      Checked="IsInteractive_Changed" Unchecked="IsInteractive_Changed"/>
            <StackPanel x:Name="InteractivePropertiesPanel" Visibility="Collapsed" Margin="15,5,0,5">
                <TextBlock Text="Interaction Type" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbInteractionType" SelectedIndex="0" Background="#252526" Margin="0,0,0,8"
                          SelectionChanged="InteractionType_Changed">
                    <ComboBoxItem Content="Open/Close" Tag="OpenClose"/>
                    <ComboBoxItem Content="Loot" Tag="Loot"/>
                    <ComboBoxItem Content="Lever/Switch" Tag="Lever"/>
                    <ComboBoxItem Content="Button" Tag="Button"/>
                    <ComboBoxItem Content="Custom" Tag="Custom"/>
                </ComboBox>
                <TextBlock Text="Interaction Data" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtInteractionData" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                         Background="#252526" Foreground="White" BorderBrush="#444" Padding="8,6"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TileDefProperty_Changed"/>
            </StackPanel>

            <!-- Notes -->
            <TextBlock Text="📝 NOTES" Style="{StaticResource SectionHeader}"/>
            <TextBox x:Name="TxtNotes" 
                     Height="70" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     Background="#252526" Foreground="White" BorderBrush="#444" Padding="8,6"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="Notes_Changed"/>

            <!-- Metadata Section -->
            <TextBlock Text="🏷️ METADATA" Style="{StaticResource SectionHeader}"/>

            <Border Background="#252526" CornerRadius="4" Padding="5" Height="100" Margin="0,0,0,8">
                <ListBox x:Name="MetadataList" 
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Foreground" Value="#CCC"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- Metadata Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="✏️ Edit" Padding="12,6" Margin="0,0,8,0" Click="EditMetadata_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="🗑️ Remove" Padding="12,6" Click="RemoveMetadata_Click"
                        Background="#C42B1C" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <!-- Add Metadata Buttons -->
            <TextBlock Text="Add Metadata:" Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
            <WrapPanel>
                <Button Content="⚠️ Trap" Margin="3" Padding="10,5" Click="AddTrap_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="🔍 Secret" Margin="3" Padding="10,5" Click="AddSecret_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="⚙️ Interactive" Margin="3" Padding="10,5" Click="AddInteractive_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="⚡ Trigger" Margin="3" Padding="10,5" Click="AddTrigger_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="☠️ Hazard" Margin="3" Padding="10,5" Click="AddHazard_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="🌀 Teleporter" Margin="3" Padding="10,5" Click="AddTeleporter_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="💚 Healing" Margin="3" Padding="10,5" Click="AddHealing_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                <Button Content="👹 Spawn" Margin="3" Padding="10,5" Click="AddSpawn_Click"
                        Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>