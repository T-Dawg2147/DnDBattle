<Window x:Class="DnDBattle.Views.TileMap.ManualRollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manual Roll" Height="350" Width="450"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TxtHeader" Text="🎲 Manual Roll Required" 
                       FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock x:Name="TxtPrompt" Text="Ask the player to roll..." 
                       FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15"/>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Character:" Style="{StaticResource HintText}"/>
                    <TextBlock x:Name="TxtCharacter" Text="Character Name" 
                               FontSize="14" FontWeight="Bold" Margin="0,2,0,10"/>

                    <TextBlock Text="Modifier:" Style="{StaticResource HintText}"/>
                    <TextBlock x:Name="TxtModifier" Text="+3" 
                               FontSize="14" FontWeight="Bold" Margin="0,2,0,10"
                               Foreground="{StaticResource Brush_Info}"/>

                    <TextBlock Text="Target DC:" Style="{StaticResource HintText}"/>
                    <TextBlock x:Name="TxtDC" Text="15" 
                               FontSize="14" FontWeight="Bold" Margin="0,2,0,0"
                               Foreground="{StaticResource Brush_Warning}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Enter the player's d20 roll result:" 
                       FontSize="12" Margin="0,20,0,5"/>
            <TextBox x:Name="TxtRoll" FontSize="24" Height="50" 
                     HorizontalContentAlignment="Center"
                     TextChanged="TxtRoll_TextChanged"/>

            <TextBlock x:Name="TxtResult" Text="" 
                       FontSize="14" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"
                       Foreground="{StaticResource Brush_Info}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="✅ Confirm" Width="100" Height="35" Margin="5" 
                    Click="Confirm_Click" IsDefault="True" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" 
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>