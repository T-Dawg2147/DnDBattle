<Window x:Class="DnDBattle.Views.TileMap.MapResizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize Map" Height="460" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="📐 Resize Map" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <!-- Current Size -->
            <Border Background="{StaticResource Brush_Background_Control}"
                    BorderBrush="{StaticResource Brush_Border_Normal}"
                    BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Current Size:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtCurrentSize" Text="50 × 50" FontSize="20" 
                               Foreground="{StaticResource Brush_Accent_Primary}" Margin="0,5"/>
                    <TextBlock x:Name="TxtTileCount" Text="Contains 0 tiles" 
                               Style="{StaticResource HintText}"/>
                </StackPanel>
            </Border>

            <!-- New Size -->
            <TextBlock Text="New Size:" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Width:"/>
                    <TextBox x:Name="TxtWidth" Height="35" FontSize="14" 
                             VerticalContentAlignment="Center" TextChanged="Size_TextChanged"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="×" FontSize="20" 
                           VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Height:"/>
                    <TextBox x:Name="TxtHeight" Height="35" FontSize="14" 
                             VerticalContentAlignment="Center" TextChanged="Size_TextChanged"/>
                </StackPanel>
            </Grid>

            <!-- Warning -->
            <Border Background="{StaticResource Brush_Warning}" Opacity="0.2"
                    BorderBrush="{StaticResource Brush_Warning}"
                    BorderThickness="1" Padding="10" CornerRadius="4" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="⚠️ Warning:" FontWeight="Bold" 
                               Foreground="{StaticResource Brush_Warning}"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush_Text_Primary}">
                        Shrinking the map will remove tiles outside the new boundaries.
                        <LineBreak/>
                        This action cannot be undone!
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <TextBlock x:Name="TxtPreview" Text="" Margin="0,10,0,0" 
                       Style="{StaticResource HintText}"/>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="✅ Resize" Width="100" Height="35" Margin="5" 
                    Click="Resize_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" 
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>