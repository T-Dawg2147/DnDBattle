<Window x:Class="DnDBattle.Views.TileMap.MapResizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📐 Resize Map" Height="480" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="📐 Resize Map" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}"/>
            <TextBlock Text="Change the dimensions of your tile map" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1">
            <!-- Current Size -->
            <Border Background="{StaticResource Brush_Background_Control}" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="CURRENT SIZE" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtCurrentSize" Text="50 × 50" FontSize="24" 
                               Foreground="{StaticResource Brush_Accent_Primary}" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTileCount" Text="Contains 0 tiles" 
                               Foreground="{StaticResource Brush_Text_Hint}" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- New Size -->
            <Border Background="{StaticResource Brush_Background_Control}" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="NEW SIZE" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Width" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtWidth" Height="40" FontSize="16" 
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     TextChanged="Size_TextChanged"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="×" FontSize="24" 
                                   Foreground="{StaticResource Brush_Text_Disabled}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Height" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtHeight" Height="40" FontSize="16" 
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     TextChanged="Size_TextChanged"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Warning -->
            <Border Background="#3D2B1C" CornerRadius="6" Padding="15" BorderBrush="{StaticResource Brush_Warning}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⚠️ Warning" FontWeight="Bold" Foreground="{StaticResource Brush_Warning}" Margin="0,0,0,5"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">
                        Shrinking the map will remove tiles outside the new boundaries.
                        <LineBreak/>
                        This action cannot be undone!
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <TextBlock x:Name="TxtPreview" Text="" Margin="0,10,0,0" 
                       Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" 
                    Click="Cancel_Click"/>
            <Button Content="✅ Resize" Padding="20,10" 
                    Click="Resize_Click"
                    Style="{StaticResource SuccessButton}"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>