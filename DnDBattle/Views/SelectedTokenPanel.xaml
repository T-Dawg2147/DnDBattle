<UserControl x:Class="DnDBattle.Views.SelectedTokenPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignWidth="320"
             Background="#1E1E1E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Stat Box Style -->
        <Style x:Key="StatBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5E5E62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No Token Selected Message -->
        <TextBlock x:Name="NoSelectionMessage"
                   Text="Select a token on the map"
                   Foreground="#666"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Visible"/>

        <!-- Token Details Panel -->
        <ScrollViewer x:Name="TokenDetailsScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel Margin="15">

                <!-- Header: Name and Type -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtTokenName" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtTokenSubtitle" 
                                   FontSize="12" 
                                   Foreground="#888" 
                                   FontStyle="Italic"/>
                    </StackPanel>

                    <!-- Token Image -->
                    <Border Grid.Column="1" 
                            Width="50" Height="50" 
                            CornerRadius="4" 
                            Background="#2D2D30"
                            Margin="10,0,0,0">
                        <Image x:Name="ImgToken" 
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>

                <!-- Conditions Bar -->
                <Border x:Name="ConditionsBar" 
                        Background="#3E3220" 
                        CornerRadius="4" 
                        Padding="10,8" 
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Active Conditions" 
                                   FontSize="10" 
                                   Foreground="#888" 
                                   Margin="0,0,0,5"/>
                        <WrapPanel x:Name="ConditionIconsPanel"/>
                    </StackPanel>
                </Border>

                <!-- HP Section -->
                <TextBlock Text="Hit Points" Style="{StaticResource SectionHeaderStyle}" Margin="0,5,0,8"/>
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCurrentHP" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#4CAF50"/>
                                <TextBlock Text=" / " 
                                           FontSize="18" 
                                           Foreground="#666" 
                                           VerticalAlignment="Bottom" 
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtMaxHP" 
                                           FontSize="18" 
                                           Foreground="#888" 
                                           VerticalAlignment="Bottom" 
                                           Margin="0,0,0,4"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="💚" 
                                        Width="32" Height="32" 
                                        Margin="0,0,5,0"
                                        ToolTip="Heal"
                                        Click="BtnHeal_Click"
                                        Style="{StaticResource ActionButtonStyle}"/>
                                <Button Content="💔" 
                                        Width="32" Height="32"
                                        ToolTip="Damage"
                                        Click="BtnDamage_Click"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- HP Bar -->
                        <Grid Height="8" Margin="0,10,0,0">
                            <Border Background="#1E1E1E" CornerRadius="4"/>
                            <Border x:Name="HPBarFill" 
                                    Background="#4CAF50" 
                                    CornerRadius="4" 
                                    HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Temp HP -->
                        <StackPanel x:Name="TempHPPanel" 
                                    Orientation="Horizontal" 
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="Temp HP: " Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="TxtTempHP" Foreground="#64B5F6" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Core Stats -->
                <TextBlock Text="Combat Stats" Style="{StaticResource SectionHeaderStyle}"/>
                <UniformGrid Columns="3">
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="AC" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtAC" Foreground="#4FC3F7" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Initiative" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtInitiative" Foreground="#BA68C8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CR" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCR" Foreground="#FFB74D" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Ability Scores -->
                <TextBlock Text="Ability Scores" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Background="#252526" CornerRadius="6" Padding="10">
                    <UniformGrid Columns="6">
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="STR" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtStr" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtStrMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="DEX" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtDex" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtDexMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="CON" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCon" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtConMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="INT" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtInt" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtIntMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="WIS" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtWis" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtWisMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="2">
                            <TextBlock Text="CHA" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCha" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtChaMod" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Speed -->
                <TextBlock Text="Speed" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock x:Name="TxtSpeed" Foreground="#CCC" FontSize="13" TextWrapping="Wrap"/>

                <!-- Movement (During Combat) -->
                <StackPanel x:Name="MovementSection" Visibility="Collapsed">
                    <TextBlock Text="Movement This Turn" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Background="#252526" CornerRadius="6" Padding="10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtMovementRemaining" Foreground="#64B5F6" FontSize="14"/>
                                <Button Grid.Column="1" 
                                        Content="Reset" 
                                        FontSize="10" 
                                        Padding="8,3"
                                        Click="BtnResetMovement_Click"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </Grid>
                            <Grid Height="6" Margin="0,8,0,0">
                                <Border Background="#1E1E1E" CornerRadius="3"/>
                                <Border x:Name="MovementBarFill" 
                                        Background="#64B5F6" 
                                        CornerRadius="3" 
                                        HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Actions Section -->
                <TextBlock Text="Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#F44336"/>
                <StackPanel x:Name="ActionsPanel">
                    <TextBlock x:Name="NoActionsText" 
                               Text="No actions available" 
                               Foreground="#666" 
                               FontStyle="Italic"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Bonus Actions -->
                <StackPanel x:Name="BonusActionsSection" Visibility="Collapsed">
                    <TextBlock Text="Bonus Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#FF9800"/>
                    <StackPanel x:Name="BonusActionsPanel"/>
                </StackPanel>

                <!-- Reactions -->
                <StackPanel x:Name="ReactionsSection" Visibility="Collapsed">
                    <TextBlock Text="Reactions" Style="{StaticResource SectionHeaderStyle}" Foreground="#9C27B0"/>
                    <StackPanel x:Name="ReactionsPanel"/>
                </StackPanel>

                <!-- Legendary Actions -->
                <StackPanel x:Name="LegendaryActionsSection" Visibility="Collapsed">
                    <TextBlock Text="Legendary Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#FFD700"/>
                    <StackPanel x:Name="LegendaryActionsPanel"/>
                </StackPanel>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <Button Content="🎲 Roll Initiative" 
                            Click="BtnRollInitiative_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,5,5"/>
                    <Button Content="🏃 Dodge" 
                            Click="BtnDodge_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,5,5"/>
                    <Button Content="🎯 Concentrate" 
                            Click="BtnConcentrate_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,5,5"/>
                    <Button Content="🥷 Hide" 
                            Click="BtnHide_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,5,5"/>
                </WrapPanel>

                <!-- Traits (Collapsible) -->
                <Expander x:Name="TraitsExpander" 
                          Header="Traits &amp; Features" 
                          Foreground="#4FC3F7"
                          Margin="0,10,0,0"
                          IsExpanded="False"
                          Visibility="Collapsed">
                    <Border Background="#252526" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                        <TextBlock x:Name="TxtTraits" 
                                   Foreground="#CCC" 
                                   TextWrapping="Wrap" 
                                   FontSize="12"/>
                    </Border>
                </Expander>

                <!-- Notes (Collapsible) -->
                <Expander Header="Notes" 
                          Foreground="#4FC3F7"
                          Margin="0,10,0,0"
                          IsExpanded="False">
                    <Border Background="#252526" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                        <TextBox x:Name="TxtNotes" 
                                 Background="Transparent"
                                 Foreground="#CCC"
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 TextChanged="TxtNotes_TextChanged"/>
                    </Border>
                </Expander>

                <!-- Bottom Spacing -->
                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>