<UserControl x:Class="DnDBattle.Views.SelectedTokenPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DnDBattle.Views"
             mc:Ignorable="d" 
             d:DesignWidth="320"
             Background="#1E1E1E"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Stat Box Style -->
        <Style x:Key="StatBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5E5E62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Action Button Style (smaller) -->
        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No Token Selected Message -->
        <TextBlock x:Name="NoSelectionMessage"
                   Text="Select a token on the map"
                   Foreground="#666"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Visible"/>

        <!-- Token Details Panel -->
        <ScrollViewer x:Name="TokenDetailsScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel Margin="12,10">

                <!-- Targeting Mode Indicator -->
                <Border x:Name="TargetingIndicator" 
                        Background="#1B5E20" 
                        CornerRadius="4" 
                        Padding="10,8" 
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtTargetingAction" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="12"/>
                            <TextBlock Text="Click a target on the map" 
                                       Foreground="#A5D6A7" 
                                       FontSize="10"/>
                        </StackPanel>

                        <Button Grid.Column="1" 
                                Content="✕ Cancel" 
                                Padding="8,4"
                                Click="BtnCancelTargeting_Click"
                                Background="#C62828"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Header: Name and Type -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtTokenName" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtTokenSubtitle" 
                                   FontSize="10" 
                                   Foreground="#888" 
                                   FontStyle="Italic"/>
                    </StackPanel>

                    <!-- Token Image -->
                    <Border Grid.Column="1" 
                            Width="40" Height="40" 
                            CornerRadius="4" 
                            Background="#2D2D30"
                            Margin="8,0,0,0">
                        <Image x:Name="ImgToken" 
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>

                <!-- Conditions Bar -->
                <Border x:Name="ConditionsBar" 
                        Background="#3E3220" 
                        CornerRadius="4" 
                        Padding="8,6" 
                        Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Active Conditions" 
                                   FontSize="9" 
                                   Foreground="#888" 
                                   Margin="0,0,0,4"/>
                        <WrapPanel x:Name="ConditionIconsPanel"/>
                    </StackPanel>
                </Border>

                <!-- Concentration Indicator -->
                <Border x:Name="ConcentrationBar" 
                        Background="#1565C0" 
                        CornerRadius="4" 
                        Padding="8,6" 
                        Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="🎯 Concentrating" 
                                       FontSize="10" 
                                       Foreground="#90CAF9"/>
                            <TextBlock x:Name="TxtConcentrationSpell" 
                                       FontSize="12" 
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button Grid.Column="1" 
                                Content="✕" 
                                Width="24" Height="24"
                                ToolTip="Break Concentration"
                                Click="BtnBreakConcentration_Click"
                                Background="#C62828"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"/>
                    </Grid>
                </Border>

                <!-- Death Saves Panel -->
                <Border x:Name="DeathSavesPanel" 
                        Background="#37474F" 
                        CornerRadius="4" 
                        Padding="10,8" 
                        Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="💀 Death Saving Throws" 
                                   FontSize="10" 
                                   Foreground="#B0BEC5"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Successes -->
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Successes" Foreground="#81C784" FontSize="9" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Ellipse x:Name="DeathSuccess1" Width="16" Height="16" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                                    <Ellipse x:Name="DeathSuccess2" Width="16" Height="16" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                                    <Ellipse x:Name="DeathSuccess3" Width="16" Height="16" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Failures -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Failures" Foreground="#E57373" FontSize="9" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Ellipse x:Name="DeathFailure1" Width="16" Height="16" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                                    <Ellipse x:Name="DeathFailure2" Width="16" Height="16" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                                    <Ellipse x:Name="DeathFailure3" Width="16" Height="16" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Status Text -->
                        <TextBlock x:Name="TxtDeathSaveStatus" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   FontWeight="Bold"/>

                        <!-- Death Save Button -->
                        <Button x:Name="BtnRollDeathSave"
                                Content="🎲 Roll Death Save" 
                                Margin="0,8,0,0"
                                Padding="10,6"
                                Click="BtnRollDeathSave_Click"
                                Background="#455A64"
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- HP Section -->
                <TextBlock Text="Hit Points" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,6"/>
                <Border Background="#252526" CornerRadius="4" Padding="10,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCurrentHP" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="#4CAF50"/>
                                <TextBlock Text=" / " 
                                           FontSize="14" 
                                           Foreground="#666" 
                                           VerticalAlignment="Bottom" 
                                           Margin="0,0,0,3"/>
                                <TextBlock x:Name="TxtMaxHP" 
                                           FontSize="14" 
                                           Foreground="#888" 
                                           VerticalAlignment="Bottom" 
                                           Margin="0,0,0,3"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="💚" 
                                        Width="28" Height="28" 
                                        Margin="0,0,4,0"
                                        ToolTip="Heal"
                                        Click="BtnHeal_Click"
                                        Style="{StaticResource ActionButtonStyle}"/>
                                <Button Content="💔" 
                                        Width="28" Height="28"
                                        ToolTip="Damage"
                                        Click="BtnDamage_Click"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- HP Bar -->
                        <Grid Height="6" Margin="0,8,0,0">
                            <Border Background="#1E1E1E" CornerRadius="3"/>
                            <Border x:Name="HPBarFill" 
                                    Background="#4CAF50" 
                                    CornerRadius="3" 
                                    HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Temp HP -->
                        <StackPanel x:Name="TempHPPanel" 
                                    Orientation="Horizontal" 
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="Temp HP: " Foreground="#888" FontSize="10"/>
                            <TextBlock x:Name="TxtTempHP" Foreground="#64B5F6" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Core Stats -->
                <TextBlock Text="Combat Stats" Style="{StaticResource SectionHeaderStyle}"/>
                <UniformGrid Columns="3">
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="AC" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtAC" Foreground="#4FC3F7" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Initiative" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtInitiative" Foreground="#BA68C8" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBoxStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CR" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCR" Foreground="#FFB74D" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Ability Scores -->
                <TextBlock Text="Ability Scores" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Background="#252526" CornerRadius="4" Padding="8">
                    <UniformGrid Columns="6">
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="STR" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtStr" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtStrMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="DEX" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtDex" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtDexMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="CON" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCon" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtConMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="INT" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtInt" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtIntMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="WIS" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtWis" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtWisMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="1">
                            <TextBlock Text="CHA" Foreground="#888" FontSize="8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCha" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtChaMod" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Speed -->
                <TextBlock Text="Speed" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock x:Name="TxtSpeed" Foreground="#CCC" FontSize="11" TextWrapping="Wrap"/>

                <!-- Movement (During Combat) -->
                <StackPanel x:Name="MovementSection" Visibility="Collapsed">
                    <TextBlock Text="Movement This Turn" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Background="#252526" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtMovementRemaining" Foreground="#64B5F6" FontSize="11"/>
                                <Button Grid.Column="1" 
                                        Content="Reset" 
                                        FontSize="9" 
                                        Padding="6,2"
                                        Click="BtnResetMovement_Click"
                                        Style="{StaticResource QuickActionButtonStyle}"/>
                            </Grid>
                            <Grid Height="5" Margin="0,6,0,0">
                                <Border Background="#1E1E1E" CornerRadius="2"/>
                                <Border x:Name="MovementBarFill" 
                                        Background="#64B5F6" 
                                        CornerRadius="2" 
                                        HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Legendary Actions Display -->
                <Border x:Name="LegendaryActionsPanel" 
                        Background="#252526" 
                        CornerRadius="4" 
                        Padding="10"
                        Margin="0,8,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⭐ Legendary Actions" 
                                   Foreground="#FFD700" 
                                   FontWeight="Bold" 
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <StackPanel x:Name="LegendaryPointsContainer" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Margin="0,0,0,8"/>

                        <TextBlock x:Name="TxtLegendaryRemaining" 
                                   HorizontalAlignment="Center"
                                   Foreground="#888"
                                   FontSize="10"/>

                        <Button x:Name="BtnResetLegendary"
                                Content="🔄 Reset"
                                Padding="8,4"
                                Margin="0,8,0,0"
                                Click="BtnResetLegendary_Click"
                                Background="#3E3E42"
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Center"
                                Cursor="Hand"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Spell Slots Display -->
                <Border x:Name="SpellSlotsPanel" 
                        Background="#252526" 
                        CornerRadius="4" 
                        Padding="10"
                        Margin="0,8,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="✨ Spell Slots" 
                                   Foreground="#BA68C8" 
                                   FontWeight="Bold" 
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <WrapPanel x:Name="SpellSlotsContainer"/>

                        <Button Content="🌙 Long Rest"
                                Padding="8,4"
                                Margin="0,8,0,0"
                                Click="BtnLongRest_Click"
                                Background="#3E3E42"
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Token Notes -->
                <Border x:Name="NotesPanel" 
                        Background="#252526" 
                        CornerRadius="4" 
                        Padding="10"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="📝 Notes" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11"/>

                            <Button Grid.Column="1" 
                                    Content="+" 
                                    Width="20" Height="20"
                                    Click="BtnAddNote_Click"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="Bold"
                                    Cursor="Hand"/>
                        </Grid>

                        <StackPanel x:Name="NotesContainer"/>

                        <Grid x:Name="QuickAddNotePanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TxtQuickNote" 
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#444"
                                     Padding="8,6"
                                     KeyDown="TxtQuickNote_KeyDown"/>

                            <Button Grid.Column="1" 
                                    Content="✓" 
                                    Width="28"
                                    Margin="5,0,0,0"
                                    Click="BtnConfirmNote_Click"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Actions Section -->
                <TextBlock Text="Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#F44336"/>
                <StackPanel x:Name="ActionsPanel">
                    <TextBlock x:Name="NoActionsText" 
                               Text="No actions available" 
                               Foreground="#666" 
                               FontStyle="Italic"
                               FontSize="10"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Bonus Actions -->
                <StackPanel x:Name="BonusActionsSection" Visibility="Collapsed">
                    <TextBlock Text="Bonus Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#FF9800"/>
                    <StackPanel x:Name="BonusActionsPanel"/>
                </StackPanel>

                <!-- Reactions -->
                <StackPanel x:Name="ReactionsSection" Visibility="Collapsed">
                    <TextBlock Text="Reactions" Style="{StaticResource SectionHeaderStyle}" Foreground="#9C27B0"/>
                    <StackPanel x:Name="ReactionsPanel"/>
                </StackPanel>

                <!-- Legendary Actions -->
                <StackPanel x:Name="LegendaryActionsSection" Visibility="Collapsed">
                    <TextBlock Text="Legendary Actions" Style="{StaticResource SectionHeaderStyle}" Foreground="#FFD700"/>
                    <StackPanel x:Name="LegendaryActionsListPanel"/>
                </StackPanel>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel x:Name="QuickActionsPanel"/>

                <!-- Traits (Collapsible) -->
                <Expander x:Name="TraitsExpander" 
                          Header="Traits &amp; Features" 
                          Foreground="#4FC3F7"
                          FontSize="10"
                          Margin="0,8,0,0"
                          IsExpanded="False"
                          Visibility="Collapsed">
                    <Border Background="#252526" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                        <TextBlock x:Name="TxtTraits" 
                                   Foreground="#CCC" 
                                   TextWrapping="Wrap" 
                                   FontSize="10"/>
                    </Border>
                </Expander>

                <!-- Notes (Collapsible) -->
                <Expander Header="DM Notes" 
                          Foreground="#4FC3F7"
                          FontSize="10"
                          Margin="0,8,0,0"
                          IsExpanded="False">
                    <Border Background="#252526" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                        <TextBox x:Name="TxtDMNotes" 
                                 Background="Transparent"
                                 Foreground="#CCC"
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontSize="10"
                                 MinHeight="50"
                                 TextChanged="TxtNotes_TextChanged"/>
                    </Border>
                </Expander>

                <!-- Bottom Spacing -->
                <Border Height="15"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>