<UserControl x:Class="DnDBattle.Views.DockablePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="ThisPanel"
             d:DesignWidth="300"
             d:DesignHeight="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PanelHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#1E1E1E" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Panel Header -->
            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="4,4,0,0" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="TitleText"
                               Text="Panel"
                               Foreground="#CCC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnMinimize"
                                Content="🗕"
                                ToolTip="Minimize"
                                Style="{StaticResource PanelHeaderButton}"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize"
                                Content="🗖"
                                ToolTip="Maximize"
                                Style="{StaticResource PanelHeaderButton}"
                                Click="BtnMaximize_Click"
                                Margin="2,0,0,0"/>
                        <Button x:Name="BtnFloat"
                                Content="⧉"
                                ToolTip="Float Panel"
                                Style="{StaticResource PanelHeaderButton}"
                                Click="BtnFloat_Click"
                                Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel Content -->
            <ContentPresenter Grid.Row="1" 
                              x:Name="PanelContent"
                              Content="{Binding ElementName=ThisPanel, Path=PanelChild}"/>
        </Grid>
    </Border>
</UserControl>
