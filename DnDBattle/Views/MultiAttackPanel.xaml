<UserControl x:Class="DnDBattle.Views.MultiAttackPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border x:Name="MainBorder" 
            Background="#252526" 
            CornerRadius="4" 
            Padding="10"
            Visibility="Collapsed">
        <StackPanel>
            <TextBlock Text="⚔️ Multi-Attack" 
                       Foreground="#F44336" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="TxtMultiattackDescription" 
                       Foreground="#888" 
                       FontSize="10"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <!-- Quick Attack Buttons -->
            <StackPanel x:Name="AttackButtonsContainer"/>

            <!-- Roll All Button -->
            <Button x:Name="BtnRollAll"
                    Content="🎲 Roll All Attacks"
                    Padding="10,8"
                    Margin="0,10,0,0"
                    Click="BtnRollAll_Click"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Border>
</UserControl>