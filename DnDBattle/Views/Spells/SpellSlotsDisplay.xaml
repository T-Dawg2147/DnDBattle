<UserControl x:Class="DnDBattle.Views.Spells.SpellSlotsDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border x:Name="MainBorder" 
            Background="{StaticResource Brush_Background_Dark}" 
            CornerRadius="4" 
            Padding="10"
            Visibility="Collapsed">
        <StackPanel>
            <TextBlock Text="✨ Spell Slots" 
                       Foreground="{StaticResource Brush_Accent_Hover}" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <WrapPanel x:Name="SlotsContainer"/>

            <Button x:Name="BtnLongRest"
                    Content="🌙 Long Rest"
                    Padding="8,4"
                    Margin="0,8,0,0"
                    Click="BtnLongRest_Click"
                    Background="{StaticResource Brush_Background_Hover}"
                    Foreground="{StaticResource Brush_Text_Primary}"
                    BorderThickness="0"
                    HorizontalAlignment="Left"
                    Cursor="Hand"
                    ToolTip="Restore all spell slots"/>
        </StackPanel>
    </Border>
</UserControl>