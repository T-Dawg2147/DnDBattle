<Window x:Class="DnDBattle.Views.Spells.SpellLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📖 Spell Templates Library"
        Width="460" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}" Foreground="{StaticResource Brush_Text_Primary}"
        ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
        </Style>
        <Style TargetType="Button" x:Key="SpellButton">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0" Background="{StaticResource Brush_Background_Control}" Padding="8" Margin="8,8,8,0" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍 " VerticalAlignment="Center" FontSize="16"/>
                <TextBox Grid.Column="1" x:Name="TxtSearch" Background="{StaticResource Brush_Background_Dark}" Foreground="{StaticResource Brush_Text_Primary}"
                         BorderBrush="{StaticResource Brush_Border_Normal}" Padding="4" FontSize="14"
                         TextChanged="TxtSearch_TextChanged"/>
                <Button Grid.Column="2" Content="✕" Width="28" Background="Transparent"
                        Foreground="{StaticResource Brush_Text_Hint}" BorderThickness="0" Click="ClearSearch_Click"
                        VerticalAlignment="Center" FontSize="14"/>
            </Grid>
        </Border>

        <!-- Level Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4" HorizontalAlignment="Center">
            <TextBlock Text="Level: " VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CmbLevelFilter" Width="120" SelectionChanged="CmbLevelFilter_SelectionChanged"
                      Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}">
                <ComboBoxItem Content="All Levels" IsSelected="True"/>
                <ComboBoxItem Content="Cantrips"/>
                <ComboBoxItem Content="1st Level"/>
                <ComboBoxItem Content="2nd Level"/>
                <ComboBoxItem Content="3rd Level"/>
                <ComboBoxItem Content="4th Level"/>
                <ComboBoxItem Content="5th Level"/>
                <ComboBoxItem Content="6th Level"/>
                <ComboBoxItem Content="7th Level"/>
                <ComboBoxItem Content="8th Level"/>
                <ComboBoxItem Content="9th Level"/>
            </ComboBox>
            <CheckBox x:Name="ChkFavoritesOnly" Content="⭐ Favorites Only" Foreground="{StaticResource Brush_Text_Primary}"
                      Margin="12,0,0,0" VerticalAlignment="Center"
                      Checked="ChkFavoritesOnly_Changed" Unchecked="ChkFavoritesOnly_Changed"/>
        </StackPanel>

        <!-- Spell List -->
        <ListBox Grid.Row="2" x:Name="LstSpells" Margin="8"
                 Background="{StaticResource Brush_Background_Dark}" BorderBrush="{StaticResource Brush_Border_Normal}"
                 SelectionChanged="LstSpells_SelectionChanged"
                 MouseDoubleClick="LstSpells_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="6,4" Margin="0,1" CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Damage type icon -->
                            <TextBlock Grid.Column="0" Text="{Binding DamageIcon}" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <!-- Spell info -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Brush_Text_Primary}"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource Brush_Text_Hint}">
                                    <Run Text="{Binding LevelDisplay, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding ShapeText, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Description, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <!-- Concentration -->
                            <TextBlock Grid.Column="2" Text="C" FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource Brush_Warning}" VerticalAlignment="Center" Margin="4,0"
                                       Visibility="{Binding ConcentrationVisibility}"/>
                            <!-- Favorite -->
                            <Button Grid.Column="3" Content="{Binding FavoriteStar}" Background="Transparent"
                                    BorderThickness="0" Foreground="{StaticResource Brush_Warning}" FontSize="16"
                                    VerticalAlignment="Center" Cursor="Hand" Tag="{Binding}"
                                    Click="ToggleFavorite_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Background="{StaticResource Brush_Background_Control}" Padding="8" Margin="8,0,8,8" CornerRadius="4">
            <StackPanel>
                <!-- Selected spell details -->
                <TextBlock x:Name="TxtSelectedInfo" TextWrapping="Wrap" FontSize="12"
                           Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📌 Place Spell" Click="PlaceSpell_Click" Padding="12,6"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0"
                            FontSize="13" Margin="0,0,6,0" x:Name="BtnPlace" IsEnabled="False"/>
                    <Button Content="Cancel" Click="Cancel_Click" Padding="12,6"
                            Background="{StaticResource Brush_Error}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
