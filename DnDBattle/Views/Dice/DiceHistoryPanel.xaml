<UserControl x:Class="DnDBattle.Views.Dice.DiceHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush_Background_Medium}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🎲 Dice History" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" FontSize="14"/>

                <Button Grid.Column="1" 
                        Content="🗑️ Clear" 
                        Padding="8,4"
                        Click="BtnClear_Click"
                        Background="{StaticResource Brush_Background_Hover}"
                        Foreground="{StaticResource Brush_Text_Primary}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource Brush_Background_Dark}" Padding="12,8" Margin="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbFilter" Width="120" SelectionChanged="CmbFilter_SelectionChanged">
                    <ComboBoxItem Content="All Rolls" IsSelected="True" Tag="All"/>
                    <ComboBoxItem Content="Attacks" Tag="Attack"/>
                    <ComboBoxItem Content="Damage" Tag="Damage"/>
                    <ComboBoxItem Content="Saving Throws" Tag="SavingThrow"/>
                    <ComboBoxItem Content="Ability Checks" Tag="AbilityCheck"/>
                    <ComboBoxItem Content="Initiative" Tag="Initiative"/>
                </ComboBox>

                <TextBlock Text="Roller:" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Center" Margin="15,0,8,0"/>
                <ComboBox x:Name="CmbRoller" Width="120" SelectionChanged="CmbRoller_SelectionChanged">
                    <ComboBoxItem Content="Everyone" IsSelected="True" Tag=""/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Roll History -->
        <ListBox x:Name="HistoryList" 
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource Brush_Background_Dark}" CornerRadius="4" Padding="10,8" Margin="5,2,5,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Time -->
                            <TextBlock Text="{Binding TimeDisplay}" 
                                       Foreground="{StaticResource Brush_Text_Disabled}" 
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Width="50"/>

                            <!-- Roll Info -->
                            <StackPanel Grid.Column="1" Margin="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding RollerName}" Foreground="{StaticResource Brush_Text_Primary}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" - " Foreground="{StaticResource Brush_Text_Disabled}"/>
                                    <TextBlock Text="{Binding Context}" Foreground="{StaticResource Brush_Text_Hint}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Expression}" Foreground="{StaticResource Brush_Info}" FontSize="11"/>
                            </StackPanel>

                            <!-- Result -->
                            <Border Grid.Column="2" 
                                    CornerRadius="4" 
                                    Padding="12,4"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                <Setter Property="Background" Value="#FFD700"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCriticalFail}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource Brush_Error}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Result}" FontWeight="Bold" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Statistics -->
        <Border Grid.Row="3" Background="{StaticResource Brush_Background_Dark}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Total Rolls" Foreground="{StaticResource Brush_Text_Hint}" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalRolls" Text="0" Foreground="{StaticResource Brush_Text_Primary}" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Nat 20s" Foreground="{StaticResource Brush_Text_Hint}" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtNat20s" Text="0" Foreground="{StaticResource Brush_Warning}" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Nat 1s" Foreground="{StaticResource Brush_Text_Hint}" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtNat1s" Text="0" Foreground="{StaticResource Brush_Error}" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Avg d20" Foreground="{StaticResource Brush_Text_Hint}" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtAvgD20" Text="0" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>