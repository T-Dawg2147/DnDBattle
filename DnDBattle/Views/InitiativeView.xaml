<UserControl x:Class="DnDBattle.Views.InitiativeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="4">
            <Button Content="Roll All" Command="{Binding RollAllInitiativeCommand}" Margin="0,0,6,0"/>
            <Button Content="Next Turn" Command="{Binding NextTurnCommand}"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding InitiativeOrder}" Margin="4">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding Image}" Width="28" Height="28" Margin="2"/>
                        <TextBlock Text="{Binding Name}" Foreground="White" Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding Initiative, StringFormat='  ({0})'}" Foreground="LightGray" Margin="6,0,0,0"/>
                        <TextBlock Text="{Binding InitiativeModifier, StringFormat='  [+{0}]'}" Foreground="LightGray" Margin="6,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ListBox Grid.Row="2" ItemsSource="{Binding ActionLog}" Margin="4">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="LightGray" FontFamily="Consolas" FontSize="12"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>