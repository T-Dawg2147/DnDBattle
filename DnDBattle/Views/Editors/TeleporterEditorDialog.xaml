<Window x:Class="DnDBattle.Views.Editors.TeleporterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌀 Teleporter Configuration" Height="550" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🌀 Configure Teleporter" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up portals and teleportation points" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Teleporter Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Mystical Portal" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDescription" Text="You are transported in a flash of light!" Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="60" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Destination -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📍 DESTINATION" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Destination X" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDestX" Text="10" Background="#1E1E1E" Foreground="#4FC3F7" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="," Foreground="#666" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0"/>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Destination Y" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDestY" Text="10" Background="#1E1E1E" Foreground="#4FC3F7" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="💡 Tip: Right-click on the tile map to get coordinates" Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚙️ SETTINGS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkIsVisible" Content="Teleporter is visible to players" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkIsActive" Content="Teleporter is currently active" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkRequiresConsent" Content="Ask for confirmation before teleporting" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkIsOneWay" Content="This is a one-way teleporter" Foreground="#CCC" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Background="#1E3D1E" CornerRadius="6" Padding="15" BorderBrush="#4CAF50" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📝 Notes" Foreground="#4CAF50" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#CCC" FontSize="11">
                            • Tokens will be moved instantly to the destination
                            <LineBreak/>
                            • If "requires consent" is checked, a prompt will appear
                            <LineBreak/>
                            • One-way teleporters cannot be reversed
                            <LineBreak/>
                            • Create two-way teleports by placing two teleporters
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>