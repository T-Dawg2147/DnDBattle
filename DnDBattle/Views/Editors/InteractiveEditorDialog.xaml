<Window x:Class="DnDBattle.Views.Editors.InteractiveEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Interactive Object" Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚙️ Configure Interactive Object" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up buttons, levers, chests, and other interactive elements" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Object Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Mysterious Lever" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Object Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbObjectType" SelectedIndex="0" Background="#1E1E1E" Margin="0,0,0,10">
                            <ComboBoxItem Content="⚙️ Lever"/>
                            <ComboBoxItem Content="🔘 Button"/>
                            <ComboBoxItem Content="📦 Chest"/>
                            <ComboBoxItem Content="🚪 Door"/>
                            <ComboBoxItem Content="🗿 Statue"/>
                            <ComboBoxItem Content="⛪ Altar"/>
                        </ComboBox>

                        <TextBlock Text="Examine Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtExamine" Text="You see a lever on the wall." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="60" AcceptsReturn="True" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Activation Effect" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtEffect" Text="You pull the lever. You hear a distant rumbling." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="60" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Skill Check -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎯 SKILL CHECK" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkRequiresCheck" Content="Requires skill check" Foreground="#CCC" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Required Skill" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbSkill" SelectedIndex="0" Background="#1E1E1E">
                                    <ComboBoxItem Content="Strength"/>
                                    <ComboBoxItem Content="Dexterity"/>
                                    <ComboBoxItem Content="Lockpicking"/>
                                    <ComboBoxItem Content="Arcana"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="DC" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDC" Text="15" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Options -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚡ OPTIONS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkSingleUse" Content="Single use only" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkLocked" Content="Object is locked" Foreground="#CCC" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Chest Loot -->
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📦 CHEST LOOT" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Only applies to Chest type objects" Foreground="#666" FontSize="10" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Gold Pieces" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtGold" Text="0" Background="#1E1E1E" Foreground="#FFD700" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="Items (comma separated)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtItems" Text="" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>