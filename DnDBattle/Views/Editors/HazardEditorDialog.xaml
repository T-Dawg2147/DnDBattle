<Window x:Class="DnDBattle.Views.Editors.HazardEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="☠️ Hazard Configuration" Height="680" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="☠️ Configure Hazard" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up environmental dangers and damage zones" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Hazard Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Pool of Lava" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Hazard Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbHazardType" SelectedIndex="1" Background="#1E1E1E" Margin="0,0,0,10">
                            <ComboBoxItem Content="🔥 Fire"/>
                            <ComboBoxItem Content="🌋 Lava"/>
                            <ComboBoxItem Content="🧪 Acid"/>
                            <ComboBoxItem Content="☠️ Poison Gas"/>
                            <ComboBoxItem Content="❄️ Ice"/>
                            <ComboBoxItem Content="⚡ Lightning"/>
                            <ComboBoxItem Content="🌿 Thorns"/>
                            <ComboBoxItem Content="🏜️ Quicksand"/>
                            <ComboBoxItem Content="🗡️ Spikes"/>
                            <ComboBoxItem Content="✨ Magic Zone"/>
                        </ComboBox>

                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDescription" Text="A pool of molten lava." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="50" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Damage -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="💥 DAMAGE" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Damage Dice" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDamageDice" Text="2d10" Background="#1E1E1E" Foreground="#F44336" FontWeight="Bold" FontSize="14" BorderBrush="#444" Padding="10,8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Damage Type" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbDamageType" SelectedIndex="3" Background="#1E1E1E">
                                    <ComboBoxItem Content="🔨 Bludgeoning"/>
                                    <ComboBoxItem Content="🗡️ Piercing"/>
                                    <ComboBoxItem Content="⚔️ Slashing"/>
                                    <ComboBoxItem Content="🔥 Fire"/>
                                    <ComboBoxItem Content="❄️ Cold"/>
                                    <ComboBoxItem Content="⚡ Lightning"/>
                                    <ComboBoxItem Content="💥 Thunder"/>
                                    <ComboBoxItem Content="🧪 Acid"/>
                                    <ComboBoxItem Content="☠️ Poison"/>
                                    <ComboBoxItem Content="💀 Necrotic"/>
                                    <ComboBoxItem Content="✨ Radiant"/>
                                    <ComboBoxItem Content="💫 Force"/>
                                    <ComboBoxItem Content="🧠 Psychic"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Damage Trigger" Style="{StaticResource FieldLabel}" Margin="0,10,0,5"/>
                        <ComboBox x:Name="CmbDamageTrigger" SelectedIndex="0" Background="#1E1E1E">
                            <ComboBoxItem Content="On Enter (when stepping in)"/>
                            <ComboBoxItem Content="Start of Turn (if inside)"/>
                            <ComboBoxItem Content="End of Turn (if inside)"/>
                            <ComboBoxItem Content="Always (enter + every turn)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Saving Throw -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🛡️ SAVING THROW" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkAllowsSave" Content="Allow saving throw" IsChecked="True" Foreground="#CCC" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Save Ability" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbSaveAbility" SelectedIndex="1" Background="#1E1E1E">
                                    <ComboBoxItem Content="STR"/>
                                    <ComboBoxItem Content="DEX"/>
                                    <ComboBoxItem Content="CON"/>
                                    <ComboBoxItem Content="INT"/>
                                    <ComboBoxItem Content="WIS"/>
                                    <ComboBoxItem Content="CHA"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Save DC" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSaveDC" Text="13" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="ChkSaveNegates" Content="Successful save negates all damage" Foreground="#CCC" Margin="0,10,0,5"/>
                        <CheckBox x:Name="ChkSaveHalves" Content="Successful save halves damage" IsChecked="True" Foreground="#CCC"/>
                    </StackPanel>
                </Border>

                <!-- Ongoing Effects -->
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="♻️ ONGOING EFFECTS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkDamagesEachTurn" Content="Damages at start of each turn while inside" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Per-Turn Damage (if ongoing)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtPerTurnDamage" Text="1d10" Width="120" HorizontalAlignment="Left" Background="#1E1E1E" Foreground="#F44336" BorderBrush="#444" Padding="10,8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>