<Window x:Class="DnDBattle.Views.Editors.SecretEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Secret Configuration" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🔍 Configure Secret" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up hidden doors, passages, and treasure" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Secret Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Hidden Door" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Secret Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbSecretType" SelectedIndex="0" Background="#1E1E1E" Margin="0,0,0,10">
                            <ComboBoxItem Content="Hidden Door"/>
                            <ComboBoxItem Content="Secret Passage"/>
                            <ComboBoxItem Content="Hidden Treasure"/>
                            <ComboBoxItem Content="Compartment"/>
                            <ComboBoxItem Content="Illusion"/>
                            <ComboBoxItem Content="False Door"/>
                        </ComboBox>

                        <TextBlock Text="Investigation DC" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDC" Text="15" Width="80" HorizontalAlignment="Left" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Discovery -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📜 DISCOVERY" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Discovery Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDiscovery" Text="You discover a hidden passage!" Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="70" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Activation -->
                <Border Background="#252526" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="⚡ ACTIVATION" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkRequiresActivation" Content="Requires activation after discovery" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Activation Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtActivation" Text="You push on the wall and it swings open." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="70" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>