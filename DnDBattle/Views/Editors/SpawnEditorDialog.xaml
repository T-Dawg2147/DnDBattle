<Window x:Class="DnDBattle.Views.Editors.SpawnEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👹 Spawn Point Configuration" Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="👹 Configure Spawn Point" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up enemy spawn locations and triggers" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Spawn Point Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Goblin Ambush" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Creature Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtCreatureName" Text="Goblin" Background="#1E1E1E" Foreground="#F44336" FontWeight="Bold" BorderBrush="#444" Padding="10,8"/>
                        <TextBlock Text="💡 Must match a creature in your Creature Bank" Style="{StaticResource HintText}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Spawn Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="👹 SPAWN SETTINGS" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Number to Spawn" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSpawnCount" Text="3" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Spawn Radius (squares)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSpawnRadius" Text="2" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Radius 0 = spawn exactly here, 2+ = scatter within radius" Style="{StaticResource HintText}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Trigger Conditions -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚡ TRIGGER CONDITIONS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkSpawnOnLoad" Content="🗺️ Spawn when map loads" Foreground="#4CAF50" Margin="0,0,0,10"
                                  ToolTip="Token(s) will appear immediately when the map is loaded"/>

                        <TextBlock Text="Spawn Trigger" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbTrigger" SelectedIndex="0" Background="#1E1E1E" Margin="0,0,0,10">
                            <ComboBoxItem Content="Manual (DM clicks to spawn)"/>
                            <ComboBoxItem Content="Combat Start"/>
                            <ComboBoxItem Content="Specific Round Number"/>
                            <ComboBoxItem Content="Proximity (player gets close)"/>
                            <ComboBoxItem Content="Event (script-triggered)"/>
                        </ComboBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Spawn on Round" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSpawnRound" Text="3" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Trigger Distance" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtTriggerDistance" Text="5" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Delay (rounds)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtSpawnDelay" Text="0" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="ChkIsReusable" Content="♻️ Spawn point can trigger multiple times" Foreground="#CCC"/>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Background="#1E3D1E" CornerRadius="6" Padding="15" BorderBrush="#4CAF50" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📝 Notes" Foreground="#4CAF50" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#CCC" FontSize="11">
                            • Creatures must exist in your Creature Bank
                            <LineBreak/>
                            • Right-click spawn point during combat to manually trigger
                            <LineBreak/>
                            • Proximity triggers check at end of each token's movement
                            <LineBreak/>
                            • Round Number triggers activate at start of that round
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>