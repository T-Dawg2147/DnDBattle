<Window x:Class="DnDBattle.Views.Editors.HealingZoneEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="💚 Healing Zone Configuration" Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="💚 Configure Healing Zone" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Set up fountains, shrines, and healing areas" Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="BASIC INFO" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Zone Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtName" Text="Healing Fountain" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDescription" Text="A mystical fountain glows with healing energy." Background="#1E1E1E" Foreground="White" BorderBrush="#444"
                                 TextWrapping="Wrap" Height="60" AcceptsReturn="True" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Healing Settings -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="💚 HEALING" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Healing Dice" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtHealingDice" Text="2d8+2" Background="#1E1E1E" Foreground="#4CAF50" FontWeight="Bold" FontSize="16" BorderBrush="#444" Padding="10,8" Margin="0,0,0,10"/>

                        <TextBlock Text="Healing Trigger" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbHealingTrigger" SelectedIndex="1" Background="#1E1E1E">
                            <ComboBoxItem Content="On Enter (automatic when stepping in)"/>
                            <ComboBoxItem Content="On Activation (requires interaction)"/>
                            <ComboBoxItem Content="Start of Turn (if inside)"/>
                            <ComboBoxItem Content="End of Turn (if inside)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Usage Limits -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="♻️ USAGE LIMITS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkOncePerCreature" Content="Each creature can only use this once" IsChecked="True" Foreground="#CCC" Margin="0,5"/>
                        <CheckBox x:Name="ChkHasCharges" Content="Limited number of charges" Foreground="#CCC" Margin="0,5"/>

                        <TextBlock Text="Charges Remaining" Style="{StaticResource FieldLabel}" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtCharges" Text="3" Width="80" HorizontalAlignment="Left" Background="#1E1E1E" Foreground="#FF9800" FontWeight="Bold" BorderBrush="#444" Padding="10,8" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Additional Effects -->
                <Border Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="✨ ADDITIONAL EFFECTS" Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkRemovesConditions" Content="Also removes conditions" Foreground="#CCC" Margin="0,5,0,10"/>

                        <TextBlock Text="Conditions Removed" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtConditionsRemoved" Text="Poisoned, Diseased" Background="#1E1E1E" Foreground="White" BorderBrush="#444" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Background="#1E3D1E" CornerRadius="6" Padding="15" BorderBrush="#4CAF50" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📝 Healing Dice Examples" Foreground="#4CAF50" FontWeight="Bold" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#CCC" FontSize="11">
                            • "2d8+2" heals 4-18 HP
                            <LineBreak/>
                            • "1d4" heals 1-4 HP (minor shrine)
                            <LineBreak/>
                            • "5d10+20" heals 25-70 HP (major temple)
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="❌ Cancel" Padding="20,10" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="💾 Save" Padding="20,10" Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>