<Window x:Class="DnDBattle.Views.Editors.HealingZoneEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Healing Zone Configuration" Height="550" Width="500">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="💚 Configure Healing Zone" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <!-- Basic Info -->
                <TextBlock Text="Zone Name:"/>
                <TextBox x:Name="TxtName" Text="Healing Fountain"/>

                <TextBlock Text="Description:"/>
                <TextBox x:Name="TxtDescription" Text="A mystical fountain glows with healing energy." 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <Separator/>

                <!-- Healing -->
                <TextBlock Text="💚 Healing" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Healing Dice:"/>
                <TextBox x:Name="TxtHealingDice" Text="2d8+2"/>

                <TextBlock Text="Healing Trigger:"/>
                <ComboBox x:Name="CmbHealingTrigger" SelectedIndex="1">
                    <ComboBoxItem Content="On Enter (automatic when stepping in)"/>
                    <ComboBoxItem Content="On Activation (requires interaction)"/>
                    <ComboBoxItem Content="Start of Turn (if inside)"/>
                    <ComboBoxItem Content="End of Turn (if inside)"/>
                </ComboBox>

                <Separator/>

                <!-- Usage Limits -->
                <TextBlock Text="♻️ Usage Limits" Style="{StaticResource SectionHeader}"/>

                <CheckBox x:Name="ChkOncePerCreature" Content="Each creature can only use this once" IsChecked="True"/>
                <CheckBox x:Name="ChkHasCharges" Content="Limited number of charges"/>

                <TextBlock Text="Charges Remaining:"/>
                <TextBox x:Name="TxtCharges" Text="3"/>

                <Separator/>

                <!-- Additional Effects -->
                <TextBlock Text="✨ Additional Effects" Style="{StaticResource SectionHeader}"/>

                <CheckBox x:Name="ChkRemovesConditions" Content="Also removes conditions"/>

                <TextBlock Text="Conditions Removed:"/>
                <TextBox x:Name="TxtConditionsRemoved" Text="Poisoned, Diseased" />

                <Separator/>

                <!-- Visual Aid -->
                <Border Background="{StaticResource Brush_Background_Control}" 
                        BorderBrush="{StaticResource Brush_Border_Normal}"
                        BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="📝 Examples:" FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource HintText}">
                            • "2d8+2" heals 2-18 HP
                            <LineBreak/>
                            • "1d4" heals 1-4 HP (minor shrine)
                            <LineBreak/>
                            • "5d10+20" heals 25-70 HP (major temple)
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Save" Width="100" Height="35" Margin="5" 
                    Click="Save_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>