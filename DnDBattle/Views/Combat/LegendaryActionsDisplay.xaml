<UserControl x:Class="DnDBattle.Views.Combat.LegendaryActionsDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border x:Name="MainBorder" 
            Background="#252526" 
            CornerRadius="4" 
            Padding="10"
            Visibility="Collapsed">
        <StackPanel>
            <TextBlock Text="⭐ Legendary Actions" 
                       Foreground="#FFD700" 
                       FontWeight="Bold" 
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <!-- Action Points -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <StackPanel x:Name="ActionPointsContainer" Orientation="Horizontal"/>
            </StackPanel>

            <!-- Display -->
            <TextBlock x:Name="TxtRemaining" 
                       HorizontalAlignment="Center"
                       Foreground="#888"
                       FontSize="10"/>

            <!-- Reset Button -->
            <Button x:Name="BtnReset"
                    Content="🔄 Reset"
                    Padding="8,4"
                    Margin="0,8,0,0"
                    Click="BtnReset_Click"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    Cursor="Hand"
                    ToolTip="Reset legendary actions (happens at start of creature's turn)"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>