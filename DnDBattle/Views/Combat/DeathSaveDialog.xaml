<Window x:Class="DnDBattle.Views.Combat.DeathSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Death Saving Throw"
        Width="380" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="💀 Death Saving Throw" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#F44336"/>
            <TextBlock x:Name="TxtCreatureName" 
                       Foreground="White" 
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Current Death Saves Status -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Current Status" Foreground="#888" FontSize="11" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Successes -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Successes" Foreground="#4CAF50" FontSize="11" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Ellipse x:Name="Success1" Width="20" Height="20" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                            <Ellipse x:Name="Success2" Width="20" Height="20" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                            <Ellipse x:Name="Success3" Width="20" Height="20" Stroke="#4CAF50" StrokeThickness="2" Margin="2"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Failures -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Failures" Foreground="#F44336" FontSize="11" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Ellipse x:Name="Failure1" Width="20" Height="20" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                            <Ellipse x:Name="Failure2" Width="20" Height="20" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                            <Ellipse x:Name="Failure3" Width="20" Height="20" Stroke="#F44336" StrokeThickness="2" Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <TextBlock Text="DC 10" 
                           Foreground="#666" 
                           FontSize="10" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Roll Input -->
        <Border Grid.Row="2" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <!-- Manual Roll -->
                <StackPanel x:Name="ManualRollPanel">
                    <TextBlock Text="Enter your d20 roll:" Foreground="#888" FontSize="11"/>
                    <TextBox x:Name="TxtRoll" 
                             Width="80" 
                             FontSize="24"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderBrush="#444"
                             Padding="8,5"
                             TextAlignment="Center"
                             HorizontalAlignment="Left"
                             Margin="0,8,0,0"/>
                    <TextBlock x:Name="TxtRollHint" 
                               Foreground="#666" 
                               FontSize="10"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Auto Roll -->
                <StackPanel x:Name="AutoRollPanel" Visibility="Collapsed">
                    <TextBlock Text="Roll Result:" Foreground="#888" FontSize="11"/>
                    <TextBlock x:Name="TxtAutoRoll" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,8,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Result Preview -->
        <Border x:Name="ResultPreview" Grid.Row="3" CornerRadius="8" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock x:Name="TxtResultPreview" 
                       FontSize="14" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" 
                    Padding="15,10" 
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Content="Confirm (Enter)" 
                    Padding="20,10"
                    Click="BtnConfirm_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>