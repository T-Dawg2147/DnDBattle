<Window x:Class="DnDBattle.Views.Combat.ConcentrationCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Concentration Check"
        Width="380" Height="340"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🎯 Concentration Check!" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#FF9800"/>
            <TextBlock x:Name="TxtCreatureName" 
                       Foreground="#888" 
                       FontSize="12"
                       Margin="0,5,0,0"/>
            <TextBlock x:Name="TxtSpellName" 
                       Foreground="#4FC3F7" 
                       FontSize="12"
                       FontStyle="Italic"/>
        </StackPanel>

        <!-- DC Info -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Constitution Saving Throw" Foreground="#888" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Modifier: " Foreground="#888"/>
                        <TextBlock x:Name="TxtConMod" Foreground="#4CAF50" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="Damage Taken: " Foreground="#888"/>
                        <TextBlock x:Name="TxtDamageTaken" Foreground="#F44336" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="DC" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtDC" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Foreground="#FF9800"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Roll Input -->
        <Border Grid.Row="2" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <!-- Manual Roll -->
                <StackPanel x:Name="ManualRollPanel">
                    <TextBlock Text="Enter your d20 roll:" Foreground="#888" FontSize="11"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtRoll" 
                                 Width="70" 
                                 FontSize="20"
                                 Background="#1E1E1E"
                                 Foreground="White"
                                 BorderBrush="#444"
                                 Padding="8,5"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Column="1" 
                                   x:Name="TxtModifierDisplay"
                                   FontSize="20" 
                                   Foreground="#888" 
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                        <TextBlock Grid.Column="2" 
                                   Text=" = " 
                                   FontSize="20" 
                                   Foreground="#888" 
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3" 
                                   x:Name="TxtTotal"
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="White" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Auto Roll -->
                <StackPanel x:Name="AutoRollPanel" Visibility="Collapsed">
                    <TextBlock Text="Roll Result:" Foreground="#888" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="TxtAutoRoll" FontSize="24" Foreground="#4CAF50" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtAutoModifier" FontSize="16" Foreground="#888" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                        <TextBlock Text=" = " FontSize="16" Foreground="#888" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtAutoTotal" FontSize="24" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Result Preview -->
        <Border x:Name="ResultPreview" Grid.Row="3" CornerRadius="8" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock x:Name="TxtResultPreview" 
                       FontSize="14" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Auto-Fail" 
                    Padding="15,10" 
                    Margin="0,0,10,0"
                    Click="BtnAutoFail_Click"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    ToolTip="Automatically fail the save (e.g., incapacitated)"/>
            <Button Content="Confirm (Enter)" 
                    Padding="20,10"
                    Click="BtnConfirm_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>