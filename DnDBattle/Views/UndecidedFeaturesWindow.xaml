<Window x:Class="DnDBattle.Views.UndecidedFeaturesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧪 Experimental / Undecided Features"
        Width="680" Height="1100"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E" Foreground="White"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FFFF8844"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Width" Value="160"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="🧪 Experimental / Undecided Features" FontSize="18" FontWeight="Bold" Foreground="#FFFF8844" Margin="0,0,0,4"/>
            <TextBlock Text="These features are experimental and may change or be removed. Enable them individually to test."
                       TextWrapping="Wrap" Foreground="#FF999999" Margin="0,0,0,12"/>

            <!-- UD.1 Weather & Environment -->
            <GroupBox Header="🌧️ UD.1 Weather &amp; Environment">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableWeather" Content="Enable Weather Effects"
                              Checked="ChkEnableWeather_Changed" Unchecked="ChkEnableWeather_Changed"/>
                    <CheckBox x:Name="ChkEnableDayNight" Content="Enable Day/Night Cycle"
                              Checked="ChkEnableDayNight_Changed" Unchecked="ChkEnableDayNight_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max Particles:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMaxParticles" Minimum="50" Maximum="1000" Width="150"
                                Value="300" TickFrequency="50" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMaxParticles_ValueChanged"/>
                        <TextBlock x:Name="TxtMaxParticles" Text="300" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Weather Type:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbWeatherType" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="None" IsSelected="True"/>
                            <ComboBoxItem Content="Rain"/>
                            <ComboBoxItem Content="Snow"/>
                            <ComboBoxItem Content="Fog"/>
                            <ComboBoxItem Content="Storm"/>
                            <ComboBoxItem Content="Sandstorm"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Intensity:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderIntensity" Minimum="0" Maximum="1" Width="150"
                                Value="0.5" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderIntensity_ValueChanged"/>
                        <TextBlock x:Name="TxtIntensity" Text="0.5" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Time of Day:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbTimeOfDay" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Dawn"/>
                            <ComboBoxItem Content="Day" IsSelected="True"/>
                            <ComboBoxItem Content="Dusk"/>
                            <ComboBoxItem Content="Night"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Season:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbSeason" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Spring"/>
                            <ComboBoxItem Content="Summer" IsSelected="True"/>
                            <ComboBoxItem Content="Autumn"/>
                            <ComboBoxItem Content="Winter"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Wind Angle (°):" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderWindAngle" Minimum="0" Maximum="360" Width="150"
                                Value="0" TickFrequency="15" IsSnapToTickEnabled="True"
                                ValueChanged="SliderWindAngle_ValueChanged"/>
                        <TextBlock x:Name="TxtWindAngle" Text="0" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Wind Strength:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderWindStrength" Minimum="0" Maximum="1" Width="150"
                                Value="0.3" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderWindStrength_ValueChanged"/>
                        <TextBlock x:Name="TxtWindStrength" Text="0.3" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <Button Content="Apply Weather" Style="{StaticResource ActionButton}" Click="ApplyWeather_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.2 2.5D Elevation -->
            <GroupBox Header="⛰️ UD.2 2.5D Elevation System">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableElevation" Content="Enable Elevation System"
                              Checked="ChkEnableElevation_Changed" Unchecked="ChkEnableElevation_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Grid Width:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtElevGridWidth" Width="60" Text="50" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Height:" Margin="12,2,0,2" VerticalAlignment="Center" Width="50"/>
                        <TextBox x:Name="TxtElevGridHeight" Width="60" Text="50" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <Button Content="Initialize Elevation Grid" Style="{StaticResource ActionButton}" Click="InitializeElevation_Click"/>
                    <TextBlock Text="Terrain Manipulation:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="X:" VerticalAlignment="Center" Width="20"/>
                        <TextBox x:Name="TxtElevX" Width="50" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Y:" Margin="8,0,0,0" VerticalAlignment="Center" Width="20"/>
                        <TextBox x:Name="TxtElevY" Width="50" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Elev (ft):" Margin="8,0,0,0" VerticalAlignment="Center" Width="60"/>
                        <TextBox x:Name="TxtElevValue" Width="50" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="Set" Style="{StaticResource ActionButton}" Click="SetTerrainElevation_Click" Width="60"/>
                        <Button Content="Raise" Style="{StaticResource ActionButton}" Click="RaiseTerrain_Click" Margin="4,4,0,4" Width="60"/>
                        <Button Content="Lower" Style="{StaticResource ActionButton}" Click="LowerTerrain_Click" Margin="4,4,0,4" Width="60"/>
                    </StackPanel>
                    <TextBlock Text="Falling Damage Calculator:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Height (ft):" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtFallingHeight" Width="60" Text="10" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <Button Content="Calculate" Style="{StaticResource ActionButton}" Click="CalculateFallingDamage_Click" Margin="8,4,0,4"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtFallingResult" Text="" Foreground="#FFFFCC66" Margin="0,4"/>
                    <Button Content="Reset Elevation Grid" Style="{StaticResource ActionButton}" Click="ResetElevation_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.3 Animated Tiles -->
            <GroupBox Header="✨ UD.3 Animated Tiles">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableAnimatedTiles" Content="Enable Animated Tiles"
                              Checked="ChkEnableAnimatedTiles_Changed" Unchecked="ChkEnableAnimatedTiles_Changed"/>
                    <TextBlock Text="Built-in Definitions:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <ListBox x:Name="LstAnimatedTiles" Height="100"
                             Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="X:" VerticalAlignment="Center" Width="20"/>
                        <TextBox x:Name="TxtAnimX" Width="50" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Y:" Margin="8,0,0,0" VerticalAlignment="Center" Width="20"/>
                        <TextBox x:Name="TxtAnimY" Width="50" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="Place Tile" Style="{StaticResource ActionButton}" Click="PlaceAnimatedTile_Click"/>
                        <Button Content="Remove Tile" Style="{StaticResource ActionButton}" Click="RemoveAnimatedTile_Click" Margin="8,4,0,4"/>
                    </StackPanel>
                    <Button Content="Clear All Animated Tiles" Style="{StaticResource ActionButton}" Click="ClearAnimatedTiles_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.4 Procedural Map Generation -->
            <GroupBox Header="🗺️ UD.4 Procedural Map Generation">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableProceduralMaps" Content="Enable Procedural Map Generation"
                              Checked="ChkEnableProceduralMaps_Changed" Unchecked="ChkEnableProceduralMaps_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Map Type:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbMapType" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Dungeon (BSP)" IsSelected="True"/>
                            <ComboBoxItem Content="Cave (Cellular Automata)"/>
                            <ComboBoxItem Content="Arena"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Width:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMapWidth" Minimum="20" Maximum="100" Width="150"
                                Value="50" TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMapWidth_ValueChanged"/>
                        <TextBlock x:Name="TxtMapWidth" Text="50" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Height:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMapHeight" Minimum="20" Maximum="100" Width="150"
                                Value="50" TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMapHeight_ValueChanged"/>
                        <TextBlock x:Name="TxtMapHeight" Text="50" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Room Count:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderRoomCount" Minimum="1" Maximum="30" Width="150"
                                Value="15" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderRoomCount_ValueChanged"/>
                        <TextBlock x:Name="TxtRoomCount" Text="15" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Min Room Size:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMinRoom" Minimum="3" Maximum="15" Width="150"
                                Value="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMinRoom_ValueChanged"/>
                        <TextBlock x:Name="TxtMinRoom" Text="5" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Max Room Size:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderMaxRoom" Minimum="5" Maximum="25" Width="150"
                                Value="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderMaxRoom_ValueChanged"/>
                        <TextBlock x:Name="TxtMaxRoom" Text="12" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <Button Content="Generate Map" Style="{StaticResource ActionButton}" Click="GenerateMap_Click"/>
                    <TextBlock x:Name="TxtMapResult" Text="" TextWrapping="Wrap" Foreground="#FFFFCC66" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.5 Token Customization -->
            <GroupBox Header="🎨 UD.5 Token Customization">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableTokenCustomization" Content="Enable Token Customization"
                              Checked="ChkEnableTokenCustomization_Changed" Unchecked="ChkEnableTokenCustomization_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Shape:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbTokenShape" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Circle" IsSelected="True"/>
                            <ComboBoxItem Content="Square"/>
                            <ComboBoxItem Content="RoundedSquare"/>
                            <ComboBoxItem Content="Hexagon"/>
                            <ComboBoxItem Content="Diamond"/>
                            <ComboBoxItem Content="Star"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Border Color:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtBorderColor" Width="100" Text="#FFFFFF" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Border Thickness:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderBorderThickness" Minimum="0" Maximum="8" Width="150"
                                Value="2" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderBorderThickness_ValueChanged"/>
                        <TextBlock x:Name="TxtBorderThickness" Text="2" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Border Style:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbBorderStyle" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Solid" IsSelected="True"/>
                            <ComboBoxItem Content="Dashed"/>
                            <ComboBoxItem Content="Double"/>
                            <ComboBoxItem Content="Glow"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="ChkShowGlow" Content="Show Glow Effect"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Glow Color:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtGlowColor" Width="100" Text="#FFFFFF" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <TextBlock Text="Name Plate:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <CheckBox x:Name="ChkNamePlateVisible" Content="Always Visible"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Position:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbNamePlatePosition" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Above"/>
                            <ComboBoxItem Content="Below" IsSelected="True"/>
                            <ComboBoxItem Content="Inside"/>
                            <ComboBoxItem Content="Left"/>
                            <ComboBoxItem Content="Right"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Font Size:" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderNamePlateFontSize" Minimum="6" Maximum="24" Width="150"
                                Value="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderNamePlateFontSize_ValueChanged"/>
                        <TextBlock x:Name="TxtNamePlateFontSize" Text="10" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <Button Content="Apply to Selected Token" Style="{StaticResource ActionButton}" Click="ApplyTokenCustomization_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.6 Persistent Measurements -->
            <GroupBox Header="📏 UD.6 Persistent Measurements">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableMeasurements" Content="Enable Measurements"
                              Checked="ChkEnableMeasurements_Changed" Unchecked="ChkEnableMeasurements_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Type:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbMeasurementType" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Distance" IsSelected="True"/>
                            <ComboBoxItem Content="Radius"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Label:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtMeasurementLabel" Width="200" Text="Measurement" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="X1:" VerticalAlignment="Center" Width="25"/>
                        <TextBox x:Name="TxtMeasX1" Width="40" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Y1:" Margin="8,0,0,0" VerticalAlignment="Center" Width="25"/>
                        <TextBox x:Name="TxtMeasY1" Width="40" Text="0" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="X2:" Margin="8,0,0,0" VerticalAlignment="Center" Width="25"/>
                        <TextBox x:Name="TxtMeasX2" Width="40" Text="5" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                        <TextBlock Text="Y2:" Margin="8,0,0,0" VerticalAlignment="Center" Width="25"/>
                        <TextBox x:Name="TxtMeasY2" Width="40" Text="5" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Color:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbMeasurementColor" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="Blue (#4FC3F7)" IsSelected="True"/>
                            <ComboBoxItem Content="Orange (#FF9800)"/>
                            <ComboBoxItem Content="Red (#F44336)"/>
                            <ComboBoxItem Content="Green (#4CAF50)"/>
                            <ComboBoxItem Content="Purple (#9C27B0)"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="Add Measurement" Style="{StaticResource ActionButton}" Click="AddMeasurement_Click"/>
                    <TextBlock Text="Active Measurements:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <ListBox x:Name="LstMeasurements" Height="100"
                             Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="Remove Selected" Style="{StaticResource ActionButton}" Click="RemoveMeasurement_Click"/>
                        <Button Content="Toggle Visibility" Style="{StaticResource ActionButton}" Click="ToggleMeasurement_Click" Margin="8,4,0,4"/>
                        <Button Content="Clear All" Style="{StaticResource ActionButton}" Click="ClearMeasurements_Click" Margin="8,4,0,4"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- UD.8 3D Dice Roller -->
            <GroupBox Header="🎲 UD.8 3D Dice Roller &amp; Statistics">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableDice3D" Content="Enable 3D Dice Roller"
                              Checked="ChkEnableDice3D_Changed" Unchecked="ChkEnableDice3D_Changed"/>
                    <CheckBox x:Name="ChkEnableDiceStats" Content="Enable Dice Statistics"
                              Checked="ChkEnableDiceStats_Changed" Unchecked="ChkEnableDiceStats_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Dice Type:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbDiceType" Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Content="D4"/>
                            <ComboBoxItem Content="D6"/>
                            <ComboBoxItem Content="D8"/>
                            <ComboBoxItem Content="D10"/>
                            <ComboBoxItem Content="D12"/>
                            <ComboBoxItem Content="D20" IsSelected="True"/>
                            <ComboBoxItem Content="D100"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Count:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDiceCount" Width="50" Text="1" Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF444466"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Button Content="Roll!" Style="{StaticResource ActionButton}" Click="RollDice_Click" Width="80"/>
                        <Button Content="Skip Animation" Style="{StaticResource ActionButton}" Click="SkipDiceAnimation_Click" Margin="8,4,0,4"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDiceResult" Text="No roll yet." FontSize="14" FontWeight="Bold" Foreground="#FFFFCC66" Margin="0,4"/>
                    <TextBlock Text="Statistics:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <TextBlock x:Name="TxtDiceAverage" Text="Average: —" Foreground="#FFCCCCDD"/>
                    <TextBlock x:Name="TxtDiceLuckScore" Text="Luck Score: —" Foreground="#FFCCCCDD"/>
                    <TextBlock x:Name="TxtDiceCrits" Text="Crits: 0 hits, 0 fails" Foreground="#FFCCCCDD"/>
                    <TextBlock x:Name="TxtDiceTotalRolls" Text="Total Rolls: 0" Foreground="#FFCCCCDD"/>
                </StackPanel>
            </GroupBox>

            <!-- UD.9 Accessibility -->
            <GroupBox Header="♿ UD.9 Accessibility Suite">
                <StackPanel>
                    <CheckBox x:Name="ChkHighContrast" Content="Enable High Contrast Mode"
                              Checked="ChkHighContrast_Changed" Unchecked="ChkHighContrast_Changed"/>
                    <CheckBox x:Name="ChkColorblindMode" Content="Enable Colorblind Mode"
                              Checked="ChkColorblindMode_Changed" Unchecked="ChkColorblindMode_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Colorblind Mode:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbColorblindMode" Style="{StaticResource FieldCombo}"
                                  SelectionChanged="CmbColorblindMode_SelectionChanged">
                            <ComboBoxItem Content="None" IsSelected="True"/>
                            <ComboBoxItem Content="Protanopia"/>
                            <ComboBoxItem Content="Deuteranopia"/>
                            <ComboBoxItem Content="Tritanopia"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="ChkDyslexiaFont" Content="Enable Dyslexia-Friendly Font"
                              Checked="ChkDyslexiaFont_Changed" Unchecked="ChkDyslexiaFont_Changed"/>
                    <CheckBox x:Name="ChkKeyboardNav" Content="Enable Keyboard Navigation"
                              Checked="ChkKeyboardNav_Changed" Unchecked="ChkKeyboardNav_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="UI Scale (%):" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="SliderUIScale" Minimum="50" Maximum="300" Width="150"
                                Value="100" TickFrequency="25" IsSnapToTickEnabled="True"
                                ValueChanged="SliderUIScale_ValueChanged"/>
                        <TextBlock x:Name="TxtUIScale" Text="100%" Margin="8,0,0,0" Foreground="#FFFFCC66"/>
                    </StackPanel>
                    <TextBlock Text="Preview:" FontWeight="Bold" Margin="0,8,0,4"/>
                    <TextBlock x:Name="TxtAccessibilityFontFamily" Text="Font: Segoe UI" Foreground="#FFCCCCDD"/>
                    <TextBlock x:Name="TxtAccessibilityFontSize" Text="Scaled Font Size (base 14): 14.0" Foreground="#FFCCCCDD"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
