<Window x:Class="DnDBattle.Views.VoiceChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎤 Voice Chat (Discord)" Height="380" Width="480"
        Background="#1A1A1D" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="#252526" CornerRadius="8" Padding="12" Margin="12">
        <StackPanel>
            <TextBlock Text="Discord Voice Chat" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

            <TextBlock Text="Discord Invite Link:" Foreground="#CCC" Margin="0,0,0,4"/>
            <TextBox x:Name="InviteLinkBox" Background="#333" Foreground="White" BorderBrush="#555" Padding="4" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Set Link" Click="SetLink_Click"
                        Background="#0E639C" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="Open Discord" Click="OpenDiscord_Click"
                        Background="#0E639C" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="Copy Invite Message" Click="CopyInvite_Click"
                        Background="#555" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <TextBlock Text="Session Name (for invite message):" Foreground="#CCC" Margin="0,0,0,4"/>
            <TextBox x:Name="SessionNameBox" Background="#333" Foreground="White" BorderBrush="#555" Padding="4" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " Foreground="#CCC"/>
                <TextBlock x:Name="StatusText" Text="Not configured" Foreground="#007ACC"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
