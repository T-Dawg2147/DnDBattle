<Window x:Class="DnDBattle.Views.ConcentrationCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Concentration Check"
        Width="380" Height="340"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🎯 Concentration Check!" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource Brush_Warning}"/>
            <TextBlock x:Name="TxtCreatureName" 
                       Foreground="{StaticResource Brush_Text_Hint}" 
                       FontSize="12"
                       Margin="0,5,0,0"/>
            <TextBlock x:Name="TxtSpellName" 
                       Foreground="{StaticResource Brush_Info}" 
                       FontSize="12"
                       FontStyle="Italic"/>
        </StackPanel>

        <!-- DC Info -->
        <Border Grid.Row="1" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Constitution Saving Throw" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Modifier: " Foreground="{StaticResource Brush_Text_Hint}"/>
                        <TextBlock x:Name="TxtConMod" Foreground="{StaticResource Brush_Success}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="Damage Taken: " Foreground="{StaticResource Brush_Text_Hint}"/>
                        <TextBlock x:Name="TxtDamageTaken" Foreground="{StaticResource Brush_Error}" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="DC" Foreground="{StaticResource Brush_Text_Hint}" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtDC" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource Brush_Warning}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Roll Input -->
        <Border Grid.Row="2" Background="{StaticResource Brush_Background_Control}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <!-- Manual Roll -->
                <StackPanel x:Name="ManualRollPanel">
                    <TextBlock Text="Enter your d20 roll:" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtRoll" 
                                 Width="70" 
                                 FontSize="20"
                                 Padding="8,5"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Column="1" 
                                   x:Name="TxtModifierDisplay"
                                   FontSize="20" 
                                   Foreground="{StaticResource Brush_Text_Hint}" 
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                        <TextBlock Grid.Column="2" 
                                   Text=" = " 
                                   FontSize="20" 
                                   Foreground="{StaticResource Brush_Text_Hint}" 
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3" 
                                   x:Name="TxtTotal"
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush_Text_Primary}" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Auto Roll -->
                <StackPanel x:Name="AutoRollPanel" Visibility="Collapsed">
                    <TextBlock Text="Roll Result:" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="TxtAutoRoll" FontSize="24" Foreground="{StaticResource Brush_Success}" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtAutoModifier" FontSize="16" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                        <TextBlock Text=" = " FontSize="16" Foreground="{StaticResource Brush_Text_Hint}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtAutoTotal" FontSize="24" Foreground="{StaticResource Brush_Text_Primary}" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Result Preview -->
        <Border x:Name="ResultPreview" Grid.Row="3" CornerRadius="8" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock x:Name="TxtResultPreview" 
                       FontSize="14" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Auto-Fail" 
                    Padding="15,10" 
                    Margin="0,0,10,0"
                    Click="BtnAutoFail_Click"
                    Style="{StaticResource ErrorButton}"
                    ToolTip="Automatically fail the save (e.g., incapacitated)"/>
            <Button Content="Confirm (Enter)" 
                    Padding="20,10"
                    Click="BtnConfirm_Click"
                    Style="{StaticResource SuccessButton}"
                    FontWeight="Bold"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>