<UserControl x:Class="DnDBattle.Views.CombatStatisticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="📊 Combat Statistics" Foreground="#4FC3F7" FontWeight="Bold" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Round: " Foreground="#888" FontSize="11"/>
                        <TextBlock x:Name="TxtRound" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text=" • Duration: " Foreground="#888" FontSize="11"/>
                        <TextBlock x:Name="TxtDuration" Text="0:00" Foreground="White" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="🔄" 
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnRefresh_Click"
                        ToolTip="Refresh Statistics"/>
            </Grid>
        </Border>

        <!-- Stats List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StatsContainer" Margin="10"/>
        </ScrollViewer>

        <!-- Summary -->
        <Border Grid.Row="2" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Damage" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalDamage" Text="0" Style="{StaticResource StatValue}" Foreground="#F44336" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Healing" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalHealing" Text="0" Style="{StaticResource StatValue}" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Kills" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalKills" Text="0" Style="{StaticResource StatValue}" Foreground="#FF9800" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Crits" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalCrits" Text="0" Style="{StaticResource StatValue}" Foreground="#FFD700" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>