<Window x:Class="DnDBattle.Views.Effects.Phase4LightingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="💡 Phase 4: Lighting &amp; Vision System"
        Width="560" Height="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush_Background_Medium}" Foreground="{StaticResource Brush_Text_Primary}"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FF88AAFF"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#FF444466"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <TextBlock Text="💡 Phase 4: Lighting &amp; Vision System" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush_Info}" Margin="0,0,0,12"/>
            <TextBlock Text="Manage light sources, shadows, vision ranges, and fog reveal." Foreground="{StaticResource Brush_Text_Hint}" Margin="0,0,0,8"/>

            <!-- 4.1 Basic Light Sources -->
            <GroupBox Header="💡 4.1 Basic Light Sources">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableLighting" Content="Enable Lighting System" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Bright Radius:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderBrightRadius" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtBrightRadius" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Dim Radius:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderDimRadius" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtDimRadius" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Intensity:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderIntensity" Minimum="0.1" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtIntensity" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Light Color:" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CmbLightColor" Width="180" SelectedIndex="0">
                            <ComboBoxItem Content="White (Default)"/>
                            <ComboBoxItem Content="Warm Yellow (Torch)"/>
                            <ComboBoxItem Content="Cool Blue (Moonlight)"/>
                            <ComboBoxItem Content="Orange-Red (Fire)"/>
                            <ComboBoxItem Content="Green (Magical)"/>
                            <ComboBoxItem Content="Purple (Arcane)"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Label:" VerticalAlignment="Center" Width="110"/>
                        <TextBox x:Name="TxtLightLabel" Width="180" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}" Padding="4,2" Text=""/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                        <Button Content="➕ Add Point Light" Click="AddPointLight_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                        <Button Content="🗑️ Remove Selected" Click="RemoveSelectedLight_Click" Style="{StaticResource ActionButton}"/>
                    </StackPanel>

                    <!-- Light list -->
                    <TextBlock Text="Current Lights:" Margin="0,8,0,4" FontWeight="SemiBold"/>
                    <ListBox x:Name="LightsList" Height="100" Background="{StaticResource Brush_Background_Dark}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Normal}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Label}" Width="160" Foreground="{StaticResource Brush_Text_Primary}"/>
                                    <TextBlock Text="{Binding Type}" Width="80" Foreground="{StaticResource Brush_Info}"/>
                                    <TextBlock Text="{Binding Brightness}" Foreground="{StaticResource Brush_Text_Hint}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </GroupBox>

            <!-- 4.2 Shadow Casting -->
            <GroupBox Header="🌑 4.2 Shadow Casting">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableShadowCasting" Content="Enable Shadow Casting" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Ray Count:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderRayCount" Minimum="36" Maximum="720" TickFrequency="36" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtRayCount" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Shadow Softness:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderShadowSoftness" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtShadowSoftness" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <Button Content="🔄 Clear Shadow Cache" Click="ClearShadowCache_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <!-- 4.3 Token Vision Ranges -->
            <GroupBox Header="👁️ 4.3 Token Vision Ranges">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableTokenVision" Content="Enable Token Vision System" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Default Range:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderVisionRange" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtVisionRange" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <TextBlock Text="💡 Vision types (Darkvision, Blindsight, Truesight) are auto-parsed from token Senses field." Foreground="{StaticResource Brush_Text_Hint}" TextWrapping="Wrap" FontSize="11" Margin="0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 4.4 Vision Mode Rendering -->
            <GroupBox Header="🎨 4.4 Vision Mode Rendering">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableVisionRendering" Content="Enable Vision Mode Rendering (darkvision grayscale)" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <Button Content="👁️ Toggle Vision Overlay" Click="ToggleVisionOverlay_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <!-- 4.5 Automatic Fog Reveal -->
            <GroupBox Header="🌫️ 4.5 Automatic Fog Reveal">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableAutoFogReveal" Content="Enable Auto Fog Reveal from Token Vision" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Fog Mode:" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CmbFogRevealMode" Width="180" SelectionChanged="OnFogModeChanged">
                            <ComboBoxItem Content="Exploration (permanent)"/>
                            <ComboBoxItem Content="Dynamic (current only)"/>
                            <ComboBoxItem Content="Hybrid (dim memory)"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="🔄 Update Fog from Vision Now" Click="UpdateFogFromVision_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <!-- 4.6 Directional Lights -->
            <GroupBox Header="🔦 4.6 Directional Lights">
                <StackPanel>
                    <CheckBox x:Name="ChkEnableDirectionalLights" Content="Enable Directional / Cone Lights" Checked="OnFeatureToggled" Unchecked="OnFeatureToggled"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Direction:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderConeDirection" Minimum="0" Maximum="360" TickFrequency="15" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtConeDirection" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cone Width:" VerticalAlignment="Center" Width="110"/>
                        <Slider x:Name="SliderConeWidth" Minimum="10" Maximum="180" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                        <TextBlock x:Name="TxtConeWidth" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>
                    <Button Content="🔦 Add Directional Light" Click="AddDirectionalLight_Click" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
