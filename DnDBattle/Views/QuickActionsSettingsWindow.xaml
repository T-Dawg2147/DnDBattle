<Window x:Class="DnDBattle.Views.QuickActionsSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Quick Actions" 
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ListItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Configure Quick Actions" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="White"/>
            <TextBlock Text="Select which quick actions appear in the token panel. Drag to reorder." 
                       FontSize="11" 
                       Foreground="#888"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Search Box -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="TxtSearch" 
                     Grid.Row="0"
                     Background="#252526"
                     Foreground="White"
                     BorderBrush="#444"
                     Padding="8,6"
                     Margin="0,0,0,10"
                     TextChanged="TxtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍 Search actions..." Foreground="#666" Margin="5,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Actions List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ActionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ListItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Drag Handle -->
                                    <TextBlock Grid.Column="0" 
                                               Text="⋮⋮" 
                                               Foreground="#666" 
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Cursor="SizeAll"/>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="1" 
                                              IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Click="CheckBox_Click"/>

                                    <!-- Icon and Name -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" 
                                                       FontSize="14" 
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       Foreground="White" 
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="#888" 
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="22,2,0,0"/>
                                    </StackPanel>

                                    <!-- Move Buttons -->
                                    <StackPanel Grid.Column="3" 
                                                Orientation="Horizontal" 
                                                VerticalAlignment="Center">
                                        <Button Content="▲" 
                                                Width="24" Height="24"
                                                FontSize="10"
                                                Background="#3E3E42"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Margin="0,0,2,0"
                                                Click="BtnMoveUp_Click"
                                                Tag="{Binding Id}"/>
                                        <Button Content="▼" 
                                                Width="24" Height="24"
                                                FontSize="10"
                                                Background="#3E3E42"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Click="BtnMoveDown_Click"
                                                Tag="{Binding Id}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Quick Select Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Select All" 
                    Padding="10,5" 
                    Margin="0,0,5,0"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnSelectAll_Click"/>
            <Button Content="Select None" 
                    Padding="10,5" 
                    Margin="0,0,5,0"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnSelectNone_Click"/>
            <Button Content="Reset Defaults" 
                    Padding="10,5"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnResetDefaults_Click"/>
        </StackPanel>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Cancel" 
                    Width="80" 
                    Padding="0,8"
                    Background="#3E3E42"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Save" 
                    Width="80" 
                    Padding="0,8"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>