<Window x:Class="DnDBattle.Views.DatabaseImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📥 Import Creatures to Database"
        Width="550" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="📥 Import Creature Files" 
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Import JSON creature files into your local database" 
                       Foreground="#888" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Folder Selection -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📁 SELECT JSON FOLDER" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtFolderPath" Grid.Column="0" IsReadOnly="True"
                             Background="#1E1E1E" Foreground="#CCC" BorderBrush="#444"
                             Padding="10,8" VerticalContentAlignment="Center"/>
                    <Button x:Name="BtnBrowse" Grid.Column="1" Content="Browse..."
                            Padding="15,8" Margin="10,0,0,0" Click="BtnBrowse_Click"
                            Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Progress Log -->
        <Border Grid.Row="2" Background="#252526" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 IMPORT LOG" Foreground="#4FC3F7" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
                <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="TxtLog" IsReadOnly="True"
                                 Background="Transparent" Foreground="#CCC"
                                 TextWrapping="Wrap" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="10"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <Border Grid.Row="3" Background="#252526" CornerRadius="4" Padding="10" Margin="0,15,0,15">
            <StackPanel>
                <ProgressBar x:Name="ProgressBar" Height="8"
                             Minimum="0" Maximum="100" Value="0"
                             Background="#1E1E1E" Foreground="#007ACC"/>
                <TextBlock x:Name="TxtStatus" Text="Select a folder to begin import" 
                           Foreground="#888" FontSize="11" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnClear" Content="🗑️ Clear Database" 
                    Padding="15,10" Margin="0,0,10,0" Click="BtnClear_Click"
                    Background="#C42B1C" Foreground="White" BorderThickness="0"
                    ToolTip="Delete all creatures from the database"/>
            <Button x:Name="BtnImport" Content="📥 Import All" 
                    Padding="15,10" Margin="0,0,10,0" Click="BtnImport_Click" IsEnabled="False"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            <Button x:Name="BtnClose" Content="Close" 
                    Padding="15,10" Click="BtnClose_Click"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
