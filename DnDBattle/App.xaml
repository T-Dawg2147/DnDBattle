<Application x:Class="DnDBattle.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DnDBattle.Views.TileMap"
             xmlns:converter="clr-namespace:DnDBattle.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ==================== COLOR PALETTE ==================== -->

        <!-- Background Colors -->
        <Color x:Key="Color_Background_Darkest">#FF0D0D0D</Color>
        <Color x:Key="Color_Background_Dark">#FF1A1A1A</Color>
        <Color x:Key="Color_Background_Medium">#FF1E1E1E</Color>
        <Color x:Key="Color_Background_Control">#FF2D2D30</Color>
        <Color x:Key="Color_Background_Hover">#FF3E3E42</Color>

        <!-- Border Colors -->
        <Color x:Key="Color_Border_Normal">#FF3E3E42</Color>
        <Color x:Key="Color_Border_Hover">#FF555555</Color>
        <Color x:Key="Color_Border_Focus">#FF007ACC</Color>

        <!-- Text Colors -->
        <Color x:Key="Color_Text_Primary">#FFFFFFFF</Color>
        <Color x:Key="Color_Text_Secondary">#FFCCCCCC</Color>
        <Color x:Key="Color_Text_Disabled">#FF808080</Color>
        <Color x:Key="Color_Text_Hint">#FFAAAAAA</Color>

        <!-- Accent Colors -->
        <Color x:Key="Color_Accent_Primary">#FF007ACC</Color>
        <Color x:Key="Color_Accent_Hover">#FF1C97EA</Color>
        <Color x:Key="Color_Accent_Pressed">#FF005A9E</Color>

        <!-- Status Colors -->
        <Color x:Key="Color_Success">#FF4CAF50</Color>
        <Color x:Key="Color_Warning">#FFFFAB40</Color>
        <Color x:Key="Color_Error">#FFF44336</Color>
        <Color x:Key="Color_Info">#FF2196F3</Color>

        <!-- ==================== BRUSHES ==================== -->

        <SolidColorBrush x:Key="Brush_Background_Darkest" Color="{StaticResource Color_Background_Darkest}"/>
        <SolidColorBrush x:Key="Brush_Background_Dark" Color="{StaticResource Color_Background_Dark}"/>
        <SolidColorBrush x:Key="Brush_Background_Medium" Color="{StaticResource Color_Background_Medium}"/>
        <SolidColorBrush x:Key="Brush_Background_Control" Color="{StaticResource Color_Background_Control}"/>
        <SolidColorBrush x:Key="Brush_Background_Hover" Color="{StaticResource Color_Background_Hover}"/>

        <SolidColorBrush x:Key="Brush_Border_Normal" Color="{StaticResource Color_Border_Normal}"/>
        <SolidColorBrush x:Key="Brush_Border_Hover" Color="{StaticResource Color_Border_Hover}"/>
        <SolidColorBrush x:Key="Brush_Border_Focus" Color="{StaticResource Color_Border_Focus}"/>

        <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}"/>
        <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}"/>
        <SolidColorBrush x:Key="Brush_Text_Disabled" Color="{StaticResource Color_Text_Disabled}"/>
        <SolidColorBrush x:Key="Brush_Text_Hint" Color="{StaticResource Color_Text_Hint}"/>

        <SolidColorBrush x:Key="Brush_Accent_Primary" Color="{StaticResource Color_Accent_Primary}"/>
        <SolidColorBrush x:Key="Brush_Accent_Hover" Color="{StaticResource Color_Accent_Hover}"/>
        <SolidColorBrush x:Key="Brush_Accent_Pressed" Color="{StaticResource Color_Accent_Pressed}"/>

        <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}"/>
        <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}"/>
        <SolidColorBrush x:Key="Brush_Error" Color="{StaticResource Color_Error}"/>
        <SolidColorBrush x:Key="Brush_Info" Color="{StaticResource Color_Info}"/>

        <!-- ==================== CONVERTERS ==================== -->

        <converter:BoolToBrushConverter x:Key="BoolToBrushConverter" TrueBrush="#FF333333" FalseBrush="Transparent"/>
        <converter:AbilityModifierConverter x:Key="AbilityModConverter"/>
        <converter:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converter:HPBarWidthConverter x:Key="HPBarWidthConverter"/>
        <converter:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converter:FavoriteColorConverter x:Key="FavoriteColorConverter"/>
        <converter:StringToVisibilityConverter x:Key="StringToVisibilityConverter" xmlns:views="clr-namespace:DnDBattle.Views"/>
        <converter:TileImageConverter x:Key="TileImageConverter"/>
        <converter:MetadataIconConverter x:Key="MetadataIconConverter"/>
        <converter:MetadataTypeNameConverter x:Key="MetadataTypeNameConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ==================== GLOBAL STYLES ==================== -->

        <!-- TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource Brush_Accent_Primary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Hover}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Focus}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource Brush_Text_Disabled}"/>
                    <Setter Property="Background" Value="{StaticResource Brush_Background_Dark}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Border_Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Accent_Pressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Brush_Text_Disabled}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_Dark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button Style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Brush_Accent_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Accent_Primary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent_Hover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent_Pressed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent_Primary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Separator -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- ScrollViewer -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Dark}"/>
        </Style>

        <!-- Window -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Medium}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- UserControl -->
        <Style TargetType="UserControl">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Medium}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ==================== SPECIALIZED STYLES ==================== -->

        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- Hint Text -->
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Hint}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- Card Border -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Normal}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Input Group -->
        <Style x:Key="InputGroup" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Toolbar Button -->
        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Icon Button -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Success}"/>
        </Style>

        <!-- Error Button -->
        <Style x:Key="ErrorButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Brush_Error}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Error}"/>
        </Style>

        <!-- Warning Text -->
        <Style x:Key="WarningText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource Brush_Warning}"/>
        </Style>

        <!-- Success Text -->
        <Style x:Key="SuccessText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource Brush_Success}"/>
        </Style>

        <!-- Error Text -->
        <Style x:Key="ErrorText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource Brush_Error}"/>
        </Style>

    </Application.Resources>
</Application>