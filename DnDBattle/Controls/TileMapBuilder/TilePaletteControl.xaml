<UserControl x:Class="DnDBattle.Controls.TileMapBuilder.TilePaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280"
             Background="#252526">

    <UserControl.Resources>
        <!-- Tile Item Template -->
        <DataTemplate x:Key="TileItemTemplate">
            <Border x:Name="TileBorder"
                    Width="56" Height="56"
                    Margin="3"
                    Background="#3E3E42"
                    BorderBrush="#4E4E52"
                    BorderThickness="2"
                    CornerRadius="4"
                    Cursor="Hand"
                    ToolTipService.InitialShowDelay="300">
                <Border.ToolTip>
                    <StackPanel MaxWidth="200">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding Category}" Foreground="#888" FontSize="11"/>
                        <TextBlock Text="{Binding FilePath}" Foreground="#666" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border.ToolTip>
                <Grid>
                    <!-- Tile Image -->
                    <Image Source="{Binding CachedImage}" 
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Margin="4"/>

                    <!-- Size indicator for multi-square tiles -->
                    <TextBlock Text="{Binding WidthInSquares, StringFormat={}{0}x}"
                               Visibility="{Binding WidthInSquares, Converter={StaticResource GreaterThanOneToVisibility}}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD700"
                               FontSize="9"
                               FontWeight="Bold"
                               Margin="0,0,2,1"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="TileBorder" Property="BorderBrush" Value="#4FC3F7"/>
                    <Setter TargetName="TileBorder" Property="BorderThickness" Value="3"/>
                    <Setter TargetName="TileBorder" Property="Background" Value="#2D4A5E"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TileBorder" Property="Background" Value="#4E4E52"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Visibility Converter for multi-square tiles -->
        <local:GreaterThanOneToVisibilityConverter x:Key="GreaterThanOneToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#333337" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tile Palette" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnRefresh" 
                            Content="🔄" 
                            ToolTip="Refresh tiles"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="14"
                            Cursor="Hand"
                            Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnOpenFolder" 
                            Content="📁" 
                            ToolTip="Open tiles folder"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="14"
                            Cursor="Hand"
                            Click="BtnOpenFolder_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Category Filter -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="8,6">
            <ComboBox x:Name="CmbCategory"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      Background="#3E3E42"
                      Foreground="White"
                      BorderBrush="#555"
                      Padding="8,6">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="White"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>

        <!-- Search Box -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="8,4,8,8">
            <Grid>
                <TextBox x:Name="TxtSearch"
                         Background="#3E3E42"
                         Foreground="White"
                         BorderBrush="#555"
                         Padding="8,6"
                         TextChanged="TxtSearch_TextChanged"/>
                <TextBlock Text="Search tiles..."
                           Foreground="#888"
                           Margin="10,8,0,0"
                           IsHitTestVisible="False"
                           Visibility="{Binding Text.Length, ElementName=TxtSearch, Converter={StaticResource IntToVisibilityInverse}}"/>
            </Grid>
        </Border>

        <!-- Tiles Grid -->
        <Border Grid.Row="3" Background="#1E1E1E" Margin="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <ListBox x:Name="TilesList"
                         ItemsSource="{Binding FilteredTiles}"
                         SelectedItem="{Binding SelectedTileDefinition, Mode=TwoWay}"
                         ItemTemplate="{StaticResource TileItemTemplate}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Status / Tile Count -->
        <Border Grid.Row="4" Background="#333337" Padding="8,6">
            <TextBlock x:Name="TxtTileCount"
                       Foreground="#888"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>