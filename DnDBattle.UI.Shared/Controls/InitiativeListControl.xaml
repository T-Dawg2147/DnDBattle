<UserControl x:Class="DnDBattle.UI.Shared.Controls.InitiativeListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#1A1A2E" CornerRadius="6" Padding="8">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Initiative Order"
                       Foreground="#F5F5F5" FontWeight="SemiBold" FontSize="14"
                       Margin="0,0,0,8"/>
            <ListBox x:Name="InitiativeList" Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding InitiativeOrder}"
                     SelectedItem="{Binding SelectedCombatant}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding InitiativeRoll}"
                                       Foreground="#E94560" FontWeight="Bold"
                                       VerticalAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       Foreground="#F5F5F5" VerticalAlignment="Center"
                                       Margin="4,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CurrentHitPoints, StringFormat='HP: {0}'}"
                                       Foreground="#4CAF50" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="&#9658;" Foreground="#FFD700"
                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#F5F5F5"/>
                        <Setter Property="Padding" Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0F3460"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
