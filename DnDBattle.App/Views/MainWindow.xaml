<Window x:Class="DnDBattle.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DnDBattle.App.ViewModels"
        Title="D&amp;D Battle Planner" Height="800" Width="1280"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Background="{StaticResource BackgroundDarkBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu + Status -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundMidBrush}" Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="&#9876; D&amp;D Battle Planner"
                           Foreground="{StaticResource AccentPrimaryBrush}"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Style="{StaticResource DndButtonStyle}" Content="&#9654; Start Encounter"
                            Command="{Binding StartEncounterCommand}" Margin="2,0"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="&#9197; Next Turn"
                            Command="{Binding NextTurnCommand}"
                            IsEnabled="{Binding IsEncounterActive}"
                            Margin="2,0"
                            Background="{StaticResource AccentSecondaryBrush}"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="&#9209; End Encounter"
                            Command="{Binding EndEncounterCommand}"
                            IsEnabled="{Binding IsEncounterActive}"
                            Margin="2,0"
                            Background="#555"/>
                    <Separator Width="1" Background="#444" Margin="8,0"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="+ Combatant"
                            Command="{Binding AddCombatantCommand}" Margin="2,0"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="Remove"
                            Command="{Binding RemoveCombatantCommand}"
                            Margin="2,0" Background="#A33"/>
                    <Separator Width="1" Background="#444" Margin="8,0"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="Attack"
                            Command="{Binding AttackSelectedCommand}"
                            IsEnabled="{Binding IsEncounterActive}"
                            Margin="2,0"/>
                    <Separator Width="1" Background="#444" Margin="8,0"/>
                    <Button Style="{StaticResource DndButtonStyle}" Content="Save"
                            Command="{Binding SaveEncounterCommand}" Margin="2,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Round:" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentRound}" Foreground="{StaticResource AccentPrimaryBrush}"
                               FontWeight="Bold" Margin="4,0,16,0" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- Initiative Panel -->
                <ColumnDefinition Width="*"/>
                <!-- Battle Map -->
                <ColumnDefinition Width="240"/>
                <!-- Selected Combatant Stats -->
            </Grid.ColumnDefinitions>

            <!-- Left: Initiative Order -->
            <Border Grid.Column="0" Background="{StaticResource BackgroundMidBrush}"
                    BorderBrush="#333" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="Initiative Order"
                               Foreground="{StaticResource AccentPrimaryBrush}"
                               FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding CurrentRound, StringFormat='Round: {0}'}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,8"
                               Visibility="{Binding IsEncounterActive, Converter={StaticResource BoolToVisibility}}"/>
                    <ListBox Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding InitiativeOrder}"
                             SelectedItem="{Binding SelectedCombatant}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4" Margin="0,2" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20FFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24"
                                                CornerRadius="12"
                                                Background="{StaticResource AccentPrimaryBrush}">
                                            <TextBlock Text="{Binding InitiativeRoll}"
                                                       Foreground="White" FontWeight="Bold"
                                                       FontSize="10" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="HP: {0}/{1} AC: {2}">
                                                        <Binding Path="CurrentHitPoints"/>
                                                        <Binding Path="MaxHitPoints"/>
                                                        <Binding Path="ArmorClass"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#30E94560"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Center: Battle Map -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundDarkBrush}"
                    ClipToBounds="True">
                <Canvas x:Name="BattleCanvas" Background="Transparent"/>
            </Border>

            <!-- Right: Combatant Stats -->
            <Border Grid.Column="2" Background="{StaticResource BackgroundMidBrush}"
                    BorderBrush="#333" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8"
                                DataContext="{Binding SelectedCombatant}">
                        <!-- Combatant name heading -->
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{StaticResource AccentPrimaryBrush}"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   FontWeight="Bold" Margin="0,0,0,8"/>

                        <!-- HP -->
                        <TextBlock Text="Hit Points" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeSmall}"/>
                        <TextBlock Foreground="{StaticResource HealthGoodBrush}"
                                   FontSize="{StaticResource FontSizeBody}" FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="CurrentHitPoints"/>
                                    <Binding Path="MaxHitPoints"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- AC / Speed -->
                        <UniformGrid Columns="2" Margin="0,8">
                            <StackPanel>
                                <TextBlock Text="Armor Class" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="{StaticResource FontSizeSmall}"/>
                                <TextBlock Text="{Binding ArmorClass}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Speed" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="{StaticResource FontSizeSmall}"/>
                                <TextBlock Text="{Binding Speed, StringFormat='{}{0} ft'}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Ability Scores -->
                        <TextBlock Text="Ability Scores"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="0,4,0,4"/>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="2">
                                <TextBlock Text="STR" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Strength}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="DEX" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Dexterity}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="CON" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Constitution}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="INT" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Intelligence}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="WIS" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Wisdom}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="CHA" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Charisma}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundMidBrush}"
                BorderBrush="#333" BorderThickness="0,1,0,0" Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="D&amp;D Battle Planner — MVVM Edition"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
