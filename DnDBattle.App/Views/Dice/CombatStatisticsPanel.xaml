<UserControl x:Class="DnDBattle.Views.Dice.CombatStatisticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush_Background_Medium}">

    <UserControl.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Hint}"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="📊 Combat Statistics" Foreground="{StaticResource Brush_Info}" FontWeight="Bold" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Round: " Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                        <TextBlock x:Name="TxtRound" Text="0" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text=" • Duration: " Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                        <TextBlock x:Name="TxtDuration" Text="0:00" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="🔄" 
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource Brush_Text_Primary}"
                        Click="BtnRefresh_Click"
                        ToolTip="Refresh Statistics"/>
            </Grid>
        </Border>

        <!-- Stats List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StatsContainer" Margin="10"/>
        </ScrollViewer>

        <!-- Summary -->
        <Border Grid.Row="2" Background="{StaticResource Brush_Background_Dark}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Damage" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalDamage" Text="0" Style="{StaticResource StatValue}" Foreground="{StaticResource Brush_Error}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Healing" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalHealing" Text="0" Style="{StaticResource StatValue}" Foreground="{StaticResource Brush_Success}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Kills" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalKills" Text="0" Style="{StaticResource StatValue}" Foreground="{StaticResource Brush_Warning}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Crits" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalCrits" Text="0" Style="{StaticResource StatValue}" Foreground="{StaticResource Brush_Warning}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>