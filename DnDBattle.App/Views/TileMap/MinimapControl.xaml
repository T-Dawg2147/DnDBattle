<UserControl x:Class="DnDBattle.Views.TileMap.MinimapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="200">

    <Border Background="{StaticResource Brush_Background_Dark}"
            BorderBrush="{StaticResource Brush_Border_Normal}"
            BorderThickness="2"
            CornerRadius="4">
        <Grid>
            <!-- Minimap Canvas -->
            <Canvas x:Name="MinimapCanvas" ClipToBounds="True"/>

            <!-- Viewport indicator -->
            <Rectangle x:Name="ViewportRect"
                       Stroke="{StaticResource Brush_Accent_Primary}"
                       StrokeThickness="2"
                       Fill="Transparent"
                       IsHitTestVisible="False"/>

            <!-- Label -->
            <TextBlock Text="Minimap" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Top"
                       Margin="0,5"
                       FontSize="10"
                       Foreground="{StaticResource Brush_Text_Hint}"/>
        </Grid>
    </Border>
</UserControl>