<Window x:Class="DnDBattle.Views.Multiplayer.HostGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌐 Host Game (DM)" Height="700" Width="850"
        Background="{StaticResource Brush_Background_Dark}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Server Controls -->
        <Border Grid.Column="0" Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,0,6,8">
            <StackPanel>
                <TextBlock Text="Server Controls" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Port:" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="PortInput" Width="80" Text="7777"
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button x:Name="StartStopButton" Content="Start Server" Click="StartStopButton_Click"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="12,6" Margin="0,0,8,0"
                            BorderThickness="0" Cursor="Hand"/>
                    <TextBlock x:Name="StatusText" Text="Stopped" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Token Assignment -->
        <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="6,0,0,8">
            <StackPanel>
                <TextBlock Text="Token Assignment" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox x:Name="PlayerCombo" Width="120" Margin="0,0,6,0"
                              Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}"/>
                    <ComboBox x:Name="TokenCombo" Width="120" DisplayMemberPath="Name" Margin="0,0,6,0"
                              Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}"/>
                    <Button Content="Assign" Click="AssignToken_Click"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Connected Players -->
        <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,0,6,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Connected Players" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <ListView x:Name="PlayersListView" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Player" Width="120" DisplayMemberBinding="{Binding Username}"/>
                            <GridViewColumn Header="Tokens" Width="140" DisplayMemberBinding="{Binding AssignedTokenIds.Count}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- Server Log + Chat -->
        <Border Grid.Column="1" Grid.Row="1" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="6,0,0,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Server Log" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <TextBox x:Name="ServerLogBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Secondary}" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <!-- Chat Section -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Chat" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBox x:Name="ChatInput" Width="600"
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"
                             KeyDown="ChatInput_KeyDown"/>
                    <Button Content="Send" Click="SendChat_Click" Margin="6,0,0,0"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="12,4" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
                <ListBox x:Name="ChatHistory" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0" Height="100"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
