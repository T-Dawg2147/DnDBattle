<Window x:Class="DnDBattle.Views.Multiplayer.JoinGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌐 Join Game (Player)" Height="650" Width="750"
        Background="{StaticResource Brush_Background_Dark}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Connection Panel -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Connection" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Host:" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center" Width="60"/>
                        <TextBox Text="{Binding ServerHost, UpdateSourceTrigger=PropertyChanged}" Width="140"
                                 Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Port:" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center" Width="40"/>
                        <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                 Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Name:" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center" Width="50"/>
                        <TextBox Text="{Binding PlayerName, UpdateSourceTrigger=PropertyChanged}" Width="120"
                                 Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                    </StackPanel>
                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,0,6,4"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="12,4" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Margin="0,0,6,4"
                            Background="{StaticResource Brush_Background_Hover}" Foreground="{StaticResource Brush_Text_Primary}" Padding="12,4" BorderThickness="0" Cursor="Hand"/>
                </WrapPanel>
                <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource Brush_Accent_Primary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Panel -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,0,6,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Chat" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBox Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}" Width="230"
                             Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                    <Button Content="Send" Command="{Binding SendChatCommand}" Margin="6,0,0,0"
                            Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding ChatMessages}" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <!-- Dice + Notifications -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="6,0,0,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Dice Rolling -->
            <Border Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Dice Rolling" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBox Text="{Binding DiceExpression, UpdateSourceTrigger=PropertyChanged}" Width="100"
                                 Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderBrush="{StaticResource Brush_Border_Hover}" Padding="4"/>
                        <Button Content="Roll" Command="{Binding RollDiceCommand}" Margin="6,0,0,0"
                                Background="{StaticResource Brush_Accent_Primary}" Foreground="{StaticResource Brush_Text_Primary}" Padding="12,4" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding DiceResults}" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}"
                             BorderThickness="0" MaxHeight="120"/>
                </StackPanel>
            </Border>

            <!-- Notifications -->
            <Border Grid.Row="1" Background="{StaticResource Brush_Background_Dark}" CornerRadius="8" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Notifications" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding Notifications}" Background="{StaticResource Brush_Background_Control}" Foreground="{StaticResource Brush_Text_Primary}" BorderThickness="0"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
