<Window x:Class="DnDBattle.Views.Editors.InteractiveEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interactive Object" Height="600" Width="550">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="⚙️ Configure Interactive Object" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="Object Name:"/>
                <TextBox x:Name="TxtName" Text="Mysterious Lever"/>

                <TextBlock Text="Object Type:"/>
                <ComboBox x:Name="CmbObjectType" SelectedIndex="0">
                    <ComboBoxItem Content="⚙️ Lever"/>
                    <ComboBoxItem Content="🔘 Button"/>
                    <ComboBoxItem Content="📦 Chest"/>
                    <ComboBoxItem Content="🚪 Door"/>
                    <ComboBoxItem Content="🗿 Statue"/>
                    <ComboBoxItem Content="⛪ Altar"/>
                </ComboBox>

                <TextBlock Text="Examine Description:"/>
                <TextBox x:Name="TxtExamine" Text="You see a lever on the wall." 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <TextBlock Text="Activation Effect:"/>
                <TextBox x:Name="TxtEffect" Text="You pull the lever. You hear a distant rumbling." 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <CheckBox x:Name="ChkRequiresCheck" Content="Requires skill check"/>
                <TextBlock Text="Required Skill:"/>
                <ComboBox x:Name="CmbSkill" SelectedIndex="0">
                    <ComboBoxItem Content="Strength"/>
                    <ComboBoxItem Content="Dexterity"/>
                    <ComboBoxItem Content="Lockpicking"/>
                    <ComboBoxItem Content="Arcana"/>
                </ComboBox>

                <TextBlock Text="Check DC:"/>
                <TextBox x:Name="TxtDC" Text="15"/>

                <CheckBox x:Name="ChkSingleUse" Content="Single use only"/>
                <CheckBox x:Name="ChkLocked" Content="Object is locked"/>

                <Separator/>
                <TextBlock Text="For Chests:" FontWeight="Bold"/>
                <TextBlock Text="Gold Pieces:"/>
                <TextBox x:Name="TxtGold" Text="0"/>
                <TextBlock Text="Items:"/>
                <TextBox x:Name="TxtItems" Text="" />
                <!-- PlaceholderText="e.g., Potion of Healing, +1 Sword" -->
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Save" Width="100" Height="35" Margin="5" 
                    Click="Save_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>