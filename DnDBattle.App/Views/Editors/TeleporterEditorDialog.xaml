<Window x:Class="DnDBattle.Views.Editors.TeleporterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teleporter Configuration" Height="450" Width="500" Background="{StaticResource Brush_Background_Dark}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="🌀 Configure Teleporter" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <!-- Basic Info -->
                <TextBlock Text="Teleporter Name:"/>
                <TextBox x:Name="TxtName" Text="Mystical Portal"/>

                <TextBlock Text="Description:"/>
                <TextBox x:Name="TxtDescription" Text="You are transported in a flash of light!" 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <Separator/>

                <!-- Destination -->
                <TextBlock Text="📍 Destination" Style="{StaticResource SectionHeader}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Destination X:"/>
                        <TextBox x:Name="TxtDestX" Text="10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Destination Y:"/>
                        <TextBox x:Name="TxtDestY" Text="10"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="💡 Tip: Right-click on the tile map to get coordinates" 
                           Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,5"/>

                <Separator/>

                <!-- Settings -->
                <TextBlock Text="⚙️ Settings" Style="{StaticResource SectionHeader}"/>

                <CheckBox x:Name="ChkIsVisible" Content="Teleporter is visible to players" IsChecked="True"/>
                <CheckBox x:Name="ChkIsActive" Content="Teleporter is currently active" IsChecked="True"/>
                <CheckBox x:Name="ChkRequiresConsent" Content="Ask for confirmation before teleporting" IsChecked="True"/>
                <CheckBox x:Name="ChkIsOneWay" Content="This is a one-way teleporter"/>

                <Separator/>

                <!-- Visual Aid -->
                <Border Background="{StaticResource Brush_Background_Control}" 
                        BorderBrush="{StaticResource Brush_Border_Normal}"
                        BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="📝 Notes:" FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource HintText}">
                            • Tokens will be moved instantly to the destination
                            <LineBreak/>
                            • If "requires consent" is checked, a prompt will appear
                            <LineBreak/>
                            • One-way teleporters cannot be reversed
                            <LineBreak/>
                            • You can create two-way teleports by placing two teleporters
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Save" Width="100" Height="35" Margin="5" 
                    Click="Save_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>