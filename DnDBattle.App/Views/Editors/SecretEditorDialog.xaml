<Window x:Class="DnDBattle.Views.Editors.SecretEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secret Configuration" Height="500" Width="500" Background="{StaticResource Brush_Background_Dark}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="🔍 Configure Secret" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="Secret Name:"/>
                <TextBox x:Name="TxtName" Text="Hidden Door"/>

                <TextBlock Text="Secret Type:"/>
                <ComboBox x:Name="CmbSecretType" SelectedIndex="0">
                    <ComboBoxItem Content="Hidden Door"/>
                    <ComboBoxItem Content="Secret Passage"/>
                    <ComboBoxItem Content="Hidden Treasure"/>
                    <ComboBoxItem Content="Compartment"/>
                    <ComboBoxItem Content="Illusion"/>
                    <ComboBoxItem Content="False Door"/>
                </ComboBox>

                <TextBlock Text="Investigation DC:"/>
                <TextBox x:Name="TxtDC" Text="15"/>

                <TextBlock Text="Discovery Description:"/>
                <TextBox x:Name="TxtDiscovery" Text="You discover a hidden passage!" 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <CheckBox x:Name="ChkRequiresActivation" Content="Requires activation after discovery"/>

                <TextBlock Text="Activation Description:"/>
                <TextBox x:Name="TxtActivation" Text="You push on the wall and it swings open." 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Save" Width="100" Height="35" Margin="5" 
                    Click="Save_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>