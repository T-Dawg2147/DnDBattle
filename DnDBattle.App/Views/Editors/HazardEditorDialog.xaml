<Window x:Class="DnDBattle.Views.Editors.HazardEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hazard Configuration" Height="650" Width="550" Background="{StaticResource Brush_Background_Dark}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="☠️ Configure Hazard" FontSize="16" FontWeight="Bold"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <!-- Basic Info -->
                <TextBlock Text="Hazard Name:"/>
                <TextBox x:Name="TxtName" Text="Pool of Lava"/>

                <TextBlock Text="Hazard Type:"/>
                <ComboBox x:Name="CmbHazardType" SelectedIndex="1">
                    <ComboBoxItem Content="🔥 Fire"/>
                    <ComboBoxItem Content="🌋 Lava"/>
                    <ComboBoxItem Content="🧪 Acid"/>
                    <ComboBoxItem Content="☠️ Poison Gas"/>
                    <ComboBoxItem Content="❄️ Ice"/>
                    <ComboBoxItem Content="⚡ Lightning"/>
                    <ComboBoxItem Content="🌿 Thorns"/>
                    <ComboBoxItem Content="🏜️ Quicksand"/>
                    <ComboBoxItem Content="🗡️ Spikes"/>
                    <ComboBoxItem Content="✨ Magic Zone"/>
                </ComboBox>

                <TextBlock Text="Description:"/>
                <TextBox x:Name="TxtDescription" Text="A pool of molten lava." 
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <Separator/>

                <!-- Damage -->
                <TextBlock Text="💥 Damage" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Damage Dice:"/>
                <TextBox x:Name="TxtDamageDice" Text="2d10"/>

                <TextBlock Text="Damage Type:"/>
                <ComboBox x:Name="CmbDamageType" SelectedIndex="3">
                    <ComboBoxItem Content="🔨 Bludgeoning"/>
                    <ComboBoxItem Content="🗡️ Piercing"/>
                    <ComboBoxItem Content="⚔️ Slashing"/>
                    <ComboBoxItem Content="🔥 Fire"/>
                    <ComboBoxItem Content="❄️ Cold"/>
                    <ComboBoxItem Content="⚡ Lightning"/>
                    <ComboBoxItem Content="💥 Thunder"/>
                    <ComboBoxItem Content="🧪 Acid"/>
                    <ComboBoxItem Content="☠️ Poison"/>
                    <ComboBoxItem Content="💀 Necrotic"/>
                    <ComboBoxItem Content="✨ Radiant"/>
                    <ComboBoxItem Content="💫 Force"/>
                    <ComboBoxItem Content="🧠 Psychic"/>
                </ComboBox>

                <TextBlock Text="Damage Trigger:"/>
                <ComboBox x:Name="CmbDamageTrigger" SelectedIndex="0">
                    <ComboBoxItem Content="On Enter (when stepping in)"/>
                    <ComboBoxItem Content="Start of Turn (if inside)"/>
                    <ComboBoxItem Content="End of Turn (if inside)"/>
                    <ComboBoxItem Content="Always (enter + every turn)"/>
                </ComboBox>

                <Separator/>

                <!-- Saving Throw -->
                <TextBlock Text="🛡️ Saving Throw" Style="{StaticResource SectionHeader}"/>

                <CheckBox x:Name="ChkAllowsSave" Content="Allow saving throw" IsChecked="True"/>

                <TextBlock Text="Save Ability:"/>
                <ComboBox x:Name="CmbSaveAbility" SelectedIndex="1">
                    <ComboBoxItem Content="STR"/>
                    <ComboBoxItem Content="DEX"/>
                    <ComboBoxItem Content="CON"/>
                    <ComboBoxItem Content="INT"/>
                    <ComboBoxItem Content="WIS"/>
                    <ComboBoxItem Content="CHA"/>
                </ComboBox>

                <TextBlock Text="Save DC:"/>
                <TextBox x:Name="TxtSaveDC" Text="13"/>

                <CheckBox x:Name="ChkSaveNegates" Content="Successful save negates all damage"/>
                <CheckBox x:Name="ChkSaveHalves" Content="Successful save halves damage" IsChecked="True"/>

                <Separator/>

                <!-- Ongoing Effects -->
                <TextBlock Text="♻️ Ongoing Effects" Style="{StaticResource SectionHeader}"/>

                <CheckBox x:Name="ChkDamagesEachTurn" Content="Damages at start of each turn while inside"/>

                <TextBlock Text="Per-Turn Damage (if ongoing):"/>
                <TextBox x:Name="TxtPerTurnDamage" Text="1d10"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Save" Width="100" Height="35" Margin="5" 
                    Click="Save_Click" Style="{StaticResource AccentButton}"/>
            <Button Content="❌ Cancel" Width="100" Height="35" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>