<UserControl x:Class="DnDBattle.Views.Combat.InitiativeTrackerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:DnDBattle.Views"
             xmlns:viewsDice="clr-namespace:DnDBattle.Views.Dice"
             mc:Ignorable="d" 
             d:DesignWidth="280"
             Background="{StaticResource Brush_Background_Medium}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Initiative Entry Style -->
        <Style x:Key="InitiativeEntryStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Control}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Current Turn Style -->
        <Style x:Key="CurrentTurnStyle" TargetType="Border" BasedOn="{StaticResource InitiativeEntryStyle}">
            <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Success}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Button Style -->
        <Style x:Key="TrackerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Background_Hover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Green) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource TrackerButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Brush_Background_Dark}" Padding="12,10">
            <StackPanel>
                <TextBlock Text="Initiative Tracker" 
                   FontSize="14" 
                   FontWeight="Bold" 
                   Foreground="{StaticResource Brush_Text_Primary}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Round: " Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                    <TextBlock x:Name="TxtRound" Text="1" Foreground="{StaticResource Brush_Info}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="  •  " Foreground="{StaticResource Brush_Border_Normal}" FontSize="11"/>
                    <TextBlock x:Name="TxtTurnCount" Text="0 creatures" Foreground="{StaticResource Brush_Text_Hint}" FontSize="11"/>
                    <viewsDice:TurnTimerDisplay x:Name="TurnTimer" Margin="0,0,0,10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Combat Controls -->
        <Border Grid.Row="1" Background="{StaticResource Brush_Background_Dark}" Padding="12,8" Margin="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="◀ Previous"
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnPrevious_Click"
                        IsEnabled="{Binding IsInCombat}"
                        Margin="0,0,4,0"/>

                <Button x:Name="BtnStartCombat"
                        Grid.Column="1" 
                        Content="⚔️ Start Combat"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="BtnStartCombat_Click"
                        MinWidth="120"/>

                <Button Grid.Column="2" 
                        Content="Next ▶"
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnNext_Click"
                        IsEnabled="{Binding IsInCombat}"
                        Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Initiative List -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="8,8,8,0">
            <ItemsControl x:Name="InitiativeList" 
                          AllowDrop="True"
                          Drop="InitiativeList_Drop">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="EntryBorder"
                                Style="{StaticResource InitiativeEntryStyle}"
                                MouseLeftButtonDown="Entry_MouseLeftButtonDown"
                                MouseMove="Entry_MouseMove"
                                AllowDrop="True"
                                DragOver="Entry_DragOver"
                                Drop="Entry_Drop"
                                Tag="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Drag Handle -->
                                <TextBlock Grid.Column="0" 
                                           Text="⋮⋮" 
                                           Foreground="{StaticResource Brush_Text_Disabled}" 
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Cursor="SizeAll"/>

                                <!-- Initiative Number -->
                                <Grid Grid.Column="1" Width="40" Height="40" Margin="0,0,10,0">
                                    <!-- Creature Image (circular) -->
                                    <Border Width="36" Height="36" 
                                        CornerRadius="18" 
                                        Background="{StaticResource Brush_Background_Medium}">
                                        <Image Source="{Binding Token.DisplayImage}" 
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Clip>
                                                <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                            </Image.Clip>
                                        </Image>
                                    </Border>

                                    <!-- Initiative Badge (overlay) -->
                                    <Border Background="{StaticResource Brush_Background_Medium}" 
                                        CornerRadius="10"
                                        Padding="4,1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,-2,-2">
                                        <TextBlock Text="{Binding InitiativeTotal}" 
                                           Foreground="{StaticResource Brush_Info}"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Name and Status -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   Foreground="{StaticResource Brush_Text_Primary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <!-- Player Icon -->
                                        <TextBlock Text=" 👤" 
                                                   FontSize="11"
                                                   Visibility="{Binding IsPlayer, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <!-- HP Bar -->
                                    <Grid Height="4" Margin="0,4,20,0">
                                        <Border Background="{StaticResource Brush_Background_Medium}" CornerRadius="2"/>
                                        <Border x:Name="HPBar" 
                                                CornerRadius="2" 
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Brush_Success}"/>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Grid>

                                    <!-- Status Text -->
                                    <TextBlock Text="{Binding StatusText}" 
                                               Foreground="{StaticResource Brush_Warning}"
                                               FontSize="10"
                                               FontStyle="Italic"
                                               Visibility="{Binding StatusText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="3" 
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="⏸️" 
                                            Width="28" Height="28"
                                            ToolTip="Delay Turn"
                                            Style="{StaticResource TrackerButtonStyle}"
                                            Padding="0"
                                            Click="BtnDelay_Click"
                                            Tag="{Binding}"/>
                                    <Button Content="⚡" 
                                            Width="28" Height="28"
                                            ToolTip="Ready Action"
                                            Style="{StaticResource TrackerButtonStyle}"
                                            Padding="0"
                                            Margin="4,0,0,0"
                                            Click="BtnReady_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsCurrentTurn}" Value="True">
                                <Setter TargetName="EntryBorder" Property="Style" Value="{StaticResource CurrentTurnStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDelaying}" Value="True">
                                <Setter TargetName="EntryBorder" Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasActed}" Value="True">
                                <Setter TargetName="EntryBorder" Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="3" Background="{StaticResource Brush_Background_Dark}" Padding="12,8" Margin="0,1,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="➕ Add" 
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnAddCreature_Click"
                        ToolTip="Add creature to combat"
                        Margin="0,0,4,0"/>
                <Button Content="🔄 Reset" 
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnReset_Click"
                        ToolTip="Reset initiative"
                        Margin="0,0,4,0"/>
                <Button Content="🎯 Sort" 
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnSort_Click"
                        ToolTip="Sort by initiative"
                        Margin="0,0,4,0"/>
                <Button Content="🗑️ Clear" 
                        Style="{StaticResource TrackerButtonStyle}"
                        Click="BtnClear_Click"
                        ToolTip="End combat"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>