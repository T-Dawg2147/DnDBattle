<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>DnDBattle</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>False</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\DnDBattle.Core\DnDBattle.Core.csproj" />
    <ProjectReference Include="..\DnDBattle.Data\DnDBattle.Data.csproj" />
    <ProjectReference Include="..\DnDBattle.GameLogic\DnDBattle.GameLogic.csproj" />
    <ProjectReference Include="..\DnDBattle.MapEngine\DnDBattle.MapEngine.csproj" />
    <ProjectReference Include="..\DnDBattle.Networking\DnDBattle.Networking.csproj" />
    <ProjectReference Include="..\DnDBattle.UI.Shared\DnDBattle.UI.Shared.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Resources\Entities\Tokens\default-token.png">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <None Update="Resources\Tiles\Floor\dungeon_floor_01.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Resources\Tiles\Door\" />
    <Folder Include="Resources\Tiles\Wall\" />
  </ItemGroup>
</Project>
